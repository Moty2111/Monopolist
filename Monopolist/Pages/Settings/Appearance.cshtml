@page
@model Monoplist.Pages.Settings.AppearanceModel
@{
    Layout = null;
    ViewData["Title"] = Model.Language == "ru" ? "Внешний вид" : (Model.Language == "en" ? "Appearance" : "Сыртқы түрі");
    var userId = User.FindFirst("UserId")?.Value;
    var avatarUrl = HttpContext.Request.Cookies[$"user_avatar_{userId}"] ?? "";
}

<!DOCTYPE html>
<html lang="@Model.Language">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        :root {
            --primary: @Model.Input.CustomColor;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --info: #3b82f6;
            --info-bg: #dbeafe;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
            --info-bg: #1e3a5f;
        }

        body.compact-mode .sidebar {
            width: 240px;
        }

        body.compact-mode .sidebar-header {
            padding: 16px;
        }

            body.compact-mode .sidebar-header i {
                font-size: 32px;
            }

            body.compact-mode .sidebar-header h2 {
                font-size: 20px;
            }

        body.compact-mode .sidebar-nav li a {
            padding: 8px 12px;
        }

        body.compact-mode .top-bar {
            padding: 12px 24px;
        }

        body.compact-mode .dashboard {
            padding: 16px;
        }

            body.compact-mode .dashboard h1 {
                font-size: 1.8rem;
            }

        body.compact-mode .subtitle {
            font-size: 0.9rem;
            margin-bottom: 16px;
        }

        body.compact-mode .form-group {
            margin-bottom: 1rem;
        }

        body.compact-mode .form-control {
            padding: 8px 12px;
        }

        body.compact-mode .btn-primary,
        body.compact-mode .btn-secondary {
            padding: 8px 18px;
        }

        body.no-animations * {
            transition: none !important;
            animation: none !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        /* ===== САЙДБАР ===== */
        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        /* ===== ОСНОВНОЙ КОНТЕНТ ===== */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
            position: relative;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            background: var(--surface-hover);
            border-radius: 40px;
            transition: var(--transition);
            cursor: pointer;
        }

            .user-profile:hover {
                background: var(--surface);
                box-shadow: var(--shadow-sm);
            }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

            .user-avatar i {
                font-size: 40px;
            }

            .user-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .user-details {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .user-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .user-menu {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 220px;
            background: var(--surface);
            border-radius: 12px;
            box-shadow: var(--shadow-hover);
            border: 1px solid var(--border);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.2s ease;
            z-index: 1000;
        }

            .user-menu.show {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
            width: 100%;
            text-align: left;
            border: none;
            background: none;
            font-size: 0.95rem;
            cursor: pointer;
        }

            .menu-item:hover {
                background: var(--surface-hover);
                color: var(--primary);
            }

            .menu-item.logout {
                color: var(--danger);
            }

                .menu-item.logout:hover {
                    background: var(--danger-bg);
                }

        .menu-divider {
            height: 1px;
            background: var(--border);
            margin: 8px 0;
        }

        /* ===== КНОПКА ПЕРЕКЛЮЧЕНИЯ ТЕМЫ (полностью статичная, без свечения, без трансформаций) ===== */
        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
            outline: none;
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
                /* Убраны transform и box-shadow */
            }

            .theme-toggle:focus-visible {
                border-color: var(--primary); /* Только изменение цвета границы */
                /* box-shadow удалён */
            }

            .theme-toggle:active {
                /* Убрана transform: scale(0.95); */
            }

            .theme-toggle i {
                font-size: 1.2rem;
                transition: color 0.2s ease; /* оставляем только для цвета */
                /* никакой трансформации */
            }

        .content {
            padding: 24px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 24px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 2rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 8px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 24px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 12px;
        }

        .alert {
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: var(--success-bg);
            color: var(--success);
            border-left: 4px solid var(--success);
        }

        .form-container {
            max-width: 600px;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

            .form-group label {
                display: block;
                font-weight: 600;
                font-size: 0.9rem;
                color: var(--primary);
                margin-bottom: 5px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            font-size: 1rem;
            border: 2px solid var(--border);
            border-radius: 12px;
            background: var(--surface);
            color: var(--text-primary);
            transition: var(--transition);
            font-family: 'Poppins', sans-serif;
        }

            .form-control:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
            }

        select.form-control {
            appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%23FF6B00' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 1em;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .checkbox-group input[type="checkbox"] {
                width: 20px;
                height: 20px;
                cursor: pointer;
                accent-color: var(--primary);
            }

        .color-picker {
            width: 100%;
            height: 40px;
            padding: 0;
            border: 2px solid var(--border);
            border-radius: 8px;
            cursor: pointer;
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .btn-primary, .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 22px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
            }

        .btn-secondary {
            background: var(--surface);
            color: var(--text-secondary);
            border: 2px solid var(--border);
        }

            .btn-secondary:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
                transform: translateY(-2px);
            }

        .preview-card {
            margin-top: 30px;
            padding: 20px;
            background: var(--surface-hover);
            border-radius: 16px;
            border: 1px solid var(--border);
        }

            .preview-card h3 {
                color: var(--primary);
                margin-bottom: 15px;
                font-size: 1.1rem;
            }

        .theme-preview {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        .theme-option {
            width: 150px;
            padding: 15px;
            border-radius: 12px;
            border: 2px solid var(--border);
            cursor: pointer;
            transition: var(--transition);
        }

            .theme-option.selected {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
            }

            .theme-option.light {
                background: #ffffff;
                color: #1e293b;
            }

            .theme-option.dark {
                background: #1a1a1a;
                color: #f0f0f0;
            }

            .theme-option i {
                font-size: 24px;
                margin-bottom: 10px;
            }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                transform: translateX(-100%);
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
            }

            .menu-toggle {
                display: block;
            }

            .user-profile .user-details {
                display: none;
            }

            .theme-toggle {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-primary, .btn-secondary {
                width: 100%;
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }
        }
    </style>
</head>
<body class="@(Model.Input.Theme == "dark" ? "dark-theme" : "") @(Model.Input.CompactMode ? "compact-mode" : "") @(Model.Input.Animations ? "" : "no-animations")">
    <div class="app">
        <!-- Боковое меню -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> @(Model.Language == "ru" ? "Главная панель" : Model.Language == "en" ? "Dashboard" : "Бас панель")</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> @(Model.Language == "ru" ? "Каталог товаров" : Model.Language == "en" ? "Products" : "Тауарлар")</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> @(Model.Language == "ru" ? "Продажи" : Model.Language == "en" ? "Orders" : "Сатулар")</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> @(Model.Language == "ru" ? "Клиенты" : Model.Language == "en" ? "Customers" : "Клиенттер")</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> @(Model.Language == "ru" ? "Склад" : Model.Language == "en" ? "Warehouse" : "Қойма")</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> @(Model.Language == "ru" ? "Поставщики" : Model.Language == "en" ? "Suppliers" : "Жеткізушілер")</a></li>
                    <li><a asp-page="/Reports/Index"><i class="fas fa-chart-line"></i> @(Model.Language == "ru" ? "Отчеты" : Model.Language == "en" ? "Reports" : "Есептер")</a></li>
                    <li><a asp-page="/Settings/Index" class="active"><i class="fas fa-cog"></i> @(Model.Language == "ru" ? "Настройки" : Model.Language == "en" ? "Settings" : "Баптаулар")</a></li>
                </ul>
            </nav>
        </aside>

        <!-- Основной контент -->
        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <!-- Кнопка переключения темы (полностью статичная) -->
                    <div class="theme-toggle" id="themeToggle" title="@(Model.Language == "ru" ? "Сменить тему" : Model.Language == "en" ? "Toggle theme" : "Тақырыпты ауыстыру")" role="button" tabindex="0" aria-label="Переключить тему">
                        <i class="fas fa-sun"></i>
                    </div>
                    <div class="user-profile" onclick="toggleUserMenu()">
                        <div class="user-avatar">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user-circle\'></i>';" />
                            }
                            else
                            {
                                <i class="fas fa-user-circle"></i>
                            }
                        </div>
                        <div class="user-details">
                            <span class="user-name">@User.Identity?.Name</span>
                            <span class="user-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</span>
                        </div>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-menu" id="userMenu">
                        <a asp-page="/Settings/Profile" class="menu-item"><i class="fas fa-user"></i> @(Model.Language == "ru" ? "Профиль" : Model.Language == "en" ? "Profile" : "Профиль")</a>
                        <a asp-page="/Settings/Security" class="menu-item"><i class="fas fa-shield-alt"></i> @(Model.Language == "ru" ? "Безопасность" : Model.Language == "en" ? "Security" : "Қауіпсіздік")</a>
                        <a asp-page="/Settings/Appearance" class="menu-item"><i class="fas fa-palette"></i> @(Model.Language == "ru" ? "Внешний вид" : Model.Language == "en" ? "Appearance" : "Сыртқы түр")</a>
                        <div class="menu-divider"></div>
                        <form method="post" asp-page="/Account/Logout" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="menu-item logout"><i class="fas fa-sign-out-alt"></i> @(Model.Language == "ru" ? "Выйти" : Model.Language == "en" ? "Logout" : "Шығу")</button>
                        </form>
                    </div>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle"></i> @TempData["Success"]
                        </div>
                    }

                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">@(Model.Language == "ru" ? "Настройка внешнего вида интерфейса" : Model.Language == "en" ? "Interface appearance settings" : "Интерфейстің сыртқы түрін баптау")</p>

                    <div class="form-container">
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="form-group">
                                <label asp-for="Input.Theme">@(Model.Language == "ru" ? "Тема оформления" : Model.Language == "en" ? "Theme" : "Тақырып")</label>
                                <div class="theme-preview">
                                    <div class="theme-option light @(Model.Input.Theme == "light" ? "selected" : "")" onclick="document.getElementById('theme_light').click();">
                                        <i class="fas fa-sun"></i>
                                        <div>@(Model.Language == "ru" ? "Светлая" : Model.Language == "en" ? "Light" : "Ашық")</div>
                                    </div>
                                    <div class="theme-option dark @(Model.Input.Theme == "dark" ? "selected" : "")" onclick="document.getElementById('theme_dark').click();">
                                        <i class="fas fa-moon"></i>
                                        <div>@(Model.Language == "ru" ? "Тёмная" : Model.Language == "en" ? "Dark" : "Қараңғы")</div>
                                    </div>
                                </div>
                                <div style="display: none;">
                                    <input type="radio" asp-for="Input.Theme" id="theme_light" value="light" />
                                    <input type="radio" asp-for="Input.Theme" id="theme_dark" value="dark" />
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.CustomColor">@(Model.Language == "ru" ? "Основной цвет" : Model.Language == "en" ? "Primary color" : "Негізгі түс")</label>
                                <input asp-for="Input.CustomColor" type="color" class="color-picker" />
                                <span asp-validation-for="Input.CustomColor" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.Language">@(Model.Language == "ru" ? "Язык интерфейса" : Model.Language == "en" ? "Interface language" : "Интерфейс тілі")</label>
                                <select asp-for="Input.Language" class="form-control">
                                    <option value="ru">Русский</option>
                                    <option value="en">English</option>
                                    <option value="kk">Қазақша</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <div class="checkbox-group">
                                    <input asp-for="Input.CompactMode" />
                                    <label asp-for="Input.CompactMode">@(Model.Language == "ru" ? "Компактный режим (уменьшенные отступы)" : Model.Language == "en" ? "Compact mode (reduced spacing)" : "Ықшам режим (кішірейтілген аралықтар)")</label>
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="checkbox-group">
                                    <input asp-for="Input.Animations" />
                                    <label asp-for="Input.Animations">@(Model.Language == "ru" ? "Анимации интерфейса" : Model.Language == "en" ? "Interface animations" : "Интерфейс анимациялары")</label>
                                </div>
                            </div>

                            <div class="preview-card">
                                <h3><i class="fas fa-eye"></i> @(Model.Language == "ru" ? "Предпросмотр" : Model.Language == "en" ? "Preview" : "Алдын ала қарау")</h3>
                                <div style="display: flex; gap: 20px; align-items: center; flex-wrap: wrap;">
                                    <span class="status-badge" style="background: var(--primary); color: white; padding: 4px 12px; border-radius: 20px;">@(Model.Language == "ru" ? "Кнопка" : Model.Language == "en" ? "Button" : "Батырма")</span>
                                    <span class="status-badge" style="background: var(--success-bg); color: var(--success); padding: 4px 12px; border-radius: 20px;">@(Model.Language == "ru" ? "Успех" : Model.Language == "en" ? "Success" : "Сәтті")</span>
                                    <span class="status-badge" style="background: var(--danger-bg); color: var(--danger); padding: 4px 12px; border-radius: 20px;">@(Model.Language == "ru" ? "Ошибка" : Model.Language == "en" ? "Error" : "Қате")</span>
                                    <span class="status-badge" style="background: var(--warning-bg); color: var(--warning); padding: 4px 12px; border-radius: 20px;">@(Model.Language == "ru" ? "Внимание" : Model.Language == "en" ? "Warning" : "Назар аударыңыз")</span>
                                </div>
                                <p style="margin-top: 15px; color: var(--text-secondary);">
                                    @(Model.Language == "ru" ? "Пример текста для демонстрации выбранной темы и цветовой схемы." : Model.Language == "en" ? "Example text to demonstrate the selected theme and color scheme." : "Таңдалған тақырып пен түс схемасын көрсетуге арналған мәтін мысалы.")
                                </p>
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn-primary">
                                    <i class="fas fa-save"></i> @(Model.Language == "ru" ? "Сохранить настройки" : Model.Language == "en" ? "Save settings" : "Баптауларды сақтау")
                                </button>
                                <a asp-page="Index" class="btn-secondary">
                                    <i class="fas fa-times"></i> @(Model.Language == "ru" ? "Отмена" : Model.Language == "en" ? "Cancel" : "Бас тарту")
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = themeToggle.querySelector('i');
            const themeLightRadio = document.getElementById('theme_light');
            const themeDarkRadio = document.getElementById('theme_dark');
            const themeOptions = document.querySelectorAll('.theme-option');

            // Мобильное меню
            if (menuToggle) {
                menuToggle.addEventListener('click', () => body.classList.toggle('sidebar-open'));
                document.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(e.target) && !menuToggle.contains(e.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            // Функция обновления темы: меняет класс на body, иконку кнопки и выделение опций
            function setTheme(theme) {
                if (theme === 'dark') {
                    body.classList.add('dark-theme');
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                    if (themeDarkRadio) themeDarkRadio.checked = true;
                    themeOptions.forEach(opt => {
                        opt.classList.toggle('selected', opt.classList.contains('dark'));
                    });
                } else {
                    body.classList.remove('dark-theme');
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                    if (themeLightRadio) themeLightRadio.checked = true;
                    themeOptions.forEach(opt => {
                        opt.classList.toggle('selected', opt.classList.contains('light'));
                    });
                }
                localStorage.setItem('theme', theme);
            }

            // Инициализация темы из сохранённой
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                setTheme('dark');
            } else {
                setTheme('light'); // по умолчанию светлая
            }

            // Обработчик клика по кнопке переключения темы в шапке
            themeToggle.addEventListener('click', function() {
                const isDark = body.classList.contains('dark-theme');
                setTheme(isDark ? 'light' : 'dark');
            });

            // Обработчики для визуальных опций темы
            themeOptions.forEach(option => {
                option.addEventListener('click', function() {
                    const newTheme = this.classList.contains('light') ? 'light' : 'dark';
                    setTheme(newTheme);
                });
            });

            // Предпросмотр кастомного цвета
            const colorPicker = document.getElementById('@Html.IdFor(m => m.Input.CustomColor)');
            if (colorPicker) {
                colorPicker.addEventListener('input', function() {
                    document.documentElement.style.setProperty('--primary', this.value);
                });
            }

            // Автоматическое скрытие алертов
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 500);
                }, 5000);
            });
        });

        function toggleUserMenu() {
            document.getElementById('userMenu').classList.toggle('show');
        }

        window.addEventListener('click', function(event) {
            const userInfo = document.querySelector('.user-info');
            const userMenu = document.getElementById('userMenu');
            if (!userInfo.contains(event.target) && userMenu.classList.contains('show')) {
                userMenu.classList.remove('show');
            }
        });
    </script>
</body>
</html>