@page
@model Monoplist.Pages.Settings.NotificationsModel
@{
    Layout = null;
    ViewData["Title"] = Model.Language == "ru" ? "Центр уведомлений" : (Model.Language == "en" ? "Notification center" : "Хабарландыру орталығы");
    var userId = User.FindFirst("UserId")?.Value;
    var avatarUrl = HttpContext.Request.Cookies[$"user_avatar_{userId}"] ?? "";
}

<!DOCTYPE html>
<html lang="@Model.Language">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        :root {
            --primary: @Model.CustomColor;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --info: #3b82f6;
            --info-bg: #dbeafe;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
            --info-bg: #1e3a5f;
        }

        body.compact-mode .sidebar {
            width: 240px;
        }

        body.compact-mode .sidebar-header {
            padding: 16px;
        }

            body.compact-mode .sidebar-header i {
                font-size: 32px;
            }

            body.compact-mode .sidebar-header h2 {
                font-size: 20px;
            }

        body.compact-mode .sidebar-nav li a {
            padding: 8px 12px;
        }

        body.compact-mode .top-bar {
            padding: 12px 24px;
        }

        body.compact-mode .content {
            padding: 16px;
        }

        body.compact-mode .dashboard {
            padding: 16px;
        }

            body.compact-mode .dashboard h1 {
                font-size: 1.8rem;
            }

        body.compact-mode .subtitle {
            font-size: 0.9rem;
            margin-bottom: 16px;
        }

        body.no-animations * {
            transition: none !important;
            animation: none !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
            position: relative;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            background: var(--surface-hover);
            border-radius: 40px;
            transition: var(--transition);
            cursor: pointer;
        }

            .user-profile:hover {
                background: var(--surface);
                box-shadow: var(--shadow-sm);
            }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

            .user-avatar i {
                font-size: 40px;
            }

            .user-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .user-details {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .user-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .user-menu {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 220px;
            background: var(--surface);
            border-radius: 12px;
            box-shadow: var(--shadow-hover);
            border: 1px solid var(--border);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.2s ease;
            z-index: 1000;
        }

            .user-menu.show {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
            width: 100%;
            text-align: left;
            border: none;
            background: none;
            font-size: 0.95rem;
            cursor: pointer;
        }

            .menu-item:hover {
                background: var(--surface-hover);
                color: var(--primary);
            }

            .menu-item.logout {
                color: var(--danger);
            }

                .menu-item.logout:hover {
                    background: var(--danger-bg);
                }

        .menu-divider {
            height: 1px;
            background: var(--border);
            margin: 8px 0;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .content {
            padding: 32px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 24px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 2rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 8px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 24px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        .mark-all-btn {
            background: none;
            border: 2px solid var(--border);
            border-radius: 30px;
            padding: 6px 16px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-secondary);
            cursor: pointer;
            transition: var(--transition);
        }

            .mark-all-btn:hover {
                border-color: var(--primary);
                color: var(--primary);
            }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 16px;
            background: var(--surface);
            border: 2px solid var(--border);
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
        }

            .back-link:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
                color: var(--text-primary);
            }

        .alert {
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: var(--success-bg);
            color: var(--success);
            border-left: 4px solid var(--success);
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger);
            border-left: 4px solid var(--danger);
        }

        .notifications-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .notification-card {
            background: var(--surface-hover);
            border-radius: 16px;
            padding: 16px 20px;
            transition: var(--transition);
            border-left: 4px solid;
            cursor: pointer;
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }

            .notification-card.unread {
                background: rgba(255, 107, 0, 0.05);
                border-left-color: var(--primary);
            }

            .notification-card.read {
                border-left-color: transparent;
                opacity: 0.8;
            }

            .notification-card:hover {
                transform: translateX(4px);
                box-shadow: var(--shadow-sm);
            }

        .notification-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 1.4rem;
        }

            .notification-icon.order {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

            .notification-icon.stock {
                background: var(--warning-bg);
                color: var(--warning);
            }

            .notification-icon.customer {
                background: var(--info-bg);
                color: var(--info);
            }

            .notification-icon.success {
                background: var(--success-bg);
                color: var(--success);
            }

            .notification-icon.warning {
                background: var(--warning-bg);
                color: var(--warning);
            }

            .notification-icon.error {
                background: var(--danger-bg);
                color: var(--danger);
            }

            .notification-icon.info {
                background: var(--info-bg);
                color: var(--info);
            }

        .notification-content {
            flex: 1;
        }

        .notification-title {
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .notification-message {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-bottom: 8px;
        }

        .notification-time {
            font-size: 0.75rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .empty-notifications {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

            .empty-notifications i {
                font-size: 64px;
                margin-bottom: 20px;
                opacity: 0.5;
            }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                transform: translateX(-100%);
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
            }

            .menu-toggle {
                display: block;
            }

            .main-content {
                width: 100%;
            }

            .top-bar {
                padding: 12px 16px;
            }

            .page-title {
                font-size: 1.25rem;
            }

            .user-profile .user-details {
                display: none;
            }

            .content {
                padding: 16px;
            }

            .dashboard {
                padding: 16px;
            }

            .notification-card {
                padding: 12px;
                gap: 12px;
            }

            .notification-icon {
                width: 36px;
                height: 36px;
                font-size: 1.1rem;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .btn-logout {
                padding: 8px 12px;
            }
        }
    </style>
</head>
<body class="@(Model.Theme == "dark" ? "dark-theme" : "") @(Model.CompactMode ? "compact-mode" : "") @(Model.Animations ? "" : "no-animations")">
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> @(Model.Language == "ru" ? "Главная панель" : Model.Language == "en" ? "Dashboard" : "Бас панель")</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> @(Model.Language == "ru" ? "Каталог товаров" : Model.Language == "en" ? "Products" : "Тауарлар каталогы")</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> @(Model.Language == "ru" ? "Продажи" : Model.Language == "en" ? "Orders" : "Сатулар")</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> @(Model.Language == "ru" ? "Клиенты" : Model.Language == "en" ? "Customers" : "Клиенттер")</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> @(Model.Language == "ru" ? "Склад" : Model.Language == "en" ? "Warehouse" : "Қойма")</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> @(Model.Language == "ru" ? "Поставщики" : Model.Language == "en" ? "Suppliers" : "Жеткізушілер")</a></li>
                    <li><a asp-page="/Reports/Index"><i class="fas fa-chart-line"></i> @(Model.Language == "ru" ? "Отчеты" : Model.Language == "en" ? "Reports" : "Есептер")</a></li>
                    <li><a asp-page="/Settings/Index" class="active"><i class="fas fa-cog"></i> @(Model.Language == "ru" ? "Настройки" : Model.Language == "en" ? "Settings" : "Баптаулар")</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <div class="theme-toggle" id="themeToggle"><i class="fas fa-sun"></i></div>
                    <div class="user-profile" onclick="toggleUserMenu()">
                        <div class="user-avatar">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user-circle\'></i>';" />
                            }
                            else
                            {
                                <i class="fas fa-user-circle"></i>
                            }
                        </div>
                        <div class="user-details">
                            <span class="user-name">@User.Identity?.Name</span>
                            <span class="user-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</span>
                        </div>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-menu" id="userMenu">
                        <a asp-page="/Settings/Profile" class="menu-item"><i class="fas fa-user"></i> @(Model.Language == "ru" ? "Профиль" : Model.Language == "en" ? "Profile" : "Профиль")</a>
                        <a asp-page="/Settings/Security" class="menu-item"><i class="fas fa-shield-alt"></i> @(Model.Language == "ru" ? "Безопасность" : Model.Language == "en" ? "Security" : "Қауіпсіздік")</a>
                        <a asp-page="/Settings/Appearance" class="menu-item"><i class="fas fa-palette"></i> @(Model.Language == "ru" ? "Внешний вид" : Model.Language == "en" ? "Appearance" : "Сыртқы түр")</a>
                        <div class="menu-divider"></div>
                        <form method="post" asp-page="/Account/Logout" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="menu-item logout"><i class="fas fa-sign-out-alt"></i> @(Model.Language == "ru" ? "Выйти" : Model.Language == "en" ? "Logout" : "Шығу")</button>
                        </form>
                    </div>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
                    }

                    <h1>@ViewData["Title"]</h1>
                    <div class="subtitle">
                        <span>@(Model.Language == "ru" ? "Все уведомления" : Model.Language == "en" ? "All notifications" : "Барлық хабарландырулар")</span>
                        <div style="display: flex; gap: 12px;">
                            <a asp-page="/Settings/Index" class="back-link">
                                <i class="fas fa-arrow-left"></i> @(Model.Language == "ru" ? "Назад к настройкам" : Model.Language == "en" ? "Back to settings" : "Баптауларға оралу")
                            </a>
                            @if (Model.Notifications.Any())
                            {
                                <button class="mark-all-btn" id="markAllBtn">
                                    <i class="fas fa-check-double"></i> @(Model.Language == "ru" ? "Прочитать все" : Model.Language == "en" ? "Mark all read" : "Барлығын оқылды деп белгілеу")
                                </button>
                            }
                        </div>
                    </div>

                    @if (Model.Notifications.Any())
                    {
                        <div class="notifications-list">
                            @foreach (var n in Model.Notifications)
                            {
                                <div class="notification-card @(n.IsRead ? "read" : "unread")" data-id="@n.Id" onclick="markAsRead(@n.Id, this)">
                                    <div class="notification-icon @n.Type">
                                        @{
                                            string icon = n.Type switch
                                            {
                                                "order" => "fa-shopping-cart",
                                                "stock" => "fa-box",
                                                "customer" => "fa-user",
                                                "success" => "fa-check-circle",
                                                "warning" => "fa-exclamation-triangle",
                                                "error" => "fa-times-circle",
                                                _ => "fa-info-circle"
                                            };
                                        }
                                        <i class="fas @icon"></i>
                                    </div>
                                    <div class="notification-content">
                                        <div class="notification-title">@n.Title</div>
                                        <div class="notification-message">@n.Message</div>
                                        <div class="notification-time"><i class="far fa-clock"></i> @n.TimeAgo</div>
                                    </div>
                                    @if (!n.IsRead)
                                    {
                                        <i class="fas fa-circle" style="font-size: 10px; color: var(--primary); align-self: center;"></i>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-notifications">
                            <i class="far fa-bell-slash"></i>
                            <p>@(Model.Language == "ru" ? "У вас пока нет уведомлений" : Model.Language == "en" ? "You have no notifications yet" : "Сізде әлі хабарландырулар жоқ")</p>
                        </div>
                    }
                </div>
            </div>
        </main>
    </div>

    @Html.AntiForgeryToken()

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;
            if (menuToggle) {
                menuToggle.addEventListener('click', () => body.classList.toggle('sidebar-open'));
                document.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(e.target) && !menuToggle.contains(e.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }
            const themeToggle = document.getElementById('themeToggle');
            if (themeToggle) {
                const themeIcon = themeToggle.querySelector('i');
                const savedTheme = localStorage.getItem('theme') || '@Model.Theme';
                if (savedTheme === 'dark') {
                    body.classList.add('dark-theme');
                    themeIcon?.classList.remove('fa-sun');
                    themeIcon?.classList.add('fa-moon');
                }
                themeToggle.addEventListener('click', () => {
                    body.classList.toggle('dark-theme');
                    if (body.classList.contains('dark-theme')) {
                        themeIcon?.classList.remove('fa-sun');
                        themeIcon?.classList.add('fa-moon');
                        localStorage.setItem('theme', 'dark');
                    } else {
                        themeIcon?.classList.remove('fa-moon');
                        themeIcon?.classList.add('fa-sun');
                        localStorage.setItem('theme', 'light');
                    }
                });
            }
            window.toggleUserMenu = function() { document.getElementById('userMenu').classList.toggle('show'); };
            document.addEventListener('click', function(event) {
                const userInfo = document.querySelector('.user-info');
                const userMenu = document.getElementById('userMenu');
                if (userInfo && !userInfo.contains(event.target) && userMenu && userMenu.classList.contains('show')) {
                    userMenu.classList.remove('show');
                }
            });

            window.markAsRead = async function(id, element) {
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const response = await fetch(`/Settings/Notifications?handler=MarkAsRead&id=${id}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token }
                    });
                    if (response.ok) {
                        element.classList.remove('unread');
                        element.classList.add('read');
                        const dot = element.querySelector('.fa-circle');
                        if (dot) dot.remove();
                        const badge = document.querySelector('.notification-badge');
                        if (badge) {
                            let count = parseInt(badge.textContent) - 1;
                            if (count > 0) badge.textContent = count;
                            else badge.remove();
                        }
                    }
                } catch (error) { console.error(error); }
            };

            const markAllBtn = document.getElementById('markAllBtn');
            if (markAllBtn) {
                markAllBtn.addEventListener('click', async () => {
                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                        const response = await fetch(`/Settings/Notifications?handler=MarkAllAsRead`, {
                            method: 'POST',
                            headers: { 'RequestVerificationToken': token }
                        });
                        if (response.ok) {
                            document.querySelectorAll('.notification-card.unread').forEach(card => {
                                card.classList.remove('unread');
                                card.classList.add('read');
                                const dot = card.querySelector('.fa-circle');
                                if (dot) dot.remove();
                            });
                            const badge = document.querySelector('.notification-badge');
                            if (badge) badge.remove();
                        }
                    } catch (error) { console.error(error); }
                });
            }

            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 500);
                }, 5000);
            });
        });
    </script>
</body>
</html>