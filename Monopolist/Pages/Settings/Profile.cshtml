@page
@model Monoplist.Pages.Settings.ProfileModel
@{
    Layout = null;
    ViewData["Title"] = Model.Language == "ru" ? "Профиль" : (Model.Language == "en" ? "Profile" : "Профиль");
    var userName = User.Identity?.Name ?? "Пользователь";
}

<!DOCTYPE html>
<html lang="@Model.Language">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        :root {
            --primary: @Model.CustomColor;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --info: #3b82f6;
            --info-bg: #dbeafe;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
            --info-bg: #1e3a5f;
        }

        body.compact-mode .sidebar {
            width: 240px;
        }
        body.compact-mode .sidebar-header {
            padding: 16px 16px;
        }
        body.compact-mode .sidebar-header i {
            font-size: 32px;
        }
        body.compact-mode .sidebar-header h2 {
            font-size: 20px;
        }
        body.compact-mode .sidebar-nav li a {
            padding: 8px 12px;
        }
        body.compact-mode .top-bar {
            padding: 12px 24px;
        }
        body.compact-mode .dashboard {
            padding: 16px;
        }
        body.compact-mode .dashboard h1 {
            font-size: 1.8rem;
        }
        body.compact-mode .subtitle {
            font-size: 0.9rem;
            margin-bottom: 16px;
        }
        body.compact-mode .form-group {
            margin-bottom: 1rem;
        }
        body.compact-mode .form-control {
            padding: 8px 12px;
        }
        body.compact-mode .btn-primary,
        body.compact-mode .btn-secondary,
        body.compact-mode .btn-danger {
            padding: 8px 18px;
        }

        body.no-animations * {
            transition: none !important;
            animation: none !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-header i {
            font-size: 40px;
            background: linear-gradient(145deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
        }

        .sidebar-header h2 {
            font-size: 24px;
            font-weight: 700;
            background: linear-gradient(135deg, var(--accent), var(--primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 0;
        }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

        .sidebar-nav ul {
            list-style: none;
        }

        .sidebar-nav li {
            margin: 4px 8px;
        }

        .sidebar-nav li a {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            border-radius: 12px;
            transition: var(--transition);
            gap: 12px;
        }

        .sidebar-nav li a i {
            width: 24px;
            text-align: center;
            font-size: 1.25rem;
            color: var(--text-muted);
            transition: var(--transition);
        }

        .sidebar-nav li a:hover,
        .sidebar-nav li a.active {
            background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
            color: var(--primary);
            transform: translateX(4px);
        }

        .sidebar-nav li a:hover i,
        .sidebar-nav li a.active i {
            color: var(--primary);
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

        .menu-toggle:hover {
            background: rgba(255,107,0,0.1);
            color: var(--primary);
        }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .user-info span {
            font-weight: 500;
            color: var(--text-secondary);
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

        .theme-toggle:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .btn-logout {
            background: none;
            border: 2px solid var(--accent);
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            color: var(--text-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

        .btn-logout:hover {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-color: transparent;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,107,0,0.3);
        }

        .btn-logout:hover i {
            color: white;
        }

        .content {
            padding: 24px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 24px;
            box-shadow: var(--shadow-md);
        }

        .dashboard h1 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 8px;
        }

        .subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 24px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 12px;
        }

        .alert {
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: var(--success-bg);
            color: var(--success);
            border-left: 4px solid var(--success);
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger);
            border-left: 4px solid var(--danger);
        }

        .alert-warning {
            background: var(--warning-bg);
            color: var(--warning);
            border-left: 4px solid var(--warning);
        }

        .alert-info {
            background: var(--info-bg);
            color: var(--info);
            border-left: 4px solid var(--info);
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 24px;
            margin-bottom: 30px;
            padding: 20px;
            background: var(--surface-hover);
            border-radius: 16px;
            border: 1px solid var(--border);
        }

        .avatar-container {
            position: relative;
            width: 120px;
            height: 120px;
        }

        .avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 48px;
            border: 3px solid var(--accent);
            overflow: hidden;
            transition: transform 0.3s ease;
        }

        .avatar:hover {
            transform: scale(1.05);
        }

        .avatar img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
        }

        .avatar-upload {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 36px;
            height: 36px;
            background: var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            cursor: pointer;
            border: 2px solid var(--surface);
            transition: all 0.2s ease;
        }

        .avatar-upload:hover {
            background: var(--primary-dark);
            transform: scale(1.1);
        }

        .avatar-upload input {
            display: none;
        }

        .profile-info {
            flex: 1;
        }

        .profile-info h2 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 8px;
        }

        .profile-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            margin-bottom: 12px;
        }

        .profile-meta {
            display: flex;
            gap: 30px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .meta-item i {
            color: var(--primary);
            font-size: 1.1rem;
        }

        .form-container {
            max-width: 900px;
            margin: 0 auto;
        }

        .form-section {
            background: var(--surface);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
            border: 1px solid var(--border);
        }

        .form-section h3 {
            font-size: 1.2rem;
            color: var(--primary);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--accent);
        }

        .form-row {
            display: flex;
            gap: 20px;
            margin-bottom: 1rem;
        }

        .form-group {
            flex: 1;
            margin-bottom: 1.2rem;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--primary);
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            font-size: 1rem;
            border: 2px solid var(--border);
            border-radius: 12px;
            background: var(--surface);
            color: var(--text-primary);
            transition: all 0.2s ease;
            font-family: 'Poppins', sans-serif;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
        }

        .form-control:read-only {
            background: var(--surface-hover);
            cursor: not-allowed;
            opacity: 0.8;
        }

        .input-hint {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-top: 4px;
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
            padding-top: 20px;
            border-top: 2px solid var(--border);
        }

        .btn-primary, .btn-secondary, .btn-danger {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(255,107,0,0.4);
        }

        .btn-secondary {
            background: var(--surface);
            color: var(--text-secondary);
            border: 2px solid var(--border);
        }

        .btn-secondary:hover {
            background: var(--surface-hover);
            border-color: var(--text-muted);
            transform: translateY(-2px);
        }

        .btn-danger {
            background: var(--danger);
            color: white;
        }

        .btn-danger:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
            box-shadow: 0 6px 15px rgba(239,68,68,0.4);
        }

        .btn-sm {
            padding: 8px 16px;
            font-size: 0.9rem;
        }

        .text-danger {
            color: var(--danger);
            font-size: 0.85rem;
            margin-top: 4px;
            display: block;
        }

        .delete-section {
            margin-top: 40px;
            padding: 24px;
            background: var(--surface-hover);
            border-radius: 16px;
            border: 1px solid var(--danger);
        }

        .delete-section h3 {
            color: var(--danger);
            font-size: 1.3rem;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .delete-section p {
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .password-strength {
            margin-top: 8px;
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            overflow: hidden;
        }

        .password-strength-bar {
            height: 100%;
            width: 0;
            transition: width 0.3s ease;
        }

        .strength-weak { background: var(--danger); width: 33.33%; }
        .strength-medium { background: var(--warning); width: 66.66%; }
        .strength-strong { background: var(--success); width: 100%; }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                transform: translateX(-100%);
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
                box-shadow: 2px 0 15px rgba(0,0,0,0.2);
            }

            .menu-toggle {
                display: block;
            }

            .profile-header {
                flex-direction: column;
                text-align: center;
            }

            .profile-meta {
                justify-content: center;
            }

            .form-row {
                flex-direction: column;
                gap: 0;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-primary, .btn-secondary, .btn-danger {
                width: 100%;
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }
        }
    </style>
</head>
<body class="@(Model.Theme == "dark" ? "dark-theme" : "") @(Model.CompactMode ? "compact-mode" : "") @(Model.Animations ? "" : "no-animations")">
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> @(Model.Language == "ru" ? "Главная панель" : Model.Language == "en" ? "Dashboard" : "Бас панель")</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> @(Model.Language == "ru" ? "Каталог товаров" : Model.Language == "en" ? "Products" : "Тауарлар")</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> @(Model.Language == "ru" ? "Продажи" : Model.Language == "en" ? "Orders" : "Сатулар")</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> @(Model.Language == "ru" ? "Клиенты" : Model.Language == "en" ? "Customers" : "Клиенттер")</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> @(Model.Language == "ru" ? "Склад" : Model.Language == "en" ? "Warehouse" : "Қойма")</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> @(Model.Language == "ru" ? "Поставщики" : Model.Language == "en" ? "Suppliers" : "Жеткізушілер")</a></li>
                    <li><a asp-page="/Reports/Index"><i class="fas fa-chart-line"></i> @(Model.Language == "ru" ? "Отчеты" : Model.Language == "en" ? "Reports" : "Есептер")</a></li>
                    <li><a asp-page="/Settings/Index" class="active"><i class="fas fa-cog"></i> @(Model.Language == "ru" ? "Настройки" : Model.Language == "en" ? "Settings" : "Баптаулар")</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <span><i class="fas fa-user-circle"></i> @userName</span>
                    <div class="theme-toggle" id="themeToggle" title="@(Model.Language == "ru" ? "Сменить тему" : Model.Language == "en" ? "Toggle theme" : "Тақырыпты ауыстыру")">
                        <i class="fas fa-sun"></i>
                    </div>
                    <form method="post" asp-page="/Account/Logout" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>@(Model.Language == "ru" ? "Выйти" : Model.Language == "en" ? "Logout" : "Шығу")</span>
                        </button>
                    </form>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle"></i> @TempData["Success"]
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                        </div>
                    }

                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">@(Model.Language == "ru" ? "Управление личной информацией" : Model.Language == "en" ? "Personal information management" : "Жеке ақпаратты басқару")</p>

                    <div class="profile-header">
                        <div class="avatar-container">
                            <div class="avatar" id="avatarPreview">
                                @if (!string.IsNullOrEmpty(Model.Input.AvatarUrl))
                                {
                                    <img src="@Model.Input.AvatarUrl" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user\'></i>';" />
                                }
                                else
                                {
                                    <i class="fas fa-user"></i>
                                }
                            </div>
                            <label class="avatar-upload" for="avatarInput" title="@(Model.Language == "ru" ? "Загрузить аватар" : Model.Language == "en" ? "Upload avatar" : "Аватар жүктеу")">
                                <i class="fas fa-camera"></i>
                                <input type="file" id="avatarInput" accept="image/*" />
                            </label>
                        </div>
                        <div class="profile-info">
                            <h2>@Model.Input.Username</h2>
                            <span class="profile-badge">@Model.Input.Role</span>
                            <div class="profile-meta">
                                <div class="meta-item">
                                    <i class="fas fa-calendar-alt"></i> @(Model.Language == "ru" ? "С" : Model.Language == "en" ? "Since" : "Бастап") @Model.Input.CreatedAt.ToString("dd.MM.yyyy")
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-clock"></i> @(Model.Language == "ru" ? "Последний вход:" : Model.Language == "en" ? "Last login:" : "Соңғы кіру:") @(Model.Input.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? (Model.Language == "ru" ? "никогда" : Model.Language == "en" ? "never" : "ешқашан"))
                                </div>
                            </div>
                        </div>
                    </div>

                    <form method="post" class="form-container" id="profileForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Input.Id" />

                        <div class="form-section">
                            <h3><i class="fas fa-user-circle"></i> @(Model.Language == "ru" ? "Основная информация" : Model.Language == "en" ? "Basic information" : "Негізгі ақпарат")</h3>
                            
                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="Input.Username">@(Model.Language == "ru" ? "Имя пользователя" : Model.Language == "en" ? "Username" : "Пайдаланушы аты")</label>
                                    <input asp-for="Input.Username" class="form-control" />
                                    <span asp-validation-for="Input.Username" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label asp-for="Input.FullName">@(Model.Language == "ru" ? "Полное имя" : Model.Language == "en" ? "Full name" : "Толық аты")</label>
                                    <input asp-for="Input.FullName" class="form-control" />
                                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="Input.Email">Email</label>
                                    <input asp-for="Input.Email" class="form-control" type="email" />
                                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label asp-for="Input.PhoneNumber">@(Model.Language == "ru" ? "Телефон" : Model.Language == "en" ? "Phone" : "Телефон")</label>
                                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="+7 (999) 123-45-67" />
                                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.Position">@(Model.Language == "ru" ? "Должность" : Model.Language == "en" ? "Position" : "Лауазымы")</label>
                                <input asp-for="Input.Position" class="form-control" readonly />
                                <div class="input-hint">@(Model.Language == "ru" ? "Должность определяется вашей ролью в системе" : Model.Language == "en" ? "Position is determined by your role" : "Лауазымы сіздің рөліңізбен анықталады")</div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.AvatarUrl">@(Model.Language == "ru" ? "URL аватара" : Model.Language == "en" ? "Avatar URL" : "Аватар URL")</label>
                                <input asp-for="Input.AvatarUrl" class="form-control" id="avatarUrl" placeholder="https://example.com/avatar.jpg" />
                                <span asp-validation-for="Input.AvatarUrl" class="text-danger"></span>
                                <div class="input-hint">@(Model.Language == "ru" ? "Введите URL изображения или загрузите файл" : Model.Language == "en" ? "Enter image URL or upload file" : "Сурет URL енгізіңіз немесе файл жүктеңіз")</div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3><i class="fas fa-lock"></i> @(Model.Language == "ru" ? "Смена пароля" : Model.Language == "en" ? "Change password" : "Құпиясөзді өзгерту")</h3>
                            <p class="text-muted" style="margin-bottom: 20px;">@(Model.Language == "ru" ? "Оставьте поля пустыми, если не хотите менять пароль" : Model.Language == "en" ? "Leave fields blank if you don't want to change password" : "Құпиясөзді өзгерткіңіз келмесе, өрістерді бос қалдырыңыз")</p>

                            <div class="form-group">
                                <label asp-for="Input.CurrentPassword">@(Model.Language == "ru" ? "Текущий пароль" : Model.Language == "en" ? "Current password" : "Ағымдағы құпиясөз")</label>
                                <input asp-for="Input.CurrentPassword" class="form-control" type="password" id="currentPassword" />
                                <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="Input.NewPassword">@(Model.Language == "ru" ? "Новый пароль" : Model.Language == "en" ? "New password" : "Жаңа құпиясөз")</label>
                                    <input asp-for="Input.NewPassword" class="form-control" type="password" id="newPassword" />
                                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                                    <div class="password-strength">
                                        <div class="password-strength-bar" id="passwordStrength"></div>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label asp-for="Input.ConfirmPassword">@(Model.Language == "ru" ? "Подтверждение" : Model.Language == "en" ? "Confirm password" : "Құпиясөзді растау")</label>
                                    <input asp-for="Input.ConfirmPassword" class="form-control" type="password" />
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn-primary">
                                <i class="fas fa-save"></i> @(Model.Language == "ru" ? "Сохранить изменения" : Model.Language == "en" ? "Save changes" : "Өзгерістерді сақтау")
                            </button>
                            <a asp-page="Index" class="btn-secondary">
                                <i class="fas fa-times"></i> @(Model.Language == "ru" ? "Отмена" : Model.Language == "en" ? "Cancel" : "Бас тарту")
                            </a>
                        </div>
                    </form>

                    <div class="delete-section">
                        <h3><i class="fas fa-exclamation-triangle"></i> @(Model.Language == "ru" ? "Опасная зона" : Model.Language == "en" ? "Danger zone" : "Қауіпті аймақ")</h3>
                        <p>@(Model.Language == "ru" ? "Удаление аккаунта приведет к потере всех данных и доступа к системе. Это действие необратимо." : Model.Language == "en" ? "Deleting your account will result in loss of all data and access to the system. This action is irreversible." : "Аккаунтты жою барлық деректерді және жүйеге кіруді жоғалтуға әкеледі. Бұл әрекетті қайтару мүмкін емес.")</p>
                        <form method="post" asp-page-handler="DeleteAccount" onsubmit="return confirm('@(Model.Language == "ru" ? "Вы уверены, что хотите удалить свой аккаунт? Это действие необратимо." : Model.Language == "en" ? "Are you sure you want to delete your account? This action is irreversible." : "Сіз өз аккаунтыңызды жойғыңыз келетініне сенімдісіз бе? Бұл әрекетті қайтару мүмкін емес.")');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-danger">
                                <i class="fas fa-trash"></i> @(Model.Language == "ru" ? "Удалить мой аккаунт" : Model.Language == "en" ? "Delete my account" : "Менің аккаунтымды жою")
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;

            if (menuToggle) {
                menuToggle.addEventListener('click', () => body.classList.toggle('sidebar-open'));
                document.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(e.target) && !menuToggle.contains(e.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = themeToggle.querySelector('i');
            const savedTheme = localStorage.getItem('theme') || '@Model.Theme';
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                themeIcon.classList.remove('fa-sun');
                themeIcon.classList.add('fa-moon');
            }

            themeToggle.addEventListener('click', () => {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });

            const avatarUrl = document.getElementById('avatarUrl');
            const avatarPreview = document.getElementById('avatarPreview');

            if (avatarUrl) {
                avatarUrl.addEventListener('input', function() {
                    const url = this.value.trim();
                    if (url) {
                        avatarPreview.innerHTML = `<img src="${url}" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\\'fas fa-user\\'></i>';" />`;
                    } else {
                        avatarPreview.innerHTML = '<i class="fas fa-user"></i>';
                    }
                });
            }

            const avatarInput = document.getElementById('avatarInput');
            if (avatarInput) {
                avatarInput.addEventListener('change', function(e) {
                    const file = e.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            avatarPreview.innerHTML = `<img src="${e.target.result}" alt="Avatar" />`;
                            localStorage.setItem('tempAvatar', e.target.result);
                        };
                        reader.readAsDataURL(file);
                    }
                });
            }

            const newPassword = document.getElementById('newPassword');
            const strengthBar = document.getElementById('passwordStrength');

            if (newPassword && strengthBar) {
                newPassword.addEventListener('input', function() {
                    const password = this.value;
                    if (!password) {
                        strengthBar.style.width = '0';
                        strengthBar.className = 'password-strength-bar';
                        return;
                    }

                    let strength = 0;
                    if (password.length >= 8) strength++;
                    if (password.match(/[a-z]+/)) strength++;
                    if (password.match(/[A-Z]+/)) strength++;
                    if (password.match(/[0-9]+/)) strength++;
                    if (password.match(/[$@@#&!]+/)) strength++;

                    strengthBar.className = 'password-strength-bar';
                    if (strength <= 2) {
                        strengthBar.classList.add('strength-weak');
                    } else if (strength <= 4) {
                        strengthBar.classList.add('strength-medium');
                    } else {
                        strengthBar.classList.add('strength-strong');
                    }
                });
            }

            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 500);
                }, 5000);
            });
        });
    </script>
</body>
</html>