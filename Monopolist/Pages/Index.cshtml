@page
@model Monoplist.Pages.IndexModel
@{
    Layout = null;
    var userName = User.Identity?.Name ?? "Пользователь";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Главная панель | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ===== ОБЩИЕ ПЕРЕМЕННЫЕ (СВЕТЛАЯ ТЕМА) ===== */
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-lg: 0 8px 24px rgba(255,107,0,0.15);
            --shadow-hover: 0 12px 28px rgba(255,215,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            /* Цвета для карточек */
            --card-color-1: #10b981; /* изумрудный */
            --card-color-2: #3b82f6; /* синий */
            --card-color-3: #8b5cf6; /* фиолетовый */
            --card-color-4: #f59e0b; /* оранжевый */

            --transition: all 0.2s ease;
        }

        /* ===== ТЁМНАЯ ТЕМА ===== */
        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
            /* Цвета карточек в тёмной теме */
            --card-color-1: #34d399;
            --card-color-2: #60a5fa;
            --card-color-3: #c084fc;
            --card-color-4: #fbbf24;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        /* ===== САЙДБАР ===== */
        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        /* ===== ОСНОВНОЙ КОНТЕНТ ===== */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

            .user-info span {
                font-weight: 500;
                color: var(--text-secondary);
            }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .btn-logout {
            background: none;
            border: 2px solid var(--accent);
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            color: var(--text-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

            .btn-logout:hover {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-color: transparent;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(255,107,0,0.3);
            }

                .btn-logout:hover i {
                    color: white;
                }

        .content {
            padding: 32px;
            flex: 1;
        }

        /* ===== КОМПОНЕНТЫ ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--surface);
            padding: 24px 80px 24px 24px; /* увеличен правый отступ, чтобы текст не заходил под иконку */
            border-radius: 20px;
            box-shadow: var(--shadow-md);
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            animation: fadeInUp 0.5s ease backwards;
            border-left: 4px solid;
        }

            .stat-card:nth-child(1) {
                border-left-color: var(--card-color-1);
                animation-delay: 0.1s;
            }

            .stat-card:nth-child(2) {
                border-left-color: var(--card-color-2);
                animation-delay: 0.2s;
            }

            .stat-card:nth-child(3) {
                border-left-color: var(--card-color-3);
                animation-delay: 0.3s;
            }

            .stat-card:nth-child(4) {
                border-left-color: var(--card-color-4);
                animation-delay: 0.4s;
            }

        @@keyframes fadeInUp {
            from

        {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .stat-card:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: var(--shadow-hover);
        }

        /* Желтый круг за иконкой (чуть менее интенсивный) */
        .stat-card::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 120px;
            height: 120px;
            background: radial-gradient(circle at 30% 30%, rgba(255,215,0,0.6) 0%, rgba(255,215,0,0) 70%);
            border-radius: 50%;
            transform: translate(40px, -40px);
            pointer-events: none;
            z-index: 0;
        }

        /* Иконки: уменьшена яркость (opacity 0.8 вместо 0.9) */
        .stat-icon {
            position: absolute;
            bottom: 15px;
            right: 15px;
            font-size: 3.5rem;
            opacity: 0.8;
            filter: drop-shadow(0 0 4px currentColor);
            z-index: 1;
        }

        .stat-card:nth-child(1) .stat-icon {
            color: var(--card-color-1);
        }

        .stat-card:nth-child(2) .stat-icon {
            color: var(--card-color-2);
        }

        .stat-card:nth-child(3) .stat-icon {
            color: var(--card-color-3);
        }

        .stat-card:nth-child(4) .stat-icon {
            color: var(--card-color-4);
        }

        .stat-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            position: relative;
            z-index: 2;
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.2;
            margin-bottom: 8px;
            position: relative;
            z-index: 2;
        }

        .stat-change {
            font-size: 0.9rem;
            color: var(--success);
            margin-top: auto;
            position: relative;
            z-index: 2;
        }

        .tables-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 28px;
        }

        .table-card {
            background: var(--surface);
            padding: 24px;
            border-radius: 20px;
            box-shadow: var(--shadow-md);
            transition: var(--transition);
            animation: fadeInUp 0.5s ease backwards;
            animation-delay: 0.5s;
            border-left: 4px solid var(--accent);
        }

            .table-card:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-hover);
            }

            .table-card h2 {
                display: flex;
                align-items: center;
                gap: 10px;
                font-size: 1.3rem;
                color: var(--primary);
                border-bottom: 2px solid var(--accent);
                padding-bottom: 10px;
                margin-bottom: 20px;
            }

                .table-card h2 i {
                    color: var(--card-color-2);
                }

            .table-card:last-child h2 i {
                color: var(--card-color-4);
            }

            .table-card table {
                width: 100%;
                border-collapse: collapse;
            }

            .table-card th {
                text-align: left;
                padding: 12px 8px;
                font-size: 0.8rem;
                font-weight: 600;
                color: var(--text-muted);
                text-transform: uppercase;
                border-bottom: 2px solid var(--accent);
            }

            .table-card td {
                padding: 12px 8px;
                border-bottom: 1px solid var(--border);
                color: var(--text-secondary);
            }

            .table-card tbody tr:hover td {
                background-color: rgba(255,107,0,0.05);
            }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.85rem;
            font-weight: 500;
            text-align: center;
        }

        .status-completed {
            background: var(--success-bg);
            color: var(--success);
        }

        .status-pending {
            background: var(--warning-bg);
            color: var(--warning);
        }

        .status-cancelled {
            background: var(--danger-bg);
            color: var(--danger);
        }

        .low-stock-warning {
            color: #f59e0b;
            font-weight: 600;
        }

        .low-stock-critical {
            color: #ef4444;
            font-weight: 700;
        }

        .alert {
            padding: 14px 18px;
            border-radius: 12px;
            margin-bottom: 24px;
            border-left: 4px solid;
            font-size: 0.95rem;
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger);
            border-left-color: var(--danger);
        }

        /* ===== АДАПТИВНОСТЬ ===== */
        @@media (max-width: 1024px) {
            .stats-grid

        {
            grid-template-columns: repeat(2, 1fr);
        }

        }

        @@media (max-width: 768px) {
            .sidebar

        {
            position: fixed;
            left: -280px;
            top: 0;
            bottom: 0;
            transform: translateX(-100%);
            box-shadow: none;
        }

        body.sidebar-open .sidebar {
            transform: translateX(0);
            box-shadow: 2px 0 15px rgba(0,0,0,0.2);
        }

        .menu-toggle {
            display: block;
        }

        .main-content {
            width: 100%;
        }

        .top-bar {
            padding: 12px 16px;
        }

        .page-title {
            font-size: 1.25rem;
        }

        .user-info span {
            display: none;
        }

        .tables-row {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .content {
            padding: 16px;
        }

        }

        @@media (max-width: 480px) {
            .stats-grid

        {
            grid-template-columns: 1fr;
        }

        .btn-logout span {
            display: none;
        }

        .btn-logout {
            padding: 8px 12px;
        }

        }
    </style>
</head>
<body>
    <div class="app">
        <!-- Боковое меню с логотипом и одной линией -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <!-- Заголовок "Главное меню" удалён, осталась только одна линия под логотипом -->
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index" class="active"><i class="fas fa-home"></i> Главная панель</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> Каталог товаров</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> Продажи</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> Клиенты</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> Склад</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> Поставщики</a></li>
                    <li><a asp-page="/Reports/Index"><i class="fas fa-chart-line"></i> Отчеты</a></li>
                    <li><a asp-page="/Settings/Index"><i class="fas fa-cog"></i> Настройки</a></li>
                </ul>
            </nav>
        </aside>

        <!-- Основной контент -->
        <main class="main-content">
            <!-- Верхняя панель с переключателем темы -->
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">Главная панель</h1>
                <div class="user-info">
                    <span><i class="fas fa-user-circle"></i> @userName</span>
                    <div class="theme-toggle" id="themeToggle" title="Сменить тему">
                        <i class="fas fa-sun"></i>
                    </div>
                    <form method="post" asp-page="/Account/Logout" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Выйти</span>
                        </button>
                    </form>
                </div>
            </header>

            <!-- Контент -->
            <div class="content">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                    </div>
                }
                @if (TempData["Warning"] != null)
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i> @TempData["Warning"]
                    </div>
                }
                @if (Model.DashboardData != null)
                {
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-label">Выручка</div>
                            <div class="stat-value">@Model.DashboardData.TotalRevenue.ToString("N0") ₽</div>
                            <div class="stat-change">+12% с прошлого месяца</div>
                            <i class="fas fa-ruble-sign stat-icon"></i>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Товаров на складе</div>
                            <div class="stat-value">@Model.DashboardData.ProductsInStock</div>
                            <div class="stat-change">+24 новых поступления</div>
                            <i class="fas fa-cubes stat-icon"></i>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Клиенты</div>
                            <div class="stat-value">@Model.DashboardData.TotalCustomers</div>
                            <div class="stat-change">+8 за неделю</div>
                            <i class="fas fa-user-friends stat-icon"></i>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Новые заказы (7 дней)</div>
                            <div class="stat-value">@Model.DashboardData.NewOrders</div>
                            <div class="stat-change">+5% к прошлой неделе</div>
                            <i class="fas fa-shopping-bag stat-icon"></i>
                        </div>
                    </div>

                    <div class="tables-row">
                        <!-- Последние заказы -->
                        <div class="table-card">
                            <h2><i class="fas fa-clock"></i> Последние заказы</h2>
                            <table>
                                <thead>
                                    <tr>
                                        <th>№ заказа</th>
                                        <th>Клиент</th>
                                        <th>Сумма</th>
                                        <th>Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.DashboardData.LatestOrders.Any())
                                    {
                                        @foreach (var order in Model.DashboardData.LatestOrders)
                                        {
                                            <tr>
                                                <td>@order.OrderNumber</td>
                                                <td>@order.CustomerName</td>
                                                <td>@order.TotalAmount.ToString("N0") ₽</td>
                                                <td>
                                                    <span class="status-badge status-@(order.Status?.ToLower() == "completed" ? "completed" : order.Status?.ToLower() == "pending" ? "pending" : "cancelled")">
                                                        @order.Status
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" style="text-align: center;">Нет данных</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Товары с низким остатком -->
                        <div class="table-card">
                            <h2><i class="fas fa-exclamation-triangle"></i> Низкий остаток</h2>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Товар</th>
                                        <th>Категория</th>
                                        <th>Остаток</th>
                                        <th>Мин. норма</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.DashboardData.LowStockProducts.Any())
                                    {
                                        @foreach (var product in Model.DashboardData.LowStockProducts)
                                        {
                                            <tr>
                                                <td>@product.Name</td>
                                                <td>@product.CategoryName</td>
                                                <td class="@(product.CurrentStock < product.MinimumStock * 0.5 ? "low-stock-critical" : "low-stock-warning")">
                                                    @product.CurrentStock
                                                </td>
                                                <td>@product.MinimumStock</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" style="text-align: center;">Все товары в норме</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle"></i> Не удалось загрузить данные.
                    </div>
                }
            </div>
        </main>
    </div>

    <!-- Скрипты -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Мобильное меню
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;

            if (menuToggle) {
                menuToggle.addEventListener('click', function() {
                    body.classList.toggle('sidebar-open');
                });

                document.addEventListener('click', function(event) {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(event.target) && !menuToggle.contains(event.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            // Переключение темы
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = themeToggle.querySelector('i');

            // Загружаем сохранённую тему
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                themeIcon.classList.remove('fa-sun');
                themeIcon.classList.add('fa-moon');
            }

            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });

            // Авто-скрытие уведомлений
            const alert = document.querySelector('.alert');
            if (alert) {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 500);
                }, 5000);
            }
        });
    </script>
</body>
</html>