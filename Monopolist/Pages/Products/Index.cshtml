@page
@model Monoplist.Pages.Products.IndexModel
@{
    Layout = null;
    var userName = User.Identity?.Name ?? "Пользователь";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ===== ОБЩИЕ ПЕРЕМЕННЫЕ (СВЕТЛАЯ ТЕМА) ===== */
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 14px rgba(0,0,0,0.07);
            --shadow-lg: 0 8px 24px rgba(255,107,0,0.15);
            --shadow-hover: 0 12px 28px rgba(255,215,0,0.2);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --card-color-1: #10b981;
            --card-color-2: #3b82f6;
            --card-color-3: #8b5cf6;
            --card-color-4: #f59e0b;
            --transition: all 0.2s ease;
        }

        /* ===== ТЁМНАЯ ТЕМА ===== */
        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 14px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
            --card-color-1: #34d399;
            --card-color-2: #60a5fa;
            --card-color-3: #c084fc;
            --card-color-4: #fbbf24;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        /* ===== САЙДБАР ===== */
        .sidebar {
            width: 260px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 20px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 36px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 22px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 12px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 2px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 10px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 10px;
                    transition: var(--transition);
                    gap: 12px;
                    font-size: 0.95rem;
                }

                    .sidebar-nav li a i {
                        width: 22px;
                        text-align: center;
                        font-size: 1.2rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        /* ===== ОСНОВНОЙ КОНТЕНТ ===== */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 14px 28px;
            display: flex;
            align-items: center;
            gap: 18px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 6px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.6rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .user-info span {
                font-weight: 500;
                color: var(--text-secondary);
                font-size: 0.95rem;
            }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .btn-logout {
            background: none;
            border: 2px solid var(--accent);
            padding: 7px 16px;
            border-radius: 30px;
            cursor: pointer;
            color: var(--text-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
            font-size: 0.95rem;
        }

            .btn-logout:hover {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-color: transparent;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(255,107,0,0.3);
            }

                .btn-logout:hover i {
                    color: white;
                }

        .content {
            padding: 28px;
            flex: 1;
        }

        /* ===== КОМПОНЕНТЫ ===== */
        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 20px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 6px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 18px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 10px;
        }

        /* Панель поиска и действий */
        .action-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .search-form {
            display: flex;
            align-items: center;
            gap: 8px;
            flex: 1;
            max-width: 420px;
        }

        .search-input {
            flex: 1;
            padding: 9px 14px;
            border: 2px solid var(--border);
            border-radius: 30px;
            font-size: 0.95rem;
            transition: var(--transition);
            background: var(--surface);
            color: var(--text-primary);
        }

            .search-input:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
            }

        .search-btn, .reset-btn {
            padding: 9px 18px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }

        .search-btn {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 10px rgba(255,107,0,0.3);
        }

            .search-btn:hover {
                background: var(--primary-dark);
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
            }

        .reset-btn {
            background: var(--surface);
            color: var(--text-secondary);
            border: 2px solid var(--border);
        }

            .reset-btn:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
            }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            padding: 9px 18px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            transition: var(--transition);
            box-shadow: 0 4px 10px rgba(255,107,0,0.3);
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
                color: white;
            }

        /* Кнопки действий */
        .action-buttons {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            justify-content: flex-start;
        }

        .btn-sm {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            border-radius: 7px;
            color: white;
            text-decoration: none;
            transition: var(--transition);
            font-size: 0.95rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

            .btn-sm.btn-info {
                background: var(--card-color-2);
            }

            .btn-sm.btn-primary {
                background: var(--primary);
            }

            .btn-sm.btn-danger {
                background: var(--danger);
            }

            .btn-sm:hover {
                transform: translateY(-2px) scale(1.05);
                filter: brightness(1.15);
                box-shadow: 0 4px 8px rgba(0,0,0,0.15);
            }

        /* ===== ТАБЛИЦА - ЖИРНЫЙ ШРИФТ В СТРОКАХ ===== */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--surface);
            border-radius: 14px;
            overflow: hidden;
            box-shadow: var(--shadow-md);
            font-size: 0.88rem;
        }

            .data-table thead tr {
                background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
            }

            .data-table th {
                text-align: left;
                padding: 11px 5px;
                color: var(--text-primary);
                font-weight: 700; /* заголовки остаются жирными */
                font-size: 0.78rem;
                text-transform: uppercase;
                letter-spacing: 0.4px;
                border-bottom: 2px solid var(--accent);
                white-space: nowrap;
            }

                .data-table th i {
                    margin-right: 4px;
                    color: var(--primary);
                    font-size: 0.85rem;
                }

            .data-table td {
                padding: 7px 5px;
                border-bottom: 1px solid var(--border);
                color: var(--text-secondary);
                font-weight: 600; /* ЖИРНЫЙ (было 500) */
            }

            .data-table tbody tr:nth-child(even) {
                background-color: rgba(0,0,0,0.02);
            }

            .data-table tbody tr:hover td {
                background-color: rgba(255,107,0,0.05);
                transition: background-color 0.2s;
            }

            /* Для числовых столбцов оставляем жирность, они уже наследуют 600 */
            .data-table td:nth-child(5),
            .data-table td:nth-child(6),
            .data-table td:nth-child(7) {
                font-weight: 600;
                color: var(--text-primary);
            }

                .data-table td:nth-child(5)::before,
                .data-table td:nth-child(6)::before {
                    content: '₽';
                    margin-right: 2px;
                    font-size: 0.75rem;
                    opacity: 0.7;
                }

        .text-muted {
            color: var(--text-muted);
            font-style: italic;
            padding: 18px;
            text-align: center;
            font-size: 0.95rem;
            font-weight: 500;
        }

        .alert {
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 18px;
            border-left: 4px solid;
            font-size: 0.9rem;
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--surface);
            box-shadow: var(--shadow-sm);
            font-weight: 500;
        }

        .alert-danger {
            border-left-color: var(--danger);
            color: var(--danger);
        }

        /* ===== АДАПТИВНОСТЬ ===== */
        @@media (max-width: 1024px) {
            .data-table {
                display: block;
                overflow-x: auto;
                white-space: nowrap;
            }
        }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -260px;
                top: 0;
                bottom: 0;
                transform: translateX(-100%);
                box-shadow: none;
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
                box-shadow: 2px 0 15px rgba(0,0,0,0.2);
            }

            .menu-toggle {
                display: block;
            }

            .main-content {
                width: 100%;
            }

            .top-bar {
                padding: 12px 18px;
            }

            .page-title {
                font-size: 1.3rem;
            }

            .user-info span {
                display: none;
            }

            .content {
                padding: 16px;
            }

            .dashboard {
                padding: 16px;
            }

            .action-bar {
                flex-direction: column;
                align-items: stretch;
            }

            .search-form {
                max-width: 100%;
            }

            .btn-primary {
                width: 100%;
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .btn-logout {
                padding: 7px 12px;
            }
        }
    </style>
</head>
<body>
    <div class="app">
        <!-- Боковое меню с логотипом -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> Главная панель</a></li>
                    <li><a asp-page="/Products/Index" class="active"><i class="fas fa-box"></i> Каталог товаров</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> Продажи</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> Клиенты</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> Склад</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> Поставщики</a></li>
                    <li><a asp-page="/Reports/Index"><i class="fas fa-chart-line"></i> Отчеты</a></li>
                    <li><a asp-page="/Settings/Index"><i class="fas fa-cog"></i> Настройки</a></li>
                </ul>
            </nav>
        </aside>

        <!-- Основной контент -->
        <main class="main-content">
            <!-- Верхняя панель -->
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <span><i class="fas fa-user-circle"></i> @userName</span>
                    <div class="theme-toggle" id="themeToggle" title="Сменить тему">
                        <i class="fas fa-sun"></i>
                    </div>
                    <form method="post" asp-page="/Account/Logout" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Выйти</span>
                        </button>
                    </form>
                </div>
            </header>

            <!-- Контент страницы -->
            <div class="content">
                <div class="dashboard">
                    <h1 class="subtitle">Управление номенклатурой строительных материалов</h1>

                    <!-- Панель поиска и действий -->
                    <div class="action-bar">
                        <form method="get" class="search-form">
                            <input type="text" class="search-input" name="searchString" placeholder="Поиск по наименованию, артикулу..." value="@Model.SearchString" />
                            <button type="submit" class="search-btn"><i class="fas fa-search"></i> Найти</button>
                            @if (!string.IsNullOrEmpty(Model.SearchString))
                            {
                                <a asp-page="Index" class="reset-btn"><i class="fas fa-times"></i> Сброс</a>
                            }
                        </form>

                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <a asp-page="Create" class="btn-primary">
                                <i class="fas fa-plus"></i> Добавить товар
                            </a>
                        }
                    </div>

                    @if (Model.Products.Any())
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th><i class="fas fa-box"></i> Наименование</th>
                                    <th><i class="fas fa-barcode"></i> Артикул</th>
                                    <th><i class="fas fa-tag"></i> Категория</th>
                                    <th><i class="fas fa-ruler"></i> Ед. изм.</th>
                                    <th><i class="fas fa-ruble-sign"></i> Цена закупки</th>
                                    <th><i class="fas fa-ruble-sign"></i> Цена продажи</th>
                                    <th><i class="fas fa-cubes"></i> Остаток</th>
                                    <th><i class="fas fa-truck"></i> Поставщик</th>
                                    <th><i class="fas fa-cogs"></i> Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Products)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.Article</td>
                                        <td>@item.CategoryName</td>
                                        <td>@item.Unit</td>
                                        <td>@item.PurchasePrice.ToString("N0")</td>
                                        <td>@item.SalePrice.ToString("N0")</td>
                                        <td>@item.CurrentStock</td>
                                        <td>@item.SupplierName</td>
                                        <td>
                                            <div class="action-buttons">
                                                <a asp-page="Details" asp-route-id="@item.Id" class="btn-sm btn-info" title="Просмотр">
                                                    <i class="fas fa-info-circle"></i>
                                                </a>
                                                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                                {
                                                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn-sm btn-primary" title="Редактировать">
                                                        <i class="fas fa-pencil-alt"></i>
                                                    </a>
                                                    <a asp-page="Delete" asp-route-id="@item.Id" class="btn-sm btn-danger" title="Удалить">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">В каталоге нет товаров.</p>
                    }
                </div>
            </div>
        </main>
    </div>

    <!-- Скрипты -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Мобильное меню
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;

            if (menuToggle) {
                menuToggle.addEventListener('click', function() {
                    body.classList.toggle('sidebar-open');
                });

                document.addEventListener('click', function(event) {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(event.target) && !menuToggle.contains(event.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            // Переключение темы
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = themeToggle.querySelector('i');

            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                themeIcon.classList.remove('fa-sun');
                themeIcon.classList.add('fa-moon');
            }

            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });
        });
    </script>
</body>
</html>