@page
@model Monoplist.Pages.Products.EditModel
@{
    ViewData["Title"] = "Редактирование товара";
}
<div class="dashboard">
    <h1>@ViewData["Title"]</h1>
    <p class="subtitle">Измените данные товара</p>

    <div class="form-container">
        <form method="post">
            <input type="hidden" asp-for="Product.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Product.Name"></label>
                <input asp-for="Product.Name" class="form-control" />
                <span asp-validation-for="Product.Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Product.Article"></label>
                <input asp-for="Product.Article" class="form-control" />
                <span asp-validation-for="Product.Article" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Product.CategoryId"></label>
                <select asp-for="Product.CategoryId" asp-items="Model.Categories" class="form-control">
                    <option value="">-- Выберите категорию --</option>
                </select>
                <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Product.Unit"></label>
                <input asp-for="Product.Unit" class="form-control" />
                <span asp-validation-for="Product.Unit" class="text-danger"></span>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label asp-for="Product.PurchasePrice"></label>
                    <input asp-for="Product.PurchasePrice" class="form-control" />
                    <span asp-validation-for="Product.PurchasePrice" class="text-danger"></span>
                </div>
                <div class="form-group half">
                    <label asp-for="Product.SalePrice"></label>
                    <input asp-for="Product.SalePrice" class="form-control" />
                    <span asp-validation-for="Product.SalePrice" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label asp-for="Product.CurrentStock"></label>
                    <input asp-for="Product.CurrentStock" class="form-control" />
                    <span asp-validation-for="Product.CurrentStock" class="text-danger"></span>
                </div>
                <div class="form-group half">
                    <label asp-for="Product.MinimumStock"></label>
                    <input asp-for="Product.MinimumStock" class="form-control" />
                    <span asp-validation-for="Product.MinimumStock" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Product.SupplierId"></label>
                <select asp-for="Product.SupplierId" asp-items="Model.Suppliers" class="form-control"></select>
                <span asp-validation-for="Product.SupplierId" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Сохранить</button>
                <a asp-page="Index" class="btn-secondary"><i class="fas fa-times"></i> Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}