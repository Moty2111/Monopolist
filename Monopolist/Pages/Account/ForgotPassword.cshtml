@page
@model Monoplist.Pages.Account.ForgotPasswordModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Восстановление пароля | Моноплист</title>

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&family=Roboto+Condensed:wght@700&display=swap" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

    <!-- Основной стиль сайта -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* ===== СВЕТЛАЯ ИНДУСТРИАЛЬНАЯ ТЕМА ===== */
        body.login-page {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Poppins', sans-serif;
            background: #e5e7eb;
            overflow-y: auto;
            position: relative;
            transition: background-color 0.3s, color 0.3s;
        }

        .theme-toggle {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 100;
            background: rgba(255,255,255,0.8);
            border: 2px solid #FF6B00;
            border-radius: 50px;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            transition: all 0.3s;
            font-size: 24px;
            color: #FF6B00;
        }

            .theme-toggle:hover {
                transform: scale(1.1);
                background: #FF6B00;
                color: white;
                border-color: white;
            }

        .industrial-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            background-image: linear-gradient(rgba(255,255,255,0.3), rgba(255,255,255,0.3)), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23d4d4d4"/><path d="M10 10 L90 10 M10 30 L90 30 M10 50 L90 50 M10 70 L90 70 M10 90 L90 90 M10 10 L10 90 M30 10 L30 90 M50 10 L50 90 M70 10 L70 90 M90 10 L90 90" stroke="%23ff6b00" stroke-width="1" opacity="0.4"/></svg>');
            background-repeat: repeat;
            opacity: 0.8;
            pointer-events: none;
            transition: opacity 0.3s;
        }

        .rebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,107,0,0.1) 20px, rgba(255,107,0,0.1) 22px);
            z-index: 1;
            pointer-events: none;
        }

        .tool-icon {
            position: fixed;
            font-size: 4rem;
            color: rgba(255,107,0,0.35);
            z-index: 1;
            pointer-events: none;
            animation: subtleFloat 14s infinite alternate ease-in-out;
        }

        .tool-1 {
            top: 5%;
            left: 2%;
            transform: rotate(-15deg);
            animation-duration: 16s;
        }

        .tool-2 {
            bottom: 8%;
            right: 3%;
            transform: rotate(20deg);
            animation-duration: 18s;
        }

        .tool-3 {
            top: 20%;
            right: 10%;
            transform: rotate(5deg);
            animation-duration: 20s;
        }

        .tool-4 {
            bottom: 15%;
            left: 7%;
            transform: rotate(-10deg);
            animation-duration: 22s;
        }

        .tool-5 {
            top: 70%;
            left: 15%;
            transform: rotate(25deg);
            animation-duration: 24s;
            font-size: 5rem;
        }

        .tool-6 {
            bottom: 30%;
            right: 15%;
            transform: rotate(-20deg);
            animation-duration: 26s;
            font-size: 3.5rem;
        }

        .tool-7 {
            top: 40%;
            left: 20%;
            transform: rotate(10deg);
            animation-duration: 28s;
            font-size: 4.5rem;
        }

        .tool-8 {
            bottom: 50%;
            right: 5%;
            transform: rotate(-5deg);
            animation-duration: 30s;
            font-size: 3rem;
        }

        @@keyframes subtleFloat {
            0% {
                transform: translateY(0) rotate(0deg);
            }

            100% {
                transform: translateY(-20px) rotate(10deg);
            }
        }

        .login-card {
            position: relative;
            z-index: 10;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(4px);
            border-radius: 32px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3), 0 0 0 3px #FF6B00 inset;
            width: 100%;
            max-width: 520px;
            padding: 50px 45px;
            animation: cardAppear 0.6s ease-out;
            margin: 30px auto;
            border: 1px solid #FFD700;
            transition: background 0.3s, box-shadow 0.3s, border-color 0.3s;
        }

        @@keyframes cardAppear {
            0% {
                opacity: 0;
                transform: translateY(30px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo-container {
            text-align: center;
            margin-bottom: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 8px;
        }

            .logo i {
                font-size: 85px;
                background: linear-gradient(145deg, #FF8C00, #FF4500, #FFD700);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 8px #FF6B00);
            }

            .logo span {
                font-family: 'Montserrat', sans-serif;
                font-size: 56px;
                font-weight: 900;
                background: linear-gradient(135deg, #2c3e50, #bdc3c7, #FF6B00);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
                letter-spacing: -1px;
            }

        .logo-tagline {
            font-family: 'Roboto Condensed', sans-serif;
            font-size: 17px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: #555;
            border-top: 2px solid #FF6B00;
            padding-top: 12px;
            display: inline-block;
            transition: color 0.3s, border-color 0.3s;
        }

        .login-heading {
            font-family: 'Montserrat', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: #FF6B00;
            margin-bottom: 10px;
            text-align: center;
            text-transform: uppercase;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        .brand-subtitle {
            font-family: 'Poppins', sans-serif;
            font-size: 16px;
            color: #333;
            font-weight: 500;
            border-bottom: 2px solid #FF6B00;
            padding-bottom: 20px;
            text-align: center;
            transition: color 0.3s, border-color 0.3s;
        }

        .login-form .form-group {
            margin-bottom: 25px;
        }

        .login-form label {
            display: block;
            font-size: 15px;
            font-weight: 700;
            color: #FF6B00;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .login-form input {
            width: 100%;
            padding: 18px 20px;
            font-size: 18px;
            border: 2px solid #bbb;
            border-radius: 16px;
            background: #fff;
            transition: border 0.2s, box-shadow 0.2s, background 0.3s, color 0.3s;
            font-family: 'Poppins', sans-serif;
            color: #111;
            font-weight: 500;
        }

            .login-form input:focus {
                outline: none;
                border-color: #FF6B00;
                box-shadow: 0 0 0 4px rgba(255,107,0,0.25);
                background: #fff;
            }

        .login-btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, #FF6B00, #FF4500);
            border: none;
            border-radius: 40px;
            color: white;
            font-size: 18px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 8px 0 #b34700;
            border: 1px solid #FFD700;
            margin-bottom: 15px;
        }

            .login-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 0 #b34700;
                background: linear-gradient(135deg, #FF8C00, #FF6B00);
            }

            .login-btn:active {
                transform: translateY(4px);
                box-shadow: 0 4px 0 #b34700;
            }

        .back-link {
            display: block;
            text-align: center;
            color: #FF6B00;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
            text-transform: uppercase;
            font-size: 14px;
        }

            .back-link:hover {
                color: #FFD700;
                text-decoration: underline;
            }

        .alert-success {
            background: rgba(40, 167, 69, 0.2);
            border-left: 6px solid #28a745;
            border-radius: 16px;
            color: #155724;
            padding: 16px;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .token-box {
            background: #fef3c7;
            color: #92400e;
            border-left: 6px solid #f59e0b;
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 20px;
            font-weight: 500;
            word-break: break-all;
        }

            .token-box i {
                margin-right: 8px;
            }

        /* Тёмная тема */
        body.dark-theme {
            background: #1a1a1a;
        }

            body.dark-theme .industrial-bg {
                opacity: 0.4;
                background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23333"/><path d="M10 10 L90 10 M10 30 L90 30 M10 50 L90 50 M10 70 L90 70 M10 90 L90 90 M10 10 L10 90 M30 10 L30 90 M50 10 L50 90 M70 10 L70 90 M90 10 L90 90" stroke="%23ff6b00" stroke-width="1" opacity="0.6"/></svg>');
            }

            body.dark-theme .rebar {
                background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,107,0,0.2) 20px, rgba(255,107,0,0.2) 22px);
            }

            body.dark-theme .tool-icon {
                color: rgba(255,107,0,0.5);
            }

            body.dark-theme .login-card {
                background: rgba(30, 30, 30, 0.98);
                box-shadow: 0 30px 60px rgba(0,0,0,0.8), 0 0 0 3px #FF6B00 inset;
                border-color: #FFD700;
            }

            body.dark-theme .logo-tagline {
                color: #aaa;
                border-top-color: #FF6B00;
            }

            body.dark-theme .brand-subtitle {
                color: #ccc;
                border-bottom-color: #FF6B00;
            }

            body.dark-theme .login-form label {
                color: #FFD700;
            }

            body.dark-theme .login-form input {
                background: #333;
                border-color: #555;
                color: #eee;
            }

                body.dark-theme .login-form input:focus {
                    background: #3a3a3a;
                }

            body.dark-theme .back-link {
                color: #FFD700;
            }

            body.dark-theme .alert-success {
                background: rgba(40, 167, 69, 0.2);
                color: #9fdf9f;
                border-left-color: #28a745;
            }

            body.dark-theme .token-box {
                background: rgba(245, 158, 11, 0.2);
                color: #fcd34d;
                border-left-color: #f59e0b;
            }

        @@media (max-width: 480px) {
            .login-card {
                padding: 30px 20px;
            }

            .logo span {
                font-size: 40px;
            }

            .logo i {
                font-size: 60px;
            }

            .login-form input {
                font-size: 16px;
                padding: 14px 16px;
            }

            .theme-toggle {
                width: 40px;
                height: 40px;
                font-size: 20px;
            }
        }
    </style>
</head>
<body class="login-page">
    <!-- Кнопка переключения темы -->
    <div class="theme-toggle" id="themeToggle" title="Сменить тему">
        <i class="fas fa-sun"></i>
    </div>

    <!-- Индустриальный фон -->
    <div class="industrial-bg"></div>
    <div class="rebar"></div>

    <!-- Иконки инструментов -->
    <i class="fas fa-hard-hat tool-icon tool-1"></i>
    <i class="fas fa-hammer tool-icon tool-2"></i>
    <i class="fas fa-trowel tool-icon tool-3"></i>
    <i class="fas fa-ruler-combined tool-icon tool-4"></i>
    <i class="fas fa-drill tool-icon tool-5"></i>
    <i class="fas fa-tools tool-icon tool-6"></i>
    <i class="fas fa-wrench tool-icon tool-7"></i>
    <i class="fas fa-saw tool-icon tool-8"></i>

    <div class="login-card">
        <div class="logo-container">
            <div class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </div>
            <div class="logo-tagline">Стройматериалы для дома</div>
        </div>

        <h2 class="login-heading">Восстановление пароля</h2>
        <p class="brand-subtitle">Введите ваш логин</p>

        @if (Model.SuccessMessage != null)
        {
            <div class="alert-success">
                <i class="fas fa-check-circle"></i> @Model.SuccessMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.GeneratedToken))
        {
            <div class="token-box">
                <i class="fas fa-key"></i> <strong>Одноразовый ключ:</strong> @Model.GeneratedToken<br />
                <small>Передайте его администратору для сброса пароля.</small>
            </div>
        }

        <form class="login-form" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Input.Username">Логин</label>
                <input asp-for="Input.Username" class="form-control" placeholder="Введите ваш логин" autofocus autocomplete="username" />
                <span asp-validation-for="Input.Username" class="text-danger"></span>
            </div>

            <button type="submit" class="login-btn">ВОССТАНОВИТЬ</button>

            <a asp-page="/Account/Login" class="back-link">← Вернуться на страницу входа</a>
        </form>

        <footer class="footer">© 2026 Моноплист</footer>
    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Переключение темы
            const themeToggle = document.getElementById('themeToggle');
            const icon = themeToggle.querySelector('i');
            const body = document.body;

            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            }

            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    icon.classList.remove('fa-sun');
                    icon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    icon.classList.remove('fa-moon');
                    icon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });
        });
    </script>
</body>
</html>