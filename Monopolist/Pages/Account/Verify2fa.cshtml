@page
@model Monoplist.Pages.Account.Verify2faModel
@{
    ViewData["Title"] = Model.Language == "ru" ? "Двухфакторная аутентификация" : (Model.Language == "en" ? "Two-factor authentication" : "Екі факторлы аутентификация");
    Layout = null;
}

<!DOCTYPE html>
<html lang="@Model.Language">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&family=Roboto+Condensed:wght@700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ===== БАЗОВЫЕ ПЕРЕМЕННЫЕ ===== */
        :root {
            --primary: @Model.CustomColor;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
        }

        body.compact-mode .login-card {
            padding: 30px 20px;
        }

        body.compact-mode .logo span {
            font-size: 40px;
        }

        body.compact-mode .logo i {
            font-size: 60px;
        }

        body.compact-mode .login-form input {
            font-size: 16px;
            padding: 14px 16px 14px 50px;
        }

        body.compact-mode .input-icon i {
            left: 18px;
            font-size: 20px;
        }

        body.compact-mode .login-btn {
            padding: 14px;
            font-size: 16px;
        }

        body.no-animations * {
            transition: none !important;
            animation: none !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        /* Индустриальный фон */
        .industrial-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            background-image: linear-gradient(rgba(255,255,255,0.3), rgba(255,255,255,0.3)), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23d4d4d4"/><path d="M10 10 L90 10 M10 30 L90 30 M10 50 L90 50 M10 70 L90 70 M10 90 L90 90 M10 10 L10 90 M30 10 L30 90 M50 10 L50 90 M70 10 L70 90 M90 10 L90 90" stroke="%23ff6b00" stroke-width="1" opacity="0.4"/></svg>');
            background-repeat: repeat;
            opacity: 0.8;
            pointer-events: none;
            transition: opacity 0.3s;
        }

        body.dark-theme .industrial-bg {
            opacity: 0.4;
            background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23333"/><path d="M10 10 L90 10 M10 30 L90 30 M10 50 L90 50 M10 70 L90 70 M10 90 L90 90 M10 10 L10 90 M30 10 L30 90 M50 10 L50 90 M70 10 L70 90 M90 10 L90 90" stroke="%23ff6b00" stroke-width="1" opacity="0.6"/></svg>');
        }

        .rebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,107,0,0.1) 20px, rgba(255,107,0,0.1) 22px);
            z-index: 1;
            pointer-events: none;
        }

        body.dark-theme .rebar {
            background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,107,0,0.2) 20px, rgba(255,107,0,0.2) 22px);
        }

        /* Плавающие инструменты */
        .tool-icon {
            position: fixed;
            font-size: 4rem;
            color: rgba(255,107,0,0.35);
            z-index: 1;
            pointer-events: none;
            animation: subtleFloat 14s infinite alternate ease-in-out;
        }

        body.dark-theme .tool-icon {
            color: rgba(255,107,0,0.5);
        }

        .tool-1 {
            top: 5%;
            left: 2%;
            transform: rotate(-15deg);
            animation-duration: 16s;
        }

        .tool-2 {
            bottom: 8%;
            right: 3%;
            transform: rotate(20deg);
            animation-duration: 18s;
        }

        .tool-3 {
            top: 20%;
            right: 10%;
            transform: rotate(5deg);
            animation-duration: 20s;
        }

        .tool-4 {
            bottom: 15%;
            left: 7%;
            transform: rotate(-10deg);
            animation-duration: 22s;
        }

        .tool-5 {
            top: 70%;
            left: 15%;
            transform: rotate(25deg);
            animation-duration: 24s;
            font-size: 5rem;
        }

        .tool-6 {
            bottom: 30%;
            right: 15%;
            transform: rotate(-20deg);
            animation-duration: 26s;
            font-size: 3.5rem;
        }

        .tool-7 {
            top: 40%;
            left: 20%;
            transform: rotate(10deg);
            animation-duration: 28s;
            font-size: 4.5rem;
        }

        .tool-8 {
            bottom: 50%;
            right: 5%;
            transform: rotate(-5deg);
            animation-duration: 30s;
            font-size: 3rem;
        }

        @@keyframes subtleFloat {
            0% {
                transform: translateY(0) rotate(0deg);
            }

            100% {
                transform: translateY(-20px) rotate(10deg);
            }
        }

        /* Кнопка переключения темы (точно как в Login) */
        .theme-toggle {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 100;
            background: rgba(255,255,255,0.8);
            border: 2px solid #FF6B00;
            border-radius: 50px;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            transition: all 0.3s;
            font-size: 24px;
            color: #FF6B00;
        }

            .theme-toggle:hover {
                transform: scale(1.1);
                background: #FF6B00;
                color: white;
                border-color: white;
            }

        body.dark-theme .theme-toggle {
            background: rgba(255,255,255,0.8);
            border-color: #FF6B00;
            color: #FF6B00;
        }

            body.dark-theme .theme-toggle:hover {
                background: #FF6B00;
                color: white;
                border-color: white;
            }

        /* Карточка */
        .login-card {
            position: relative;
            z-index: 10;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(4px);
            border-radius: 32px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3), 0 0 0 3px var(--primary) inset;
            width: 100%;
            max-width: 520px;
            padding: 50px 45px;
            animation: cardAppear 0.6s ease-out;
            margin: 30px auto;
            border: 1px solid var(--accent);
            transition: background 0.3s, box-shadow 0.3s, border-color 0.3s;
        }

        body.dark-theme .login-card {
            background: rgba(30, 30, 30, 0.98);
            box-shadow: 0 30px 60px rgba(0,0,0,0.8), 0 0 0 3px var(--primary) inset;
            border-color: var(--accent);
        }

        @@keyframes cardAppear {
            0% {
                opacity: 0;
                transform: translateY(30px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo-container {
            text-align: center;
            margin-bottom: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 8px;
        }

            .logo i {
                font-size: 85px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 8px var(--primary));
            }

            .logo span {
                font-family: 'Montserrat', sans-serif;
                font-size: 56px;
                font-weight: 900;
                background: linear-gradient(135deg, #2c3e50, #bdc3c7, var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
                letter-spacing: -1px;
            }

        .logo-tagline {
            font-family: 'Roboto Condensed', sans-serif;
            font-size: 17px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: #555;
            border-top: 2px solid var(--primary);
            padding-top: 12px;
            display: inline-block;
            transition: color 0.3s, border-color 0.3s;
        }

        body.dark-theme .logo-tagline {
            color: #aaa;
            border-top-color: var(--primary);
        }

        .login-heading {
            font-family: 'Montserrat', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 10px;
            text-align: center;
            text-transform: uppercase;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        .brand-subtitle {
            font-family: 'Poppins', sans-serif;
            font-size: 16px;
            color: #333;
            font-weight: 500;
            border-bottom: 2px solid var(--primary);
            padding-bottom: 20px;
            text-align: center;
            transition: color 0.3s, border-color 0.3s;
        }

        body.dark-theme .brand-subtitle {
            color: #ccc;
            border-bottom-color: var(--primary);
        }

        .login-form .form-group {
            margin-bottom: 25px;
        }

        .login-form label {
            display: block;
            font-size: 15px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        body.dark-theme .login-form label {
            color: var(--accent);
        }

        .login-form input {
            width: 100%;
            padding: 18px 20px 18px 60px;
            font-size: 18px;
            border: 2px solid #bbb;
            border-radius: 16px;
            background: #fff;
            transition: border 0.2s, box-shadow 0.2s, background 0.3s, color 0.3s;
            font-family: 'Poppins', sans-serif;
            color: #111;
            font-weight: 500;
        }

        body.dark-theme .login-form input {
            background: #333;
            border-color: #555;
            color: #eee;
        }

        .login-form input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(255,107,0,0.25);
        }

        body.dark-theme .login-form input:focus {
            background: #3a3a3a;
        }

        .input-icon {
            position: relative;
        }

            .input-icon i {
                position: absolute;
                left: 22px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--primary);
                font-size: 22px;
                transition: color 0.2s;
                pointer-events: none;
            }

            .input-icon.focused i {
                color: var(--accent);
            }

        body.dark-theme .input-icon i {
            color: var(--accent);
        }

        .login-btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            border-radius: 40px;
            color: white;
            font-size: 18px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 8px 0 #b34700;
            border: 1px solid var(--accent);
        }

            .login-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 0 #b34700;
                background: linear-gradient(135deg, var(--primary-light), var(--primary));
            }

            .login-btn:active {
                transform: translateY(4px);
                box-shadow: 0 4px 0 #b34700;
            }

        .text-danger {
            color: var(--danger);
            font-size: 0.85rem;
            margin-top: 4px;
            display: block;
        }

        .validation-summary-errors {
            background: rgba(255, 200, 200, 0.9);
            backdrop-filter: blur(4px);
            border-left: 6px solid var(--danger);
            border-radius: 16px;
            color: var(--danger);
            padding: 16px;
            margin-bottom: 20px;
            font-weight: 500;
            font-size: 15px;
        }

        body.dark-theme .validation-summary-errors {
            background: rgba(180, 60, 60, 0.3);
            color: #ffaaaa;
            border-left-color: var(--danger);
        }

        .validation-summary-errors ul {
            margin-top: 8px;
            padding-left: 20px;
        }

        .form-check {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 10px 0 15px 0;
            cursor: pointer;
        }

        .form-check-input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .form-check-label {
            position: relative;
            padding-left: 34px;
            font-size: 16px;
            color: #222;
            font-weight: 600;
            cursor: pointer;
            user-select: none;
            transition: color 0.2s;
        }

        body.dark-theme .form-check-label {
            color: #ccc;
        }

        .form-check-label:before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 24px;
            height: 24px;
            border: 2px solid var(--primary);
            background: #fff;
            border-radius: 6px;
            transition: background 0.2s, border-color 0.2s;
        }

        body.dark-theme .form-check-label:before {
            background: #333;
            border-color: var(--accent);
        }

        .form-check-label:after {
            content: '\f00c';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            left: 4px;
            top: 50%;
            transform: translateY(-50%) scale(0);
            color: var(--accent);
            font-size: 18px;
            transition: transform 0.2s;
        }

        .form-check-input:checked + .form-check-label:after {
            transform: translateY(-50%) scale(1);
        }

        .form-check-input:checked + .form-check-label:before {
            background: var(--primary);
            border-color: var(--accent);
        }

        body.dark-theme .form-check-input:checked + .form-check-label:before {
            background: var(--primary);
            border-color: var(--accent);
        }

        .form-check-input:focus + .form-check-label:before {
            box-shadow: 0 0 0 3px rgba(255,107,0,0.4);
        }

        .footer {
            text-align: center;
            color: #666;
            font-size: 14px;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 2px solid var(--primary);
            transition: color 0.3s, border-color 0.3s;
        }

        body.dark-theme .footer {
            color: #888;
            border-top-color: var(--primary);
        }
    </style>
</head>
<body class="@(Model.Theme == "dark" ? "dark-theme" : "") @(Model.CompactMode ? "compact-mode" : "") @(Model.Animations ? "" : "no-animations")">
    <!-- Кнопка переключения темы (точно как в Login) -->
    <div class="theme-toggle" id="themeToggle" title="@(Model.Language == "ru" ? "Сменить тему" : Model.Language == "en" ? "Toggle theme" : "Тақырыпты ауыстыру")">
        <i class="fas fa-sun"></i>
    </div>

    <!-- Индустриальный фон -->
    <div class="industrial-bg"></div>
    <div class="rebar"></div>

    <!-- Плавающие иконки инструментов -->
    <i class="fas fa-hard-hat tool-icon tool-1"></i>
    <i class="fas fa-hammer tool-icon tool-2"></i>
    <i class="fas fa-trowel tool-icon tool-3"></i>
    <i class="fas fa-ruler-combined tool-icon tool-4"></i>
    <i class="fas fa-drill tool-icon tool-5"></i>
    <i class="fas fa-tools tool-icon tool-6"></i>
    <i class="fas fa-wrench tool-icon tool-7"></i>
    <i class="fas fa-saw tool-icon tool-8"></i>

    <div class="login-card">
        <div class="logo-container">
            <div class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </div>
            <div class="logo-tagline">Стройматериалы для дома</div>
        </div>

        <h2 class="login-heading">@ViewData["Title"]</h2>
        <p class="brand-subtitle">@(Model.Language == "ru" ? "Введите код из приложения аутентификатора" : Model.Language == "en" ? "Enter the code from your authenticator app" : "Аутентификатор қолданбасынан кодты енгізіңіз")</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary-errors">
                <i class="fas fa-exclamation-circle"></i>
                <span>@(Model.Language == "ru" ? "Пожалуйста, исправьте ошибки:" : Model.Language == "en" ? "Please correct the errors:" : "Қателерді түзетіңіз:")</span>
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form method="post" class="login-form">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Input.Code">@(Model.Language == "ru" ? "Код подтверждения" : Model.Language == "en" ? "Verification code" : "Растау коды")</label>
                <div class="input-icon">
                    <i class="fas fa-shield-alt"></i>
                    <input asp-for="Input.Code" class="form-control" placeholder="000000" autofocus autocomplete="off" />
                </div>
                <span asp-validation-for="Input.Code" class="text-danger"></span>
            </div>

            <div class="form-check">
                <input asp-for="Input.RememberMe" class="form-check-input" id="rememberMe" />
                <label class="form-check-label" for="rememberMe">@(Model.Language == "ru" ? "Запомнить меня" : Model.Language == "en" ? "Remember me" : "Мені есте сақта")</label>
            </div>

            <button type="submit" class="login-btn">@(Model.Language == "ru" ? "Подтвердить" : Model.Language == "en" ? "Verify" : "Растау")</button>
        </form>

        <footer class="footer">© 2026 Моноплист</footer>
    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Эффект фокуса на поле
            const inputs = document.querySelectorAll('.input-icon input');
            inputs.forEach(input => {
                input.addEventListener('focus', () => {
                    input.closest('.input-icon').classList.add('focused');
                });
                input.addEventListener('blur', () => {
                    input.closest('.input-icon').classList.remove('focused');
                });
            });

            // Переключение темы (как в Login)
            const themeToggle = document.getElementById('themeToggle');
            const body = document.body;
            const themeIcon = themeToggle.querySelector('i');

            const savedTheme = localStorage.getItem('theme') || '@Model.Theme';
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                themeIcon.classList.remove('fa-sun');
                themeIcon.classList.add('fa-moon');
            }

            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });

            // Авто-скрытие алерта (если есть)
            const alert = document.querySelector('.validation-summary-errors');
            if (alert) {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 500);
                }, 8000);
            }
        });
    </script>
</body>
</html>