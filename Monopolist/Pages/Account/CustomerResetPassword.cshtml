@page
@model Monoplist.Pages.Account.CustomerResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Сброс пароля";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&family=Roboto+Condensed:wght@700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* Полностью идентичные компактные стили, как в ForgotPassword */
        body.login-page {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Poppins', sans-serif;
            background: #e5e7eb;
            overflow-y: auto;
            position: relative;
        }

        .theme-toggle {
            position: fixed;
            top: 15px;
            right: 15px;
            z-index: 100;
            background: rgba(255,255,255,0.8);
            border: 2px solid #FF6B00;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 20px;
            color: #FF6B00;
        }

        .industrial-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            background-image: linear-gradient(rgba(255,255,255,0.3), rgba(255,255,255,0.3)), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23d4d4d4"/><path d="M10 10 L90 10 M10 30 L90 30 M10 50 L90 50 M10 70 L90 70 M10 90 L90 90 M10 10 L10 90 M30 10 L30 90 M50 10 L50 90 M70 10 L70 90 M90 10 L90 90" stroke="%23ff6b00" stroke-width="1" opacity="0.4"/></svg>');
            background-repeat: repeat;
            opacity: 0.8;
            pointer-events: none;
        }

        .rebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,107,0,0.1) 20px, rgba(255,107,0,0.1) 22px);
            z-index: 1;
            pointer-events: none;
        }

        .tool-icon {
            position: fixed;
            font-size: 2.5rem;
            color: rgba(255,107,0,0.25);
            z-index: 1;
            pointer-events: none;
            animation: subtleFloat 14s infinite alternate ease-in-out;
        }

        .tool-1 {
            top: 5%;
            left: 2%;
            animation-duration: 16s;
        }

        .tool-2 {
            bottom: 8%;
            right: 3%;
            animation-duration: 18s;
        }

        .tool-3 {
            top: 20%;
            right: 10%;
            animation-duration: 20s;
        }

        .tool-4 {
            bottom: 15%;
            left: 7%;
            animation-duration: 22s;
        }

        .tool-5 {
            top: 70%;
            left: 15%;
            animation-duration: 24s;
            font-size: 3rem;
        }

        .tool-6 {
            bottom: 30%;
            right: 15%;
            animation-duration: 26s;
        }

        .tool-7 {
            top: 40%;
            left: 20%;
            animation-duration: 28s;
        }

        .tool-8 {
            bottom: 50%;
            right: 5%;
            animation-duration: 30s;
        }

        @@keyframes subtleFloat {
            0% {
                transform: translateY(0) rotate(0deg);
            }

            100% {
                transform: translateY(-15px) rotate(8deg);
            }
        }

        .login-card {
            position: relative;
            z-index: 10;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(4px);
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2), 0 0 0 2px #FF6B00 inset;
            width: 100%;
            max-width: 380px;
            padding: 25px 20px;
            animation: cardAppear 0.5s ease-out;
            margin: 20px auto;
            border: 1px solid #FFD700;
            box-sizing: border-box;
        }

        @@keyframes cardAppear {
            0% {
                opacity: 0;
                transform: translateY(15px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo-container {
            text-align: center;
            margin-bottom: 12px;
        }

        .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 3px;
        }

            .logo i {
                font-size: 55px;
                background: linear-gradient(145deg, #FF8C00, #FF4500, #FFD700);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            .logo span {
                font-family: 'Montserrat', sans-serif;
                font-size: 38px;
                font-weight: 900;
                background: linear-gradient(135deg, #2c3e50, #bdc3c7, #FF6B00);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                letter-spacing: -1px;
            }

        .logo-tagline {
            font-family: 'Roboto Condensed', sans-serif;
            font-size: 12px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #555;
            border-top: 1px solid #FF6B00;
            padding-top: 5px;
            display: inline-block;
        }

        .login-heading {
            font-size: 20px;
            font-weight: 700;
            color: #FF6B00;
            margin-bottom: 5px;
            text-align: center;
        }

        .brand-subtitle {
            font-size: 12px;
            color: #333;
            font-weight: 500;
            border-bottom: 1px solid #FF6B00;
            padding-bottom: 10px;
            text-align: center;
            margin-bottom: 15px;
        }

        .form-group {
            margin-bottom: 14px;
        }

        label {
            display: block;
            font-size: 12px;
            font-weight: 700;
            color: #FF6B00;
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-icon {
            position: relative;
        }

            .input-icon i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #FF6B00;
                font-size: 14px;
                pointer-events: none;
            }

        input {
            width: 100%;
            padding: 8px 12px 8px 36px;
            font-size: 14px;
            border: 2px solid #bbb;
            border-radius: 12px;
            background: #fff;
            transition: border 0.2s, box-shadow 0.2s;
            font-family: 'Poppins', sans-serif;
            color: #111;
            font-weight: 500;
            box-sizing: border-box;
        }

            input:focus {
                outline: none;
                border-color: #FF6B00;
                box-shadow: 0 0 0 2px rgba(255,107,0,0.2);
            }

        .password-wrapper {
            position: relative;
        }

            .password-wrapper input {
                padding-right: 40px;
            }

        .toggle-password {
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 1.2rem;
            color: #FF6B00;
            width: 30px;
            height: 30px;
            border-radius: 50%;
        }

        .login-btn {
            width: 100%;
            padding: 10px;
            background: linear-gradient(135deg, #FF6B00, #FF4500);
            border: none;
            border-radius: 30px;
            color: white;
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 4px 0 #b34700;
            border: 1px solid #FFD700;
            margin-top: 5px;
            box-sizing: border-box;
        }

            .login-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 0 #b34700;
            }

        .links-container {
            margin-top: 15px;
            text-align: center;
        }

        .back-link {
            color: #FF6B00;
            text-decoration: none;
            font-weight: 600;
            font-size: 12px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .validation-summary {
            padding: 10px;
            border-radius: 12px;
            margin-bottom: 15px;
            font-size: 12px;
            background: rgba(255, 200, 200, 0.9);
            border-left: 3px solid #ff4444;
            color: #b30000;
        }

        .btn-close {
            background: none;
            border: none;
            font-size: 1.2rem;
            cursor: pointer;
            float: right;
        }

        .footer {
            text-align: center;
            color: #666;
            font-size: 11px;
            margin-top: 15px;
            padding-top: 10px;
            border-top: 1px solid #FF6B00;
        }

        body.dark-theme {
            background: #1a1a1a;
        }

            body.dark-theme .industrial-bg {
                opacity: 0.4;
                background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23333"/><path d="M10 10 L90 10 M10 30 L90 30 M10 50 L90 50 M10 70 L90 70 M10 90 L90 90 M10 10 L10 90 M30 10 L30 90 M50 10 L50 90 M70 10 L70 90 M90 10 L90 90" stroke="%23ff6b00" stroke-width="1" opacity="0.6"/></svg>');
            }

            body.dark-theme .rebar {
                background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,107,0,0.2) 20px, rgba(255,107,0,0.2) 22px);
            }

            body.dark-theme .login-card {
                background: rgba(30, 30, 30, 0.98);
                box-shadow: 0 15px 35px rgba(0,0,0,0.6), 0 0 0 2px #FF6B00 inset;
                border-color: #FFD700;
            }

            body.dark-theme .logo-tagline,
            body.dark-theme .brand-subtitle {
                color: #ccc;
            }

            body.dark-theme label {
                color: #FFD700;
            }

            body.dark-theme input {
                background: #333;
                border-color: #555;
                color: #eee;
            }

            body.dark-theme .input-icon i {
                color: #FFD700;
            }

            body.dark-theme .toggle-password {
                color: #FFD700;
            }

            body.dark-theme .back-link {
                color: #FFD700;
            }

            body.dark-theme .validation-summary {
                background: rgba(180, 60, 60, 0.3);
                color: #ffaaaa;
            }

            body.dark-theme .footer {
                color: #888;
            }
        @@media (max-width: 480px) {
            .login-card

        {
            padding: 20px 15px;
            max-width: 95%;
        }

        .logo span {
            font-size: 32px;
        }

        .logo i {
            font-size: 45px;
        }

        input {
            font-size: 13px;
            padding: 7px 10px 7px 32px;
        }

        .input-icon i {
            left: 10px;
            font-size: 12px;
        }

        .toggle-password {
            right: 5px;
            width: 28px;
            height: 28px;
            font-size: 1rem;
        }

        }
    </style>
</head>
<body class="login-page">
    <div class="theme-toggle" id="themeToggle">
        <i class="fas fa-sun"></i>
    </div>
    <div class="industrial-bg"></div>
    <div class="rebar"></div>
    <i class="fas fa-hard-hat tool-icon tool-1"></i>
    <i class="fas fa-hammer tool-icon tool-2"></i>
    <i class="fas fa-trowel tool-icon tool-3"></i>
    <i class="fas fa-ruler-combined tool-icon tool-4"></i>
    <i class="fas fa-drill tool-icon tool-5"></i>
    <i class="fas fa-tools tool-icon tool-6"></i>
    <i class="fas fa-wrench tool-icon tool-7"></i>
    <i class="fas fa-saw tool-icon tool-8"></i>

    <div class="login-card">
        <div class="logo-container">
            <div class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </div>
            <div class="logo-tagline">Стройматериалы для дома</div>
        </div>

        <h1 class="login-heading">Создание нового пароля</h1>
        <p class="brand-subtitle">Введите новый пароль для вашей учётной записи</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary">
                <i class="fas fa-exclamation-circle"></i>
                <span>Пожалуйста, исправьте ошибки:</span>
                <button type="button" class="btn-close">&times;</button>
                <ul style="margin-top:5px; margin-left:20px;">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div class="form-group">
                <label asp-for="Input.Password">Новый пароль</label>
                <div class="input-icon password-wrapper">
                    <i class="fas fa-lock"></i>
                    <input asp-for="Input.Password" type="password" id="newPassword" />
                    <button type="button" class="toggle-password" data-target="newPassword">
                        <i class="far fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.ConfirmPassword">Подтверждение пароля</label>
                <div class="input-icon password-wrapper">
                    <i class="fas fa-lock"></i>
                    <input asp-for="Input.ConfirmPassword" type="password" id="confirmPassword" />
                    <button type="button" class="toggle-password" data-target="confirmPassword">
                        <i class="far fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size:11px;"></span>
            </div>

            <button type="submit" class="login-btn">Сохранить пароль</button>

            <div class="links-container">
                <a asp-page="./CustomerLogin" class="back-link"><i class="fas fa-arrow-left"></i> Вернуться ко входу</a>
            </div>
        </form>

        <footer class="footer">© 2026 Моноплист</footer>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const themeToggle = document.getElementById('themeToggle');
            const icon = themeToggle.querySelector('i');
            const body = document.body;
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            }
            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    icon.classList.remove('fa-sun');
                    icon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    icon.classList.remove('fa-moon');
                    icon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });

            const toggleButtons = document.querySelectorAll('.toggle-password');
            toggleButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    const targetId = this.getAttribute('data-target');
                    const input = document.getElementById(targetId);
                    if (input) {
                        const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                        input.setAttribute('type', type);
                        const iconSpan = this.querySelector('i');
                        iconSpan.classList.toggle('fa-eye');
                        iconSpan.classList.toggle('fa-eye-slash');
                    }
                });
            });

            const closeBtns = document.querySelectorAll('.btn-close');
            closeBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    const parent = this.closest('.validation-summary');
                    if (parent) {
                        parent.style.opacity = '0';
                        setTimeout(() => parent.style.display = 'none', 300);
                    }
                });
            });
        });
    </script>
</body>
</html>