@page
@model Monoplist.Pages.Account.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход | Моноплист</title>

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Google Fonts: индустриальные шрифты -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&family=Roboto+Condensed:wght@700&display=swap" rel="stylesheet" />

    <!-- Font Awesome 6 (иконки) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

    <!-- Основной стиль сайта (если есть) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* ===== БАЗОВЫЕ ПЕРЕМЕННЫЕ ===== */
        body.login-page {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Poppins', sans-serif;
            background: #e5e7eb;
            overflow-y: auto;
            position: relative;
            transition: background-color 0.3s, color 0.3s;
        }

        /* Кнопка переключения темы */
        .theme-toggle {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 100;
            background: rgba(255,255,255,0.8);
            border: 2px solid #FF6B00;
            border-radius: 50px;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            transition: all 0.3s;
            font-size: 24px;
            color: #FF6B00;
        }

            .theme-toggle:hover {
                transform: scale(1.1);
                background: #FF6B00;
                color: white;
                border-color: white;
            }

        /* Текстура светлого бетона с арматурой */
        .industrial-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            background-image: linear-gradient(rgba(255,255,255,0.3), rgba(255,255,255,0.3)), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23d4d4d4"/><path d="M10 10 L90 10 M10 30 L90 30 M10 50 L90 50 M10 70 L90 70 M10 90 L90 90 M10 10 L10 90 M30 10 L30 90 M50 10 L50 90 M70 10 L70 90 M90 10 L90 90" stroke="%23ff6b00" stroke-width="1" opacity="0.4"/></svg>');
            background-repeat: repeat;
            opacity: 0.8;
            pointer-events: none;
            transition: opacity 0.3s;
        }

        /* Арматурные прутья */
        .rebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,107,0,0.1) 20px, rgba(255,107,0,0.1) 22px);
            z-index: 1;
            pointer-events: none;
        }

        /* Плавающие инструменты (общие для обеих тем) */
        .tool-icon {
            position: fixed;
            font-size: 4rem;
            color: rgba(255,107,0,0.35);
            z-index: 1;
            pointer-events: none;
            animation: subtleFloat 14s infinite alternate ease-in-out;
        }

        .tool-1 {
            top: 5%;
            left: 2%;
            transform: rotate(-15deg);
            animation-duration: 16s;
        }

        .tool-2 {
            bottom: 8%;
            right: 3%;
            transform: rotate(20deg);
            animation-duration: 18s;
        }

        .tool-3 {
            top: 20%;
            right: 10%;
            transform: rotate(5deg);
            animation-duration: 20s;
        }

        .tool-4 {
            bottom: 15%;
            left: 7%;
            transform: rotate(-10deg);
            animation-duration: 22s;
        }

        .tool-5 {
            top: 70%;
            left: 15%;
            transform: rotate(25deg);
            animation-duration: 24s;
            font-size: 5rem;
        }

        .tool-6 {
            bottom: 30%;
            right: 15%;
            transform: rotate(-20deg);
            animation-duration: 26s;
            font-size: 3.5rem;
        }

        .tool-7 {
            top: 40%;
            left: 20%;
            transform: rotate(10deg);
            animation-duration: 28s;
            font-size: 4.5rem;
        }

        .tool-8 {
            bottom: 50%;
            right: 5%;
            transform: rotate(-5deg);
            animation-duration: 30s;
            font-size: 3rem;
        }

        @@keyframes subtleFloat {
            0% {
                transform: translateY(0) rotate(0deg);
            }

            100% {
                transform: translateY(-20px) rotate(10deg);
            }
        }

        /* Карточка входа */
        .login-card {
            position: relative;
            z-index: 10;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(4px);
            border-radius: 32px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3), 0 0 0 3px #FF6B00 inset;
            width: 100%;
            max-width: 520px;
            padding: 50px 45px;
            animation: cardAppear 0.6s ease-out;
            margin: 30px auto;
            border: 1px solid #FFD700;
            transition: background 0.3s, box-shadow 0.3s, border-color 0.3s;
        }

        @@keyframes cardAppear {
            0% {
                opacity: 0;
                transform: translateY(30px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Логотип (статичный) */
        .logo-container {
            text-align: center;
            margin-bottom: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 8px;
        }

            .logo i {
                font-size: 85px;
                background: linear-gradient(145deg, #FF8C00, #FF4500, #FFD700);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 8px #FF6B00);
            }

            .logo span {
                font-family: 'Montserrat', sans-serif;
                font-size: 56px;
                font-weight: 900;
                background: linear-gradient(135deg, #2c3e50, #bdc3c7, #FF6B00);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
                letter-spacing: -1px;
            }

        .logo-tagline {
            font-family: 'Roboto Condensed', sans-serif;
            font-size: 17px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: #555;
            border-top: 2px solid #FF6B00;
            padding-top: 12px;
            display: inline-block;
            transition: color 0.3s, border-color 0.3s;
        }

        .login-heading {
            font-family: 'Montserrat', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: #FF6B00;
            margin-bottom: 10px;
            text-align: center;
            text-transform: uppercase;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        .brand-subtitle {
            font-family: 'Poppins', sans-serif;
            font-size: 16px;
            color: #333;
            font-weight: 500;
            border-bottom: 2px solid #FF6B00;
            padding-bottom: 20px;
            text-align: center;
            transition: color 0.3s, border-color 0.3s;
        }

        /* Табы переключения */
        .auth-tabs {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 30px;
            border-bottom: 2px solid rgba(255,107,0,0.3);
            padding-bottom: 10px;
        }

        .auth-tab {
            background: none;
            border: none;
            font-size: 18px;
            font-weight: 700;
            padding: 8px 20px;
            cursor: pointer;
            color: #666;
            transition: all 0.2s;
            border-radius: 40px;
            font-family: 'Poppins', sans-serif;
        }

        body.dark-theme .auth-tab {
            color: white;
        }

        .auth-tab.active {
            background: linear-gradient(135deg, #FF6B00, #FF4500);
            color: white;
            box-shadow: 0 4px 10px rgba(255,107,0,0.3);
        }

        .auth-tab:hover:not(.active) {
            background: rgba(255,107,0,0.1);
            color: #FF6B00;
        }

        body.dark-theme .auth-tab:hover:not(.active) {
            background: rgba(255,107,0,0.2);
            color: #FFD700;
        }

        /* Формы */
        .auth-form {
            transition: opacity 0.3s ease;
        }

        .hidden-form {
            display: none;
        }

        /* Поля ввода (общие) */
        .login-form .form-group {
            margin-bottom: 25px;
        }

        .login-form label {
            display: block;
            font-size: 15px;
            font-weight: 700;
            color: #FF6B00;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .login-form input {
            width: 100%;
            padding: 18px 20px 18px 60px;
            font-size: 18px;
            border: 2px solid #bbb;
            border-radius: 16px;
            background: #fff;
            transition: border 0.2s, box-shadow 0.2s, background 0.3s, color 0.3s;
            font-family: 'Poppins', sans-serif;
            color: #111;
            font-weight: 500;
        }

            .login-form input:focus {
                outline: none;
                border-color: #FF6B00;
                box-shadow: 0 0 0 4px rgba(255,107,0,0.25);
                background: #fff;
            }

        .input-icon {
            position: relative;
        }

            .input-icon i {
                position: absolute;
                left: 22px;
                top: 50%;
                transform: translateY(-50%);
                color: #FF6B00;
                font-size: 22px;
                transition: color 0.2s;
                pointer-events: none;
            }

            .input-icon.focused i {
                color: #FFD700;
            }

        .password-wrapper {
            position: relative;
        }

            .password-wrapper input {
                padding-right: 60px;
            }

        .toggle-password {
            position: absolute;
            right: 18px;
            top: 50%;
            transform: translateY(-50%);
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 1.6rem;
            color: #FF6B00;
            transition: color 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 50%;
        }

            .toggle-password:hover {
                color: #FFD700;
            }

        .form-check {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 10px 0 15px 0;
            cursor: pointer;
        }

        .form-check-input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .form-check-label {
            position: relative;
            padding-left: 34px;
            font-size: 16px;
            color: #222;
            font-weight: 600;
            cursor: pointer;
            user-select: none;
            transition: color 0.2s;
        }

            .form-check-label:before {
                content: '';
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 24px;
                height: 24px;
                border: 2px solid #FF6B00;
                background: #fff;
                border-radius: 6px;
                transition: background 0.2s, border-color 0.2s;
            }

            .form-check-label:after {
                content: '\f00c';
                font-family: 'Font Awesome 6 Free';
                font-weight: 900;
                position: absolute;
                left: 4px;
                top: 50%;
                transform: translateY(-50%) scale(0);
                color: #FFD700;
                font-size: 18px;
                transition: transform 0.2s;
            }

        .form-check-input:checked + .form-check-label:after {
            transform: translateY(-50%) scale(1);
        }

        .form-check-input:checked + .form-check-label:before {
            background: #FF6B00;
            border-color: #FFD700;
        }

        .form-check-input:focus + .form-check-label:before {
            box-shadow: 0 0 0 3px rgba(255,107,0,0.4);
        }

        .login-btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, #FF6B00, #FF4500);
            border: none;
            border-radius: 40px;
            color: white;
            font-size: 18px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 8px 0 #b34700;
            border: 1px solid #FFD700;
        }

            .login-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 0 #b34700;
                background: linear-gradient(135deg, #FF8C00, #FF6B00);
            }

            .login-btn:active {
                transform: translateY(4px);
                box-shadow: 0 4px 0 #b34700;
            }

        .links-container {
            display: flex;
            justify-content: flex-start;
            margin-top: 20px;
            font-size: 15px;
        }

        .forgot-password {
            color: #FF6B00;
            text-decoration: none;
            font-weight: 700;
            transition: color 0.2s;
            text-transform: uppercase;
        }

            .forgot-password:hover {
                color: #FFD700;
                text-decoration: underline;
            }

        .validation-summary {
            background: rgba(255, 200, 200, 0.9);
            backdrop-filter: blur(4px);
            border-left: 6px solid #ff4444;
            border-radius: 16px;
            color: #b30000;
            padding: 16px;
            margin-bottom: 20px;
            font-weight: 500;
            font-size: 15px;
        }

        .alert-danger ul {
            margin-top: 8px;
            padding-left: 20px;
        }

        .btn-close {
            background: none;
            border: none;
            color: #b30000;
            font-size: 1.5rem;
            line-height: 1;
            cursor: pointer;
            float: right;
        }

        .demo-accounts {
            background: rgba(255, 255, 255, 0.9);
            border: 2px solid #FF6B00;
            border-radius: 20px;
            padding: 20px;
            margin: 30px 0 20px;
            transition: background 0.3s, border-color 0.3s;
        }

            .demo-accounts h3 {
                color: #FF6B00;
                font-size: 18px;
                font-weight: 700;
                text-align: center;
                margin-bottom: 15px;
                text-transform: uppercase;
            }

        .account-item {
            background: #f8f8f8;
            border-radius: 12px;
            padding: 15px 18px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            border-left: 4px solid #FF6B00;
            transition: transform 0.2s, background 0.3s, color 0.3s;
        }

            .account-item:hover {
                transform: translateX(5px);
            }

        .role {
            font-weight: 700;
            color: #222;
            min-width: 140px;
            font-size: 17px;
        }

        .credentials {
            font-family: 'Courier New', monospace;
            color: #333;
            background: #fff;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 16px;
            border: 1px solid #FF6B00;
            transition: background 0.3s, color 0.3s, border-color 0.3s;
        }

        .customer-info {
            text-align: center;
            margin-top: 15px;
            font-size: 14px;
            color: #666;
        }

            .customer-info a {
                color: #FF6B00;
                text-decoration: none;
                font-weight: 600;
            }

                .customer-info a:hover {
                    color: #FFD700;
                    text-decoration: underline;
                }

        .footer {
            text-align: center;
            color: #666;
            font-size: 14px;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 2px solid #FF6B00;
            transition: color 0.3s, border-color 0.3s;
        }

        /* ===== ТЁМНАЯ ТЕМА ===== */
        body.dark-theme {
            background: #1a1a1a;
        }

            body.dark-theme .industrial-bg {
                opacity: 0.4;
                background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23333"/><path d="M10 10 L90 10 M10 30 L90 30 M10 50 L90 50 M10 70 L90 70 M10 90 L90 90 M10 10 L10 90 M30 10 L30 90 M50 10 L50 90 M70 10 L70 90 M90 10 L90 90" stroke="%23ff6b00" stroke-width="1" opacity="0.6"/></svg>');
            }

            body.dark-theme .rebar {
                background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,107,0,0.2) 20px, rgba(255,107,0,0.2) 22px);
            }

            body.dark-theme .tool-icon {
                color: rgba(255,107,0,0.5);
            }

            body.dark-theme .login-card {
                background: rgba(30, 30, 30, 0.98);
                box-shadow: 0 30px 60px rgba(0,0,0,0.8), 0 0 0 3px #FF6B00 inset;
                border-color: #FFD700;
            }

            body.dark-theme .logo-tagline {
                color: #aaa;
                border-top-color: #FF6B00;
            }

            body.dark-theme .brand-subtitle {
                color: #ccc;
                border-bottom-color: #FF6B00;
            }

            body.dark-theme .login-form label {
                color: #FFD700;
            }

            body.dark-theme .login-form input {
                background: #333;
                border-color: #555;
                color: #eee;
            }

                body.dark-theme .login-form input:focus {
                    background: #3a3a3a;
                }

            body.dark-theme .input-icon i {
                color: #FFD700;
            }

            body.dark-theme .toggle-password {
                color: #FFD700;
            }

            body.dark-theme .form-check-label {
                color: #ccc;
            }

                body.dark-theme .form-check-label:before {
                    background: #333;
                    border-color: #FFD700;
                }

            body.dark-theme .form-check-input:checked + .form-check-label:before {
                background: #FF6B00;
                border-color: #FFD700;
            }

            body.dark-theme .forgot-password {
                color: #FFD700;
            }

            body.dark-theme .validation-summary {
                background: rgba(180, 60, 60, 0.3);
                color: #ffaaaa;
                border-left-color: #ff4444;
            }

            body.dark-theme .btn-close {
                color: #ffaaaa;
            }

            body.dark-theme .demo-accounts {
                background: rgba(0,0,0,0.5);
                border-color: #FF6B00;
            }

                body.dark-theme .demo-accounts h3 {
                    color: #FFD700;
                }

            body.dark-theme .account-item {
                background: #2a2a2a;
            }

            body.dark-theme .role {
                color: #FFD700;
            }

            body.dark-theme .credentials {
                background: #1a1a1a;
                color: #ccc;
                border-color: #FF6B00;
            }

            body.dark-theme .customer-info {
                color: #aaa;
            }

                body.dark-theme .customer-info a {
                    color: #FFD700;
                }

            body.dark-theme .footer {
                color: #888;
                border-top-color: #FF6B00;
            }

        /* ===== ПРЕЛОАДЕР ===== */
        .preloader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s ease, visibility 0.5s ease;
            opacity: 1;
            visibility: visible;
        }

        .preloader-content {
            text-align: center;
            max-width: 400px;
            padding: 30px;
        }

        .preloader-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 20px;
        }

            .preloader-logo i {
                font-size: 70px;
                background: linear-gradient(145deg, #FF8C00, #FF4500, #FFD700);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 8px #FF6B00);
            }

            .preloader-logo span {
                font-family: 'Montserrat', sans-serif;
                font-size: 48px;
                font-weight: 900;
                background: linear-gradient(135deg, #2c3e50, #bdc3c7, #FF6B00);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                letter-spacing: -1px;
            }

        .preloader-message {
            font-family: 'Poppins', sans-serif;
            font-size: 24px;
            font-weight: 600;
            color: #FF6B00;
            margin: 20px 0 30px;
            text-transform: uppercase;
            letter-spacing: 2px;
            animation: pulse 1.5s infinite;
        }

        .preloader-spinner {
            width: 60px;
            height: 60px;
            margin: 0 auto;
            border: 6px solid rgba(255, 107, 0, 0.3);
            border-top: 6px solid #FF6B00;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        @@keyframes pulse {
            0% {
                opacity: 0.7;
            }

            50% {
                opacity: 1;
            }

            100% {
                opacity: 0.7;
            }
        }

        body.dark-theme .preloader {
            background: rgba(20, 20, 20, 0.98);
            backdrop-filter: blur(10px);
        }

        body.dark-theme .preloader-message {
            color: #FFD700;
        }

        body.dark-theme .preloader-spinner {
            border-color: rgba(255, 215, 0, 0.3);
            border-top-color: #FFD700;
        }

        @@media (max-width: 480px) {
            .login-card {
                padding: 30px 20px;
            }

            .logo span {
                font-size: 40px;
            }

            .logo i {
                font-size: 60px;
            }

            .login-form input {
                font-size: 16px;
                padding: 14px 16px 14px 50px;
            }

            .input-icon i {
                left: 18px;
                font-size: 20px;
            }

            .account-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .role {
                margin-bottom: 5px;
            }

            .theme-toggle {
                width: 40px;
                height: 40px;
                font-size: 20px;
            }

            .auth-tabs {
                gap: 5px;
            }

            .auth-tab {
                font-size: 14px;
                padding: 6px 12px;
            }
        }
    </style>
</head>
<body class="login-page">
    <!-- Preloader -->
    <div class="preloader" id="preloader">
        <div class="preloader-content">
            <div class="preloader-logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </div>
            <div class="preloader-message">Добро пожаловать в систему</div>
            <div class="preloader-spinner"></div>
        </div>
    </div>

    <!-- Кнопка переключения темы -->
    <div class="theme-toggle" id="themeToggle" title="Сменить тему">
        <i class="fas fa-sun"></i>
    </div>

    <!-- Индустриальный фон -->
    <div class="industrial-bg"></div>
    <div class="rebar"></div>

    <!-- Иконки инструментов -->
    <i class="fas fa-hard-hat tool-icon tool-1"></i>
    <i class="fas fa-hammer tool-icon tool-2"></i>
    <i class="fas fa-trowel tool-icon tool-3"></i>
    <i class="fas fa-ruler-combined tool-icon tool-4"></i>
    <i class="fas fa-drill tool-icon tool-5"></i>
    <i class="fas fa-tools tool-icon tool-6"></i>
    <i class="fas fa-wrench tool-icon tool-7"></i>
    <i class="fas fa-saw tool-icon tool-8"></i>

    <div class="login-card">
        <div class="logo-container">
            <div class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </div>
            <div class="logo-tagline">Стройматериалы для дома</div>
        </div>

        <!-- Табы переключения -->
        <div class="auth-tabs">
            <button class="auth-tab active" data-tab="employee">Сотрудники</button>
            <button class="auth-tab" data-tab="customer">Клиенты</button>
        </div>

        <!-- Форма для сотрудников -->
        <div id="employee-form" class="auth-form">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary alert alert-danger alert-dismissible">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>Пожалуйста, исправьте ошибки:</span>
                    <button type="button" class="btn-close" aria-label="Закрыть">&times;</button>
                    <ul>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form class="login-form" method="post" asp-route-returnUrl="@Model.ReturnUrl">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Input.Username">Логин</label>
                    <div class="input-icon">
                        <i class="fas fa-user"></i>
                        <input asp-for="Input.Username" class="form-control" placeholder="Введите ваш логин" autofocus autocomplete="username" />
                    </div>
                    <span asp-validation-for="Input.Username" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Password">Пароль</label>
                    <div class="input-icon password-wrapper">
                        <i class="fas fa-lock"></i>
                        <input asp-for="Input.Password" class="form-control" placeholder="Введите ваш пароль" autocomplete="current-password" id="password-field" />
                        <button type="button" class="toggle-password" aria-label="Показать/скрыть пароль">
                            <i class="far fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input" id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">Запомнить меня</label>
                </div>

                <button type="submit" class="login-btn">ВОЙТИ В СИСТЕМУ</button>

                <div class="links-container">
                    <a asp-page="/Account/ForgotPassword" class="forgot-password">Забыли пароль?</a>
                </div>
            </form>

            @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
            {
                <div class="demo-accounts">
                    <h3>ДЕМО-АККАУНТЫ ДЛЯ ТЕСТИРОВАНИЯ</h3>
                    <div class="account-item"><span class="role">Администратор</span><span class="credentials">admin / admin123</span></div>
                    <div class="account-item"><span class="role">Менеджер</span><span class="credentials">manager / manager123</span></div>
                    <div class="account-item"><span class="role">Продавец</span><span class="credentials">seller / seller123</span></div>
                </div>
            }
        </div>

        <!-- Форма для клиентов -->
        <div id="customer-form" class="auth-form hidden-form">
            <form class="login-form" method="post" action="/Account/CustomerLogin">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label>Email или телефон</label>
                    <div class="input-icon">
                        <i class="fas fa-envelope"></i>
                        <input type="text" name="login" class="form-control" placeholder="Введите email или номер телефона" autocomplete="email" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Пароль</label>
                    <div class="input-icon password-wrapper">
                        <i class="fas fa-lock"></i>
                        <input type="password" name="password" class="form-control" placeholder="Введите пароль" id="customer-password-field" />
                        <button type="button" class="toggle-password" data-target="customer-password-field" aria-label="Показать/скрыть пароль">
                            <i class="far fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="form-check">
                    <input type="checkbox" name="rememberMe" class="form-check-input" id="customerRememberMe" />
                    <label class="form-check-label" for="customerRememberMe">Запомнить меня</label>
                </div>

                <button type="submit" class="login-btn">ВОЙТИ КАК КЛИЕНТ</button>

                <div class="links-container">
                    <a asp-page="/Account/ForgotPassword" class="forgot-password">Забыли пароль?</a>
                </div>
            </form>

            <div class="customer-info">
                <p>Нет аккаунта? <a asp-page="/Account/CustomerRegister">Зарегистрируйтесь</a></p>
                <p>Для юридических лиц и оптовых закупок используйте форму для сотрудников.</p>
            </div>
        </div>

        <footer class="footer">© 2026 Моноплист</footer>
    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Переключение табов
            const tabButtons = document.querySelectorAll('.auth-tab');
            const employeeForm = document.getElementById('employee-form');
            const customerForm = document.getElementById('customer-form');

            tabButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    const tab = this.getAttribute('data-tab');
                    // Удаляем active у всех
                    tabButtons.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    // Показываем нужную форму
                    if (tab === 'employee') {
                        employeeForm.classList.remove('hidden-form');
                        customerForm.classList.add('hidden-form');
                    } else {
                        employeeForm.classList.add('hidden-form');
                        customerForm.classList.remove('hidden-form');
                    }
                });
            });

            // Переключение видимости пароля (работает для обоих форм)
            const toggleButtons = document.querySelectorAll('.toggle-password');
            toggleButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    const targetId = this.getAttribute('data-target');
                    let passwordField;
                    if (targetId) {
                        passwordField = document.getElementById(targetId);
                    } else {
                        // Для формы сотрудников (поле имеет id="password-field")
                        passwordField = this.closest('.password-wrapper')?.querySelector('input');
                    }
                    if (passwordField) {
                        const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
                        passwordField.setAttribute('type', type);
                        const icon = this.querySelector('i');
                        icon.classList.toggle('fa-eye');
                        icon.classList.toggle('fa-eye-slash');
                    }
                });
            });

            // Эффект фокуса на полях
            const inputs = document.querySelectorAll('.input-icon input');
            inputs.forEach(input => {
                input.addEventListener('focus', () => {
                    input.closest('.input-icon').classList.add('focused');
                });
                input.addEventListener('blur', () => {
                    input.closest('.input-icon').classList.remove('focused');
                });
            });

            // Авто-скрытие алерта
            const alert = document.querySelector('.validation-summary');
            if (alert) {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 500);
                }, 8000);
            }

            // Кнопка закрытия алерта
            const closeBtn = document.querySelector('.alert .btn-close');
            if (closeBtn) {
                closeBtn.addEventListener('click', function() {
                    const alert = this.closest('.alert');
                    alert.style.transition = 'opacity 0.3s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 300);
                });
            }

            // Переключение темы
            const themeToggle = document.getElementById('themeToggle');
            const icon = themeToggle.querySelector('i');
            const body = document.body;

            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            }

            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    icon.classList.remove('fa-sun');
                    icon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    icon.classList.remove('fa-moon');
                    icon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });

            // Прелоадер
            const preloader = document.getElementById('preloader');
            if (preloader) {
                window.addEventListener('load', function() {
                    setTimeout(() => {
                        preloader.style.opacity = '0';
                        preloader.style.visibility = 'hidden';
                    }, 500);
                });
                setTimeout(() => {
                    if (preloader.style.visibility !== 'hidden') {
                        preloader.style.opacity = '0';
                        preloader.style.visibility = 'hidden';
                    }
                }, 3000);
            }
        });
    </script>
</body>
</html>