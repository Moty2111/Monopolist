@page
@model Monoplist.Pages.Customers.DeleteModel
@{
    Layout = null;
    ViewData["Title"] = "Удаление клиента";
    var userName = User.Identity?.Name ?? "Пользователь";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-lg: 0 8px 24px rgba(255,107,0,0.15);
            --shadow-hover: 0 12px 28px rgba(255,215,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --card-color-1: #10b981;
            --card-color-2: #3b82f6;
            --card-color-3: #8b5cf6;
            --card-color-4: #f59e0b;
            --transition: all 0.2s ease;
        }

        /* ===== ТЁМНАЯ ТЕМА ===== */
        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
            --card-color-1: #34d399;
            --card-color-2: #60a5fa;
            --card-color-3: #c084fc;
            --card-color-4: #fbbf24;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        /* ===== САЙДБАР ===== */
        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        /* ===== ОСНОВНОЙ КОНТЕНТ ===== */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

            .user-info span {
                font-weight: 500;
                color: var(--text-secondary);
            }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .btn-logout {
            background: none;
            border: 2px solid var(--accent);
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            color: var(--text-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

            .btn-logout:hover {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-color: transparent;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(255,107,0,0.3);
            }

                .btn-logout:hover i {
                    color: white;
                }

        .content {
            padding: 16px;
            flex: 1;
        }

        /* ===== КОМПОНЕНТЫ ===== */
        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 16px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 6px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 18px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 10px;
        }

        /* ===== СТИЛИ ФОРМ ===== */
        .form-container {
            max-width: 800px;
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

            .form-group label {
                display: block;
                font-weight: 600;
                font-size: 0.9rem;
                color: var(--primary);
                margin-bottom: 5px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            font-size: 1rem;
            border: 2px solid var(--border);
            border-radius: 12px;
            background: var(--surface);
            color: var(--text-primary);
            transition: var(--transition);
            font-family: 'Poppins', sans-serif;
        }

            .form-control:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
            }

        select.form-control {
            appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%23FF6B00' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 1em;
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .btn-primary, .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 22px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
            }

        .btn-secondary {
            background: var(--surface);
            color: var(--text-secondary);
            border: 2px solid var(--border);
        }

            .btn-secondary:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
                transform: translateY(-2px);
            }

        .text-danger {
            color: var(--danger);
            font-size: 0.85rem;
            margin-top: 4px;
            display: block;
        }

        /* ===== АДАПТИВНОСТЬ ===== */
        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                top: 0;
                bottom: 0;
                transform: translateX(-100%);
                box-shadow: none;
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
                box-shadow: 2px 0 15px rgba(0,0,0,0.2);
            }

            .menu-toggle {
                display: block;
            }

            .main-content {
                width: 100%;
            }

            .top-bar {
                padding: 12px 16px;
            }

            .page-title {
                font-size: 1.25rem;
            }

            .user-info span {
                display: none;
            }

            .content {
                padding: 12px;
            }

            .dashboard {
                padding: 12px;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-primary, .btn-secondary {
                width: 100%;
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .btn-logout {
                padding: 8px 12px;
            }
        }
        .delete-confirmation dl {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 12px 20px;
            max-width: 600px;
            margin-bottom: 2rem;
        }

        .delete-confirmation dt {
            font-weight: 700;
            color: var(--primary);
        }

        .delete-confirmation dd {
            margin: 0;
            color: var(--text-secondary);
        }

        .btn-danger {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 22px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            background: var(--danger);
            color: white;
        }

            .btn-danger:hover {
                transform: translateY(-2px);
                filter: brightness(1.1);
                box-shadow: 0 6px 15px rgba(239,68,68,0.4);
            }

        .delete-confirmation form {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        @@media (max-width: 480px) {
            .delete-confirmation form {
                flex-direction: column;
            }

            .btn-danger, .btn-secondary {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="app">
        <!-- Боковое меню -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> Главная панель</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> Каталог товаров</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> Продажи</a></li>
                    <li><a asp-page="/Customers/Index" class="active"><i class="fas fa-users"></i> Клиенты</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> Склад</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> Поставщики</a></li>
                    <li><a asp-page="/Reports/Index"><i class="fas fa-chart-line"></i> Отчеты</a></li>
                    <li><a asp-page="/Settings/Index"><i class="fas fa-cog"></i> Настройки</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <span><i class="fas fa-user-circle"></i> @userName</span>
                    <div class="theme-toggle" id="themeToggle" title="Сменить тему"><i class="fas fa-sun"></i></div>
                    <form method="post" asp-page="/Account/Logout" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout"><i class="fas fa-sign-out-alt"></i> <span>Выйти</span></button>
                    </form>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">Вы уверены, что хотите удалить этого клиента?</p>

                    <div class="delete-confirmation">
                        <dl>
                            <dt>ФИО / Название</dt>
                            <dd>@Model.Customer.FullName</dd>
                            <dt>Телефон</dt>
                            <dd>@Model.Customer.Phone</dd>
                            <dt>Email</dt>
                            <dd>@Model.Customer.Email</dd>
                            <dt>Скидка</dt>
                            <dd>@Model.Customer.Discount%</dd>
                            <dt>Дата регистрации</dt>
                            <dd>@Model.Customer.RegistrationDate.ToString("dd.MM.yyyy")</dd>
                        </dl>

                        <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Customer.Id">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-danger"><i class="fas fa-trash"></i> Удалить</button>
                            <a asp-page="Index" class="btn-secondary"><i class="fas fa-times"></i> Отмена</a>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Тот же скрипт, что в Create
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;
            if (menuToggle) {
                menuToggle.addEventListener('click', () => body.classList.toggle('sidebar-open'));
                document.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(e.target) && !menuToggle.contains(e.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = themeToggle.querySelector('i');
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                themeIcon.classList.remove('fa-sun');
                themeIcon.classList.add('fa-moon');
            }
            themeToggle.addEventListener('click', () => {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });
        });
    </script>
</body>
</html>