@page
@model Monoplist.Pages.Customers.CreateModel
@{
    Layout = null;
    ViewData["Title"] = Model.Language == "ru" ? "Добавление клиента" : (Model.Language == "en" ? "Add customer" : "Клиент қосу");
    var userId = User.FindFirst("UserId")?.Value;
    var avatarUrl = HttpContext.Request.Cookies[$"user_avatar_{userId}"] ?? "";
}

<!DOCTYPE html>
<html lang="@Model.Language">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* Все стили как в предыдущей версии Create.cshtml, плюс добавлены стили для аватара */
        :root {
            --primary: @Model.CustomColor;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --info: #3b82f6;
            --info-bg: #dbeafe;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
            --info-bg: #1e3a5f;
        }

        body.compact-mode .sidebar {
            width: 240px;
        }

        body.compact-mode .sidebar-header {
            padding: 16px 16px;
        }

            body.compact-mode .sidebar-header i {
                font-size: 32px;
            }

            body.compact-mode .sidebar-header h2 {
                font-size: 20px;
            }

        body.compact-mode .sidebar-nav li a {
            padding: 8px 12px;
        }

        body.compact-mode .top-bar {
            padding: 12px 24px;
        }

        body.compact-mode .dashboard {
            padding: 16px;
        }

            body.compact-mode .dashboard h1 {
                font-size: 1.8rem;
            }

        body.compact-mode .subtitle {
            font-size: 0.9rem;
            margin-bottom: 16px;
        }

        body.compact-mode .form-group {
            margin-bottom: 1rem;
        }

        body.compact-mode .form-control {
            padding: 8px 12px;
        }

        body.compact-mode .btn-primary, body.compact-mode .btn-secondary {
            padding: 8px 18px;
        }

        body.no-animations * {
            transition: none !important;
            animation: none !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
            position: relative;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            background: var(--surface-hover);
            border-radius: 40px;
            transition: var(--transition);
            cursor: pointer;
        }

            .user-profile:hover {
                background: var(--surface);
                box-shadow: var(--shadow-sm);
            }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

            .user-avatar i {
                font-size: 40px;
            }

            .user-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .user-details {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .user-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .user-menu {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 220px;
            background: var(--surface);
            border-radius: 12px;
            box-shadow: var(--shadow-hover);
            border: 1px solid var(--border);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.2s ease;
            z-index: 1000;
        }

            .user-menu.show {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
            width: 100%;
            text-align: left;
            border: none;
            background: none;
            font-size: 0.95rem;
            cursor: pointer;
        }

            .menu-item:hover {
                background: var(--surface-hover);
                color: var(--primary);
            }

            .menu-item.logout {
                color: var(--danger);
            }

                .menu-item.logout:hover {
                    background: var(--danger-bg);
                }

        .menu-divider {
            height: 1px;
            background: var(--border);
            margin: 8px 0;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .content {
            padding: 24px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 24px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 2rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 8px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 24px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 12px;
        }

        .alert {
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: var(--success-bg);
            color: var(--success);
            border-left: 4px solid var(--success);
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger);
            border-left: 4px solid var(--danger);
        }

        .form-container {
            max-width: 800px;
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

            .form-group label {
                display: block;
                font-weight: 600;
                font-size: 0.9rem;
                color: var(--primary);
                margin-bottom: 5px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            font-size: 1rem;
            border: 2px solid var(--border);
            border-radius: 12px;
            background: var(--surface);
            color: var(--text-primary);
            transition: var(--transition);
            font-family: 'Poppins', sans-serif;
        }

            .form-control:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
            }

        .form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .btn-primary, .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
            }

        .btn-secondary {
            background: var(--surface);
            color: var(--text-secondary);
            border: 2px solid var(--border);
        }

            .btn-secondary:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
                transform: translateY(-2px);
            }

        .text-danger {
            color: var(--danger);
            font-size: 0.85rem;
            margin-top: 4px;
            display: block;
        }

        /* Стили для аватара */
        .avatar-upload-area {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 15px;
        }

        .avatar-preview {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: var(--surface-hover);
            border: 2px dashed var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

            .avatar-preview img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .avatar-preview i {
                font-size: 48px;
                color: var(--text-muted);
            }

        .avatar-controls {
            flex: 1;
            min-width: 200px;
        }

        .avatar-url-input {
            margin-top: 10px;
        }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                top: 0;
                bottom: 0;
                transform: translateX(-100%);
                box-shadow: none;
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
                box-shadow: 2px 0 15px rgba(0,0,0,0.2);
            }

            .menu-toggle {
                display: block;
            }

            .main-content {
                width: 100%;
            }

            .top-bar {
                padding: 12px 16px;
            }

            .page-title {
                font-size: 1.25rem;
            }

            .user-profile .user-details {
                display: none;
            }

            .content {
                padding: 16px;
            }

            .dashboard {
                padding: 16px;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-primary, .btn-secondary {
                width: 100%;
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .btn-logout {
                padding: 8px 12px;
            }
        }
    </style>
</head>
<body class="@(Model.Theme == "dark" ? "dark-theme" : "") @(Model.CompactMode ? "compact-mode" : "") @(Model.Animations ? "" : "no-animations")">
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> @(Model.Language == "ru" ? "Главная панель" : Model.Language == "en" ? "Dashboard" : "Бас панель")</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> @(Model.Language == "ru" ? "Каталог товаров" : Model.Language == "en" ? "Products" : "Тауарлар каталогы")</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> @(Model.Language == "ru" ? "Продажи" : Model.Language == "en" ? "Orders" : "Сатулар")</a></li>
                    <li><a asp-page="/Customers/Index" class="active"><i class="fas fa-users"></i> @(Model.Language == "ru" ? "Клиенты" : Model.Language == "en" ? "Customers" : "Клиенттер")</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> @(Model.Language == "ru" ? "Склад" : Model.Language == "en" ? "Warehouse" : "Қойма")</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> @(Model.Language == "ru" ? "Поставщики" : Model.Language == "en" ? "Suppliers" : "Жеткізушілер")</a></li>
                    <li><a asp-page="/Reports/Index"><i class="fas fa-chart-line"></i> @(Model.Language == "ru" ? "Отчеты" : Model.Language == "en" ? "Reports" : "Есептер")</a></li>
                    <li><a asp-page="/Settings/Index"><i class="fas fa-cog"></i> @(Model.Language == "ru" ? "Настройки" : Model.Language == "en" ? "Settings" : "Баптаулар")</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <div class="theme-toggle" id="themeToggle" title="@(Model.Language == "ru" ? "Сменить тему" : Model.Language == "en" ? "Toggle theme" : "Тақырыпты ауыстыру")"><i class="fas fa-sun"></i></div>
                    <div class="user-profile" onclick="toggleUserMenu()">
                        <div class="user-avatar">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user-circle\'></i>';" />
                            }
                            else
                            {
                                <i class="fas fa-user-circle"></i>
                            }
                        </div>
                        <div class="user-details">
                            <span class="user-name">@User.Identity?.Name</span>
                            <span class="user-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</span>
                        </div>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-menu" id="userMenu">
                        <a asp-page="/Settings/Profile" class="menu-item"><i class="fas fa-user"></i> @(Model.Language == "ru" ? "Профиль" : Model.Language == "en" ? "Profile" : "Профиль")</a>
                        <a asp-page="/Settings/Security" class="menu-item"><i class="fas fa-shield-alt"></i> @(Model.Language == "ru" ? "Безопасность" : Model.Language == "en" ? "Security" : "Қауіпсіздік")</a>
                        <a asp-page="/Settings/Appearance" class="menu-item"><i class="fas fa-palette"></i> @(Model.Language == "ru" ? "Внешний вид" : Model.Language == "en" ? "Appearance" : "Сыртқы түр")</a>
                        <div class="menu-divider"></div>
                        <form method="post" asp-page="/Account/Logout" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="menu-item logout"><i class="fas fa-sign-out-alt"></i> @(Model.Language == "ru" ? "Выйти" : Model.Language == "en" ? "Logout" : "Шығу")</button>
                        </form>
                    </div>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
                    }

                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">@(Model.Language == "ru" ? "Заполните форму" : Model.Language == "en" ? "Fill the form" : "Пішінді толтырыңыз")</p>

                    <div class="form-container">
                        <form method="post" enctype="multipart/form-data">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <!-- Аватар -->
                            <div class="form-group">
                                <label>@(Model.Language == "ru" ? "Аватар" : Model.Language == "en" ? "Avatar" : "Аватар")</label>
                                <div class="avatar-upload-area">
                                    <div class="avatar-preview" id="avatarPreview">
                                        <i class="fas fa-user-circle"></i>
                                    </div>
                                    <div class="avatar-controls">
                                        <input type="file" id="AvatarFile" name="AvatarFile" accept="image/*" class="form-control" style="padding: 8px;" />
                                        <div class="avatar-url-input">
                                            <input type="text" id="AvatarUrlInput" name="Customer.AvatarUrl" class="form-control" placeholder="@(Model.Language == "ru" ? "Или укажите URL аватара" : Model.Language == "en" ? "Or enter avatar URL" : "Немесе аватар сілтемесін енгізіңіз")" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Customer.FullName">@(Model.Language == "ru" ? "ФИО / Название" : Model.Language == "en" ? "Full name" : "Аты-жөні / Атауы")</label>
                                <input asp-for="Customer.FullName" class="form-control" />
                                <span asp-validation-for="Customer.FullName" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Customer.Phone">@(Model.Language == "ru" ? "Телефон" : Model.Language == "en" ? "Phone" : "Телефон")</label>
                                <input asp-for="Customer.Phone" class="form-control" />
                                <span asp-validation-for="Customer.Phone" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Customer.Email">Email</label>
                                <input asp-for="Customer.Email" class="form-control" />
                                <span asp-validation-for="Customer.Email" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Customer.Password">@(Model.Language == "ru" ? "Пароль" : Model.Language == "en" ? "Password" : "Құпиясөз")</label>
                                <input asp-for="Customer.Password" class="form-control" type="password" />
                                <span asp-validation-for="Customer.Password" class="text-danger"></span>
                                <div class="input-hint" style="font-size:0.85rem; color: var(--text-muted); margin-top:4px;">
                                    @(Model.Language == "ru" ? "Минимум 4 символа. Если оставить пустым, будет сгенерирован автоматически." : Model.Language == "en" ? "Minimum 4 characters. If empty, a password will be generated." : "Кемінде 4 таңба. Бос қалдырсаңыз, құпиясөз автоматты түрде жасалады.")
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Customer.Discount">@(Model.Language == "ru" ? "Скидка (%)" : Model.Language == "en" ? "Discount (%)" : "Жеңілдік (%)")</label>
                                <input asp-for="Customer.Discount" class="form-control" type="number" step="1" min="0" max="100" />
                                <span asp-validation-for="Customer.Discount" class="text-danger"></span>
                                <div class="input-hint" style="font-size:0.85rem; color: var(--text-muted); margin-top:4px;">
                                    @(Model.Language == "ru" ? "Целое число от 0 до 100" : Model.Language == "en" ? "Integer from 0 to 100" : "0-ден 100-ге дейінгі бүтін сан")
                                </div>
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn-primary"><i class="fas fa-save"></i> @(Model.Language == "ru" ? "Сохранить" : Model.Language == "en" ? "Save" : "Сақтау")</button>
                                <a asp-page="Index" class="btn-secondary"><i class="fas fa-times"></i> @(Model.Language == "ru" ? "Отмена" : Model.Language == "en" ? "Cancel" : "Бас тарту")</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;
            if (menuToggle) {
                menuToggle.addEventListener('click', function() { body.classList.toggle('sidebar-open'); });
                document.addEventListener('click', function(event) {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(event.target) && !menuToggle.contains(event.target) && body.classList.contains('sidebar-open'))
                            body.classList.remove('sidebar-open');
                    }
                });
            }
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = themeToggle.querySelector('i');
            const savedTheme = localStorage.getItem('theme') || '@Model.Theme';
            if (savedTheme === 'dark') { body.classList.add('dark-theme'); themeIcon.classList.remove('fa-sun'); themeIcon.classList.add('fa-moon'); }
            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    themeIcon.classList.remove('fa-sun'); themeIcon.classList.add('fa-moon'); localStorage.setItem('theme', 'dark');
                } else {
                    themeIcon.classList.remove('fa-moon'); themeIcon.classList.add('fa-sun'); localStorage.setItem('theme', 'light');
                }
            });
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => { setTimeout(() => { alert.style.transition = 'opacity 0.5s'; alert.style.opacity = '0'; setTimeout(() => alert.style.display = 'none', 500); }, 5000); });

            // Предпросмотр аватара
            const avatarFile = document.getElementById('AvatarFile');
            const avatarUrlInput = document.getElementById('AvatarUrlInput');
            const preview = document.getElementById('avatarPreview');

            function updatePreview(src) {
                if (src) {
                    preview.innerHTML = `<img src="${src}" alt="Avatar" onerror="this.onerror=null; this.parentElement.innerHTML='<i class=\'fas fa-user-circle\'></i>';" />`;
                } else {
                    preview.innerHTML = '<i class="fas fa-user-circle"></i>';
                }
            }

            avatarFile.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        updatePreview(e.target.result);
                        avatarUrlInput.value = '';
                    };
                    reader.readAsDataURL(file);
                } else {
                    updatePreview(null);
                }
            });

            avatarUrlInput.addEventListener('input', function() {
                const url = this.value.trim();
                if (url) {
                    updatePreview(url);
                    avatarFile.value = '';
                } else {
                    if (!avatarFile.files.length) {
                        updatePreview(null);
                    }
                }
            });
        });
        function toggleUserMenu() { document.getElementById('userMenu').classList.toggle('show'); }
        window.addEventListener('click', function(event) {
            const userInfo = document.querySelector('.user-info');
            const userMenu = document.getElementById('userMenu');
            if (!userInfo.contains(event.target) && userMenu.classList.contains('show')) userMenu.classList.remove('show');
        });
    </script>
</body>
</html>