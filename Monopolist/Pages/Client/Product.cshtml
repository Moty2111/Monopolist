@page "{id}"
@model Monoplist.Pages.Client.ProductModel
@{
    Layout = null;
    ViewData["Title"] = $"{Model.Product.Name} | Моноплист";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* Используем те же стили, что и на главной, с небольшими дополнениями для детальной страницы */
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --bg: #f8f9fc;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.05);
            --radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body.dark {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-hover: #334155;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --text-muted: #94a3b8;
            --border: #334155;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            transition: background 0.3s, color 0.3s;
            min-height: 100vh;
        }

        .gear {
            position: fixed;
            font-size: 6rem;
            color: rgba(255,107,0,0.08);
            z-index: -2;
            animation: spin 30s linear infinite;
            pointer-events: none;
        }

        body.dark .gear {
            color: rgba(255,107,0,0.25);
        }

        .gear1 {
            top: 5%;
            left: 2%;
            animation-duration: 40s;
        }

        .gear2 {
            bottom: 10%;
            right: 3%;
            animation-duration: 35s;
            animation-direction: reverse;
            font-size: 8rem;
        }

        .gear3 {
            top: 30%;
            right: 5%;
            animation-duration: 45s;
            font-size: 5rem;
        }

        .gear4 {
            bottom: 30%;
            left: 5%;
            animation-duration: 50s;
            animation-direction: reverse;
            font-size: 7rem;
        }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        /* Шапка (такая же, как на главной) */
        .header {
            background: rgba(var(--surface-rgb), 0.95);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid var(--border);
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 28px;
            flex-wrap: nowrap;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-decoration: none;
        }

            .logo i {
                font-size: 30px;
            }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-link {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .nav-link:hover {
                color: var(--primary);
            }

        .user-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--border);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--text-secondary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                border-color: var(--primary);
                color: var(--primary);
                transform: rotate(15deg);
            }

        .cart-icon {
            position: relative;
            font-size: 24px;
            color: var(--text-secondary);
            transition: var(--transition);
            text-decoration: none;
        }

            .cart-icon:hover {
                color: var(--primary);
                transform: scale(1.05);
            }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -12px;
            background: var(--primary);
            color: white;
            font-size: 11px;
            font-weight: 600;
            border-radius: 20px;
            padding: 2px 6px;
            min-width: 18px;
            text-align: center;
        }

        .customer-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--surface-hover);
            padding: 8px 16px;
            border-radius: 40px;
            border: 1px solid var(--border);
        }

        .customer-name {
            font-weight: 500;
            font-size: 15px;
            color: var(--text-primary);
        }

        .logout-btn {
            background: none;
            border: none;
            font-size: 20px;
            color: var(--text-muted);
            cursor: pointer;
        }

            .logout-btn:hover {
                color: var(--primary);
            }

        /* Основной контент */
        .main {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 20px;
        }

        .product-detail {
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            overflow: hidden;
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
            padding: 2rem;
            box-shadow: var(--shadow);
        }

        .product-image {
            flex: 1;
            min-width: 250px;
            background: var(--surface-hover);
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

            .product-image img {
                max-width: 100%;
                height: auto;
                border-radius: var(--radius);
            }

            .product-image i {
                font-size: 8rem;
                color: var(--primary-light);
            }

        .product-info {
            flex: 2;
        }

            .product-info h1 {
                font-size: 2rem;
                font-weight: 700;
                margin-bottom: 0.5rem;
                background: linear-gradient(135deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
            }

        .product-meta {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin: 1rem 0;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

            .product-meta span i {
                margin-right: 0.3rem;
                color: var(--primary);
            }

        .price {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
            margin: 1rem 0;
        }

            .price small {
                font-size: 1rem;
                font-weight: 400;
                color: var(--text-muted);
            }

        .stock {
            display: inline-block;
            background: #10b981;
            color: white;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .description {
            margin: 1rem 0;
            line-height: 1.6;
            color: var(--text-secondary);
        }

        .supplier {
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        .add-to-cart-btn {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            padding: 12px 28px;
            border-radius: 40px;
            color: white;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .add-to-cart-btn:hover {
                transform: translateY(-2px);
                background: linear-gradient(135deg, var(--primary-dark), var(--primary));
            }

        .back-link {
            display: inline-block;
            margin-top: 1rem;
            color: var(--primary);
            text-decoration: none;
        }

            .back-link:hover {
                text-decoration: underline;
            }

        /* Футер */
        .footer {
            background: var(--surface);
            border-top: 1px solid var(--border);
            margin-top: 48px;
            padding: 24px;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
        }

            .footer a {
                color: var(--primary);
                text-decoration: none;
            }

        @@media (max-width: 1024px) {
            .header-container {
                flex-wrap: wrap;
                justify-content: center;
            }

            .nav-links {
                order: 3;
                width: 100%;
                justify-content: center;
                margin-top: 12px;
                gap: 20px;
            }
        }

        @@media (max-width: 768px) {
            .header-container {
                padding: 12px 16px;
            }

            .logo {
                font-size: 22px;
            }

                .logo i {
                    font-size: 26px;
                }

            .nav-link {
                font-size: 14px;
            }

            .theme-toggle {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }

            .customer-badge {
                padding: 6px 12px;
            }

            .customer-name {
                font-size: 13px;
            }

            .main {
                padding: 0 16px;
                margin: 1rem auto;
            }

            .product-detail {
                flex-direction: column;
                padding: 1rem;
            }

            .product-info h1 {
                font-size: 1.5rem;
            }

            .price {
                font-size: 1.5rem;
            }
        }

        @@media (max-width: 480px) {
            .customer-name {
                display: none;
            }

            .nav-links {
                gap: 12px;
                font-size: 12px;
            }

            .nav-link i {
                display: none;
            }
        }
    </style>
</head>
<body>
    <!-- Шестерёнки -->
    <div class="gear gear1"><i class="fas fa-cog"></i></div>
    <div class="gear gear2"><i class="fas fa-cog"></i></div>
    <div class="gear gear3"><i class="fas fa-cog"></i></div>
    <div class="gear gear4"><i class="fas fa-cog"></i></div>

    <header class="header">
        <div class="header-container">
            <a href="/Client/Index" class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </a>
            <div class="nav-links">
                <a href="/Client/Index" class="nav-link"><i class="fas fa-home"></i> Главная</a>
                <a href="/Client/Index" class="nav-link"><i class="fas fa-box"></i> Каталог</a>
                <a href="/Client/Index" class="nav-link"><i class="fas fa-heart"></i> Избранное</a>
                <a href="/Client/Index" class="nav-link"><i class="fas fa-shopping-cart"></i> Корзина</a>
                <a href="/Client/Index" class="nav-link"><i class="fas fa-user"></i> Профиль</a>
            </div>
            <div class="user-actions">
                <button class="theme-toggle" id="themeToggle"><i class="fas fa-moon"></i></button>
                <a href="/Client/Index" class="cart-icon" id="cartIcon">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count" id="cartCount">0</span>
                </a>
                <div class="customer-badge">
                    <i class="fas fa-user-circle"></i>
                    <span class="customer-name">@Model.CustomerName</span>
                    <form method="post" asp-page="/Account/CustomerLogout">
                        <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i></button>
                    </form>
                </div>
            </div>
        </div>
    </header>

    <main class="main">
        <div class="product-detail">
            <div class="product-image">
                @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
                {
                    <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name">
                }
                else
                {
                    <i class="fas fa-box-open"></i>
                }
            </div>
            <div class="product-info">
                <h1>@Model.Product.Name</h1>
                <div class="product-meta">
                    <span><i class="fas fa-tag"></i> @Model.Product.CategoryName</span>
                    <span><i class="fas fa-barcode"></i> Артикул: @(Model.Product.Article ?? "—")</span>
                    <span><i class="fas fa-ruler"></i> Ед. изм.: @Model.Product.Unit</span>
                </div>
                <div class="stock">
                    @if (Model.Product.CurrentStock > 0)
                    {
                        <span><i class="fas fa-check-circle"></i> В наличии: @Model.Product.CurrentStock @Model.Product.Unit</span>
                    }
                    else
                    {
                        <span style="background:#ef4444;"><i class="fas fa-times-circle"></i> Нет в наличии</span>
                    }
                </div>
                <div class="price">
                    @Model.Product.SalePrice.ToString("N0") <small>₽ / @Model.Product.Unit</small>
                </div>
                <div class="description">
                    @Model.Product.Description
                </div>
                <div class="supplier">
                    <i class="fas fa-truck"></i> Поставщик: @Model.Product.SupplierName
                </div>
                <button class="add-to-cart-btn" data-product-id="@Model.Product.Id" data-product-name="@Model.Product.Name" data-product-price="@Model.Product.SalePrice">
                    <i class="fas fa-shopping-cart"></i> В корзину
                </button>
                <div>
                    <a href="/Client/Index" class="back-link"><i class="fas fa-arrow-left"></i> Назад к товарам</a>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <p>© 2026 Моноплист — строительные материалы с доставкой</p>
        <p><a href="/Client/About">О компании</a> | <a href="/Client/Contacts">Контакты</a> | <a href="/Client/Delivery">Доставка и оплата</a></p>
    </footer>

    <script>
        // Тёмная тема
        const themeToggle = document.getElementById('themeToggle');
        const icon = themeToggle.querySelector('i');
        const savedTheme = localStorage.getItem('clientTheme');
        if (savedTheme === 'dark') {
            document.body.classList.add('dark');
            icon.classList.remove('fa-moon');
            icon.classList.add('fa-sun');
        }
        themeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark');
            if (document.body.classList.contains('dark')) {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
                localStorage.setItem('clientTheme', 'dark');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
                localStorage.setItem('clientTheme', 'light');
            }
        });

        // Корзина (такая же, как на главной)
        let cart = JSON.parse(localStorage.getItem('cart')) || [];

        function updateCartCount() {
            const count = cart.reduce((sum, item) => sum + item.quantity, 0);
            const cartCountSpan = document.getElementById('cartCount');
            if (count === 0) cartCountSpan.style.display = 'none';
            else { cartCountSpan.style.display = 'inline-block'; cartCountSpan.innerText = count; }
        }

        function addToCart(productId, productName, price, btnElement) {
            const existing = cart.find(item => item.id === productId);
            if (existing) existing.quantity++;
            else cart.push({ id: productId, name: productName, price: parseFloat(price), quantity: 1 });
            localStorage.setItem('cart', JSON.stringify(cart));
            updateCartCount();

            const rect = btnElement.getBoundingClientRect();
            const cartIcon = document.getElementById('cartIcon');
            const cartRect = cartIcon.getBoundingClientRect();
            const flyer = document.createElement('div');
            flyer.className = 'fly-to-cart';
            flyer.style.position = 'fixed';
            flyer.style.width = '30px';
            flyer.style.height = '30px';
            flyer.style.background = 'var(--primary)';
            flyer.style.borderRadius = '50%';
            flyer.style.left = rect.left + rect.width/2 + 'px';
            flyer.style.top = rect.top + rect.height/2 + 'px';
            flyer.style.transition = 'all 0.5s cubic-bezier(0.2, 0.9, 0.4, 1.1)';
            flyer.style.pointerEvents = 'none';
            flyer.style.opacity = '0.8';
            document.body.appendChild(flyer);
            const deltaX = cartRect.left + cartRect.width/2 - (rect.left + rect.width/2);
            const deltaY = cartRect.top + cartRect.height/2 - (rect.top + rect.height/2);
            flyer.style.transform = `translate(${deltaX}px, ${deltaY}px) scale(0.2)`;
            flyer.style.opacity = '0';
            setTimeout(() => flyer.remove(), 500);
            cartIcon.style.transform = 'scale(1.2)';
            setTimeout(() => cartIcon.style.transform = '', 200);
            const originalText = btnElement.innerHTML;
            btnElement.innerHTML = '<i class="fas fa-check"></i> В корзине';
            setTimeout(() => btnElement.innerHTML = originalText, 1000);
        }

        document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const id = btn.getAttribute('data-product-id');
                const name = btn.getAttribute('data-product-name');
                const price = btn.getAttribute('data-product-price');
                addToCart(id, name, price, btn);
            });
        });

        updateCartCount();
    </script>
</body>
</html>