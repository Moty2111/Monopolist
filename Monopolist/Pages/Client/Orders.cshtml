@page
@model Monoplist.Pages.Client.OrdersModel
@{
    Layout = null;
    ViewData["Title"] = "Мои заказы";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ========== БАЗОВЫЕ ПЕРЕМЕННЫЕ (как на главной) ========== */
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --bg: #f8f9fc;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.05);
            --shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.1);
            --radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body.dark {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-hover: #334155;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --text-muted: #94a3b8;
            --border: #334155;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.2);
            --shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.3);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background 0.3s, color 0.3s;
            position: relative;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Шестерёнки (копия из Index) */
        .gear {
            position: fixed;
            font-size: 6rem;
            color: rgba(255,107,0,0.08);
            z-index: -2;
            animation: spin 30s linear infinite;
            pointer-events: none;
        }

        body.dark .gear {
            color: rgba(255,107,0,0.25);
        }

        .gear1 {
            top: 5%;
            left: 2%;
            animation-duration: 40s;
        }

        .gear2 {
            bottom: 10%;
            right: 3%;
            animation-duration: 35s;
            animation-direction: reverse;
            font-size: 8rem;
        }

        .gear3 {
            top: 30%;
            right: 5%;
            animation-duration: 45s;
            font-size: 5rem;
        }

        .gear4 {
            bottom: 30%;
            left: 5%;
            animation-duration: 50s;
            animation-direction: reverse;
            font-size: 7rem;
        }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        /* Шапка (копия из Index) */
        .header {
            background: rgba(var(--surface-rgb), 0.95);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid var(--border);
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 28px;
            flex-wrap: nowrap;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-decoration: none;
        }

            .logo i {
                font-size: 30px;
            }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-link {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .nav-link:hover {
                color: var(--primary);
            }

        .user-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--border);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--text-secondary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                border-color: var(--primary);
                color: var(--primary);
                transform: rotate(15deg);
            }

        .cart-icon {
            position: relative;
            font-size: 24px;
            color: var(--text-secondary);
            transition: var(--transition);
            text-decoration: none;
        }

            .cart-icon:hover {
                color: var(--primary);
                transform: scale(1.05);
            }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -12px;
            background: var(--primary);
            color: white;
            font-size: 11px;
            font-weight: 600;
            border-radius: 20px;
            padding: 2px 6px;
            min-width: 18px;
            text-align: center;
        }

        .customer-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--surface-hover);
            padding: 8px 16px;
            border-radius: 40px;
            border: 1px solid var(--border);
        }

        .customer-name {
            font-weight: 500;
            font-size: 15px;
            color: var(--text-primary);
        }

        .logout-btn {
            background: none;
            border: none;
            font-size: 20px;
            color: var(--text-muted);
            cursor: pointer;
        }

            .logout-btn:hover {
                color: var(--primary);
            }

        /* Основной контент */
        .main {
            max-width: 1400px;
            margin: 0 auto;
            padding: 32px;
        }

        .welcome {
            margin-bottom: 32px;
            text-align: center;
        }

            .welcome h1 {
                font-size: 42px;
                font-weight: 800;
                background: linear-gradient(135deg, var(--primary), var(--accent), var(--primary-light));
                background-size: 200% auto;
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                animation: gradientShift 6s infinite linear;
            }

        @@keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .welcome p {
            color: var(--text-muted);
            margin-top: 8px;
            font-size: 18px;
        }

        /* Панель фильтров */
        .filters-bar {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 20px 24px;
            margin-bottom: 32px;
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            align-items: flex-end;
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
        }

        .filter-group {
            flex: 1;
            min-width: 160px;
        }

            .filter-group label {
                display: block;
                font-size: 12px;
                font-weight: 600;
                text-transform: uppercase;
                color: var(--text-muted);
                margin-bottom: 6px;
                letter-spacing: 0.5px;
            }

            .filter-group select, .filter-group input {
                width: 100%;
                padding: 10px 12px;
                border: 2px solid var(--border);
                border-radius: 12px;
                background: var(--surface);
                color: var(--text-primary);
                font-family: inherit;
                font-size: 14px;
                transition: var(--transition);
            }

                .filter-group select:focus, .filter-group input:focus {
                    outline: none;
                    border-color: var(--primary);
                }

        .reset-filters {
            background: none;
            border: 2px solid var(--border);
            border-radius: 12px;
            padding: 10px 20px;
            font-weight: 600;
            color: var(--text-secondary);
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
            text-decoration: none;
        }

            .reset-filters:hover {
                border-color: var(--primary);
                color: var(--primary);
                transform: translateY(-2px);
            }

        /* Стили для списка заказов */
        .orders-list {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .order-card {
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            overflow: hidden;
            transition: var(--transition);
            box-shadow: var(--shadow);
        }

            .order-card:hover {
                transform: translateY(-2px);
                box-shadow: var(--shadow-hover);
            }

        .order-header {
            padding: 20px 24px;
            background: var(--surface-hover);
            border-bottom: 1px solid var(--border);
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        .order-number {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .order-date {
            color: var(--text-muted);
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .order-status {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            background: #f1f5f9;
            color: #334155;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .order-status.completed {
                background: #d1fae5;
                color: #065f46;
            }

            .order-status.pending {
                background: #fed7aa;
                color: #9a3412;
            }

            .order-status.cancelled {
                background: #fee2e2;
                color: #991b1b;
            }

        .order-total {
            font-weight: 700;
            font-size: 18px;
            color: var(--primary);
        }

        .order-items {
            padding: 0 24px;
            background: var(--surface);
        }

            .order-items table {
                width: 100%;
                border-collapse: collapse;
                font-size: 14px;
            }

            .order-items th {
                text-align: left;
                padding: 12px 8px;
                border-bottom: 1px solid var(--border);
                color: var(--text-muted);
                font-weight: 600;
            }

            .order-items td {
                padding: 12px 8px;
                border-bottom: 1px solid var(--border);
                color: var(--text-secondary);
            }

        .order-footer {
            padding: 12px 24px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        .payment-method {
            font-size: 13px;
            color: var(--text-muted);
        }

        .reorder-btn {
            background: none;
            border: 2px solid var(--border);
            border-radius: 30px;
            padding: 6px 16px;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .reorder-btn:hover {
                border-color: var(--primary);
                color: var(--primary);
                transform: translateY(-1px);
            }

        /* Пагинация */
        .pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 40px;
            flex-wrap: wrap;
        }

            .pagination a, .pagination span {
                display: inline-block;
                padding: 8px 14px;
                border: 1px solid var(--border);
                border-radius: 8px;
                background: var(--surface);
                color: var(--text-primary);
                text-decoration: none;
                transition: var(--transition);
                font-weight: 500;
            }

                .pagination a:hover {
                    background: var(--primary);
                    color: white;
                    border-color: var(--primary);
                }

            .pagination .active {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

            .pagination .disabled {
                opacity: 0.5;
                pointer-events: none;
            }

        /* Пустое состояние */
        .empty-orders {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

            .empty-orders i {
                font-size: 80px;
                margin-bottom: 20px;
                opacity: 0.5;
            }

        /* Футер */
        .footer {
            background: var(--surface);
            border-top: 1px solid var(--border);
            margin-top: 48px;
            padding: 24px;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
        }

            .footer a {
                color: var(--primary);
                text-decoration: none;
            }

        /* Адаптивность */
        @@media (max-width: 1024px) {
            .header-container {
                flex-wrap: wrap;
                justify-content: center;
            }

            .nav-links {
                order: 3;
                width: 100%;
                justify-content: center;
                margin-top: 12px;
                gap: 20px;
            }

            .filters-bar {
                flex-direction: column;
                align-items: stretch;
            }

            .reset-filters {
                align-self: flex-start;
            }
        }

        @@media (max-width: 768px) {
            .header-container {
                padding: 12px 16px;
            }

            .logo {
                font-size: 22px;
            }

                .logo i {
                    font-size: 26px;
                }

            .nav-link {
                font-size: 14px;
            }

            .theme-toggle {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }

            .customer-badge {
                padding: 6px 12px;
            }

            .customer-name {
                font-size: 13px;
            }

            .main {
                padding: 16px;
            }

            .order-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .order-footer {
                flex-direction: column;
                align-items: flex-start;
            }

            .order-items {
                overflow-x: auto;
            }
        }

        @@media (max-width: 480px) {
            .customer-name {
                display: none;
            }

            .nav-links {
                gap: 12px;
                font-size: 12px;
            }

            .nav-link i {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="gear gear1"><i class="fas fa-cog"></i></div>
    <div class="gear gear2"><i class="fas fa-cog"></i></div>
    <div class="gear gear3"><i class="fas fa-cog"></i></div>
    <div class="gear gear4"><i class="fas fa-cog"></i></div>

    <header class="header">
        <div class="header-container">
            <a href="/Client/Index" class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </a>
            <div class="nav-links">
                <a href="/Client/Index" class="nav-link"><i class="fas fa-home"></i> Главная</a>
                <a href="/Client/Orders" class="nav-link active"><i class="fas fa-truck"></i> Заказы</a>
                <a href="/Client/Favorites" class="nav-link"><i class="fas fa-heart"></i> Избранное</a>
                <a href="/Client/Cart" class="nav-link"><i class="fas fa-shopping-cart"></i> Корзина</a>
                <a href="/Client/Profile" class="nav-link"><i class="fas fa-user"></i> Профиль</a>
            </div>
            <div class="user-actions">
                <button class="theme-toggle" id="themeToggle"><i class="fas fa-moon"></i></button>
                <a href="/Client/Cart" class="cart-icon" id="cartIcon">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count" id="cartCount">0</span>
                </a>
                <div class="customer-badge">
                    <i class="fas fa-user-circle"></i>
                    <span class="customer-name">@Model.CustomerName</span>
                    <form method="post" asp-page="/Account/CustomerLogout">
                        <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i></button>
                    </form>
                </div>
            </div>
        </div>
    </header>

    <main class="main">
        <div class="welcome">
            <h1>Мои заказы</h1>
            <p>История ваших покупок</p>
        </div>

        <!-- Форма фильтров -->
        <form method="get" class="filters-bar">
            <div class="filter-group">
                <label><i class="fas fa-filter"></i> Статус</label>
                <select name="statusFilter" onchange="this.form.submit()">
                    <option value="All" selected="@(Model.StatusFilter == null || Model.StatusFilter == "All")">Все</option>
                    <option value="Completed" selected="@(Model.StatusFilter == "Completed")">Выполненные</option>
                    <option value="Pending" selected="@(Model.StatusFilter == "Pending")">В обработке</option>
                    <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled")">Отменённые</option>
                </select>
            </div>
            <div class="filter-group">
                <label><i class="fas fa-calendar-alt"></i> Дата от</label>
                <input type="date" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" onchange="this.form.submit()">
            </div>
            <div class="filter-group">
                <label><i class="fas fa-calendar-alt"></i> Дата до</label>
                <input type="date" name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" onchange="this.form.submit()">
            </div>
            @if (!string.IsNullOrEmpty(Model.StatusFilter) || Model.DateFrom.HasValue || Model.DateTo.HasValue)
            {
                <a href="/Client/Orders" class="reset-filters"><i class="fas fa-times"></i> Сбросить</a>
            }
        </form>

        @if (Model.Orders.Any())
        {
            <div class="orders-list">
                @foreach (var order in Model.Orders)
                {
                    <div class="order-card">
                        <div class="order-header">
                            <div class="order-number">
                                <i class="fas fa-receipt"></i> Заказ № @order.OrderNumber
                                <span class="order-date"><i class="far fa-calendar-alt"></i> @order.OrderDate.ToString("dd.MM.yyyy")</span>
                            </div>
                            <div>
                                <span class="order-status @(order.Status.ToLower())">
                                    @if (order.Status == "Completed")
                                    {
                                        <i class="fas fa-check-circle"></i>
                                    }
                                    else if (order.Status == "Pending")
                                    {

                                        <i class="fas fa-clock"></i>
                                    }
                                    else
                                    {

                                        <i class="fas fa-times-circle"></i>
                                    }
                                    @(order.Status switch { "Completed" => "Выполнен", "Pending" => "Ожидание", "Cancelled" => "Отменён", _ => order.Status })
                                </span>
                                <span class="order-total">@order.TotalAmount.ToString("N0") ₽</span>
                            </div>
                        </div>
                        @if (order.Items.Any())
                        {
                            <div class="order-items">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Товар</th>
                                            <th>Кол-во</th>
                                            <th>Цена</th>
                                            <th>Сумма</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in order.Items)
                                        {
                                            <tr>
                                                <td>@item.ProductName</td>
                                                <td>@item.Quantity @item.Unit</td>
                                                <td>@item.Price.ToString("N0") ₽</td>
                                                <td>@item.Total.ToString("N0") ₽</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        <div class="order-footer">
                            <div class="payment-method">
                                <i class="fas fa-credit-card"></i> @(order.PaymentMethod switch { "Card" => "Оплата картой", "Cash" => "Наличными", "Credit" => "Кредит/Рассрочка", _ => order.PaymentMethod ?? "Способ не указан" })
                            </div>
                            <button class="reorder-btn" data-order-id="@order.Id">
                                <i class="fas fa-redo-alt"></i> Повторить заказ
                            </button>
                        </div>
                    </div>
                }
            </div>

            <!-- Пагинация -->
            @if (Model.TotalPages > 1)
            {
                <div class="pagination">
                    @if (Model.PageNumber > 1)
                    {
                        <a href="?pageNumber=@(Model.PageNumber - 1)&statusFilter=@Model.StatusFilter&dateFrom=@Model.DateFrom&dateTo=@Model.DateTo"><i class="fas fa-chevron-left"></i> Назад</a>
                    }
                    else
                    {
                        <span class="disabled"><i class="fas fa-chevron-left"></i> Назад</span>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.PageNumber)
                        {
                            <span class="active">@i</span>
                        }
                        else
                        {
                            <a href="?pageNumber=@i&statusFilter=@Model.StatusFilter&dateFrom=@Model.DateFrom&dateTo=@Model.DateTo">@i</a>
                        }
                    }

                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a href="?pageNumber=@(Model.PageNumber + 1)&statusFilter=@Model.StatusFilter&dateFrom=@Model.DateFrom&dateTo=@Model.DateTo">Вперёд <i class="fas fa-chevron-right"></i></a>
                    }
                    else
                    {
                        <span class="disabled">Вперёд <i class="fas fa-chevron-right"></i></span>
                    }
                </div>
            }
        }
        else
        {
            <div class="empty-orders">
                <i class="fas fa-box-open"></i>
                <p>У вас пока нет заказов</p>
                <p style="font-size: 14px; margin-top: 8px;">Перейдите в <a href="/Client/Index" style="color: var(--primary);">каталог</a> и сделайте первый заказ</p>
            </div>
        }
    </main>

    <footer class="footer">
        <p>© 2026 Моноплист — строительные материалы с доставкой</p>
        <p><a href="/Client/About">О компании</a> | <a href="/Client/Contacts">Контакты</a> | <a href="/Client/Delivery">Доставка и оплата</a></p>
    </footer>

    <script>
        // Тёмная тема
        const themeToggle = document.getElementById('themeToggle');
        const icon = themeToggle.querySelector('i');
        const savedTheme = localStorage.getItem('clientTheme');

        if (savedTheme === 'dark') {
            document.body.classList.add('dark');
            icon.classList.remove('fa-moon');
            icon.classList.add('fa-sun');
        }

        themeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark');
            if (document.body.classList.contains('dark')) {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
                localStorage.setItem('clientTheme', 'dark');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
                localStorage.setItem('clientTheme', 'light');
            }
        });

        // Функция обновления счётчика корзины (из серверной корзины)
        async function updateCartCount() {
            try {
                const response = await fetch('/Client/Cart?handler=Count', {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                const data = await response.json();
                const countSpan = document.getElementById('cartCount');
                if (data.count > 0) {
                    countSpan.style.display = 'inline-block';
                    countSpan.innerText = data.count;
                } else {
                    countSpan.style.display = 'none';
                }
            } catch (error) {
                console.error('Ошибка получения количества товаров', error);
            }
        }

        // Функция добавления товара в корзину (через сервер)
        async function addToCart(productId, productName, price, quantity = 1) {
            const formData = new FormData();
            formData.append('productId', productId);
            formData.append('quantity', quantity);
            try {
                const response = await fetch('/Client/Cart?handler=Add', {
                    method: 'POST',
                    body: formData
                });
                if (response.ok) {
                    showNotification(`${productName} добавлен в корзину!`, 'success');
                    updateCartCount();
                } else {
                    showNotification('Ошибка добавления в корзину', 'error');
                }
            } catch (error) {
                console.error('Ошибка добавления в корзину', error);
                showNotification('Ошибка добавления в корзину', 'error');
            }
        }

        function showNotification(message, type = 'info') {
            const notif = document.createElement('div');
            notif.className = 'alert';
            notif.style.position = 'fixed';
            notif.style.bottom = '20px';
            notif.style.right = '20px';
            notif.style.maxWidth = '300px';
            notif.style.zIndex = '1000';
            notif.style.background = type === 'success' ? 'linear-gradient(135deg, #10b981, #059669)' : 'linear-gradient(135deg, #f59e0b, #d97706)';
            notif.style.color = 'white';
            notif.style.padding = '12px 20px';
            notif.style.borderRadius = '12px';
            notif.style.fontWeight = '600';
            notif.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-info-circle'}"></i> ${message}`;
            document.body.appendChild(notif);
            setTimeout(() => {
                notif.style.transition = 'opacity 0.5s';
                notif.style.opacity = '0';
                setTimeout(() => notif.remove(), 500);
            }, 2000);
        }

        // Обработчик повторного заказа
        document.querySelectorAll('.reorder-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const orderId = btn.getAttribute('data-order-id');
                try {
                    const response = await fetch(`/Client/Orders?handler=Reorder&orderId=${orderId}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });
                    const items = await response.json();
                    if (items && items.length) {
                        for (const item of items) {
                            await addToCart(item.productId, item.productName, item.price, item.quantity);
                        }
                        showNotification('Товары добавлены в корзину', 'success');
                    } else {
                        showNotification('Не удалось повторить заказ', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    showNotification('Ошибка при повторении заказа', 'error');
                }
            });
        });

        // Инициализация счётчика корзины
        updateCartCount();
    </script>
</body>
</html>