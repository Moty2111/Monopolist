@page
@model Monoplist.Pages.Client.ProfileModel
@{
    Layout = null;
    ViewData["Title"] = "Мой профиль";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ========== БАЗОВЫЕ ПЕРЕМЕННЫЕ ========== */
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --bg: #f8f9fc;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.05);
            --shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.1);
            --radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body.dark {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-hover: #334155;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --text-muted: #94a3b8;
            --border: #334155;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.2);
            --shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.3);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background 0.3s, color 0.3s;
            position: relative;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Шестерёнки */
        .gear {
            position: fixed;
            font-size: 6rem;
            color: rgba(255,107,0,0.08);
            z-index: -2;
            animation: spin 30s linear infinite;
            pointer-events: none;
        }

        body.dark .gear {
            color: rgba(255,107,0,0.25);
        }

        .gear1 {
            top: 5%;
            left: 2%;
            animation-duration: 40s;
        }

        .gear2 {
            bottom: 10%;
            right: 3%;
            animation-duration: 35s;
            animation-direction: reverse;
            font-size: 8rem;
        }

        .gear3 {
            top: 30%;
            right: 5%;
            animation-duration: 45s;
            font-size: 5rem;
        }

        .gear4 {
            bottom: 30%;
            left: 5%;
            animation-duration: 50s;
            animation-direction: reverse;
            font-size: 7rem;
        }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        /* Шапка */
        .header {
            background: rgba(var(--surface-rgb), 0.95);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid var(--border);
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 28px;
            flex-wrap: nowrap;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-decoration: none;
        }

            .logo i {
                font-size: 30px;
            }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-link {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .nav-link:hover {
                color: var(--primary);
            }

        .user-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--border);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--text-secondary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                border-color: var(--primary);
                color: var(--primary);
                transform: rotate(15deg);
            }

        .cart-icon {
            position: relative;
            font-size: 24px;
            color: var(--text-secondary);
            transition: var(--transition);
            text-decoration: none;
        }

            .cart-icon:hover {
                color: var(--primary);
                transform: scale(1.05);
            }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -12px;
            background: var(--primary);
            color: white;
            font-size: 11px;
            font-weight: 600;
            border-radius: 20px;
            padding: 2px 6px;
            min-width: 18px;
            text-align: center;
        }

        .customer-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--surface-hover);
            padding: 8px 16px;
            border-radius: 40px;
            border: 1px solid var(--border);
        }

        .customer-name {
            font-weight: 500;
            font-size: 15px;
            color: var(--text-primary);
        }

        .logout-btn {
            background: none;
            border: none;
            font-size: 20px;
            color: var(--text-muted);
            cursor: pointer;
        }

            .logout-btn:hover {
                color: var(--primary);
            }

        /* Основной контент */
        .main {
            max-width: 1400px;
            margin: 0 auto;
            padding: 32px;
        }

        .welcome {
            margin-bottom: 32px;
            text-align: center;
        }

            .welcome h1 {
                font-size: 42px;
                font-weight: 800;
                background: linear-gradient(135deg, var(--primary), var(--accent), var(--primary-light));
                background-size: 200% auto;
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                animation: gradientShift 6s infinite linear;
            }

        @@keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .welcome p {
            color: var(--text-muted);
            margin-top: 8px;
            font-size: 18px;
        }

        /* Форма профиля */
        .profile-form {
            max-width: 600px;
            margin: 0 auto;
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            padding: 2rem;
            box-shadow: var(--shadow);
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

            .form-group label {
                display: block;
                font-weight: 600;
                margin-bottom: 0.5rem;
                color: var(--text-secondary);
            }

            .form-group input {
                width: 100%;
                padding: 12px 16px;
                border: 2px solid var(--border);
                border-radius: 12px;
                background: var(--surface);
                color: var(--text-primary);
                font-family: inherit;
                font-size: 16px;
                transition: var(--transition);
            }

                .form-group input:focus {
                    outline: none;
                    border-color: var(--primary);
                }

        .btn-save {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            padding: 12px 28px;
            border-radius: 40px;
            color: white;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-save:hover {
                transform: translateY(-2px);
                background: linear-gradient(135deg, var(--primary-dark), var(--primary));
            }

        .alert-success {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            padding: 14px 24px;
            border-radius: 12px;
            margin-bottom: 24px;
            text-align: center;
        }

        .text-danger {
            color: #ef4444;
            font-size: 0.85rem;
            margin-top: 0.25rem;
            display: block;
        }

        .guest-message-box {
            text-align: center;
            padding: 60px 20px;
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            max-width: 500px;
            margin: 0 auto;
        }

            .guest-message-box i {
                font-size: 64px;
                color: var(--primary);
                margin-bottom: 20px;
            }

            .guest-message-box h2 {
                margin-bottom: 16px;
            }

            .guest-message-box .btn-primary {
                display: inline-block;
                margin-top: 20px;
                padding: 12px 28px;
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-radius: 40px;
                color: white;
                text-decoration: none;
                font-weight: 600;
            }

        /* Футер */
        .footer {
            background: var(--surface);
            border-top: 1px solid var(--border);
            margin-top: 48px;
            padding: 24px;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
        }

            .footer a {
                color: var(--primary);
                text-decoration: none;
            }

        /* Адаптивность */
        @@media (max-width: 1024px) {
            .header-container {
                flex-wrap: wrap;
                justify-content: center;
            }

            .nav-links {
                order: 3;
                width: 100%;
                justify-content: center;
                margin-top: 12px;
                gap: 20px;
            }
        }

        @@media (max-width: 768px) {
            .header-container {
                padding: 12px 16px;
            }

            .logo {
                font-size: 22px;
            }

                .logo i {
                    font-size: 26px;
                }

            .nav-link {
                font-size: 14px;
            }

            .theme-toggle {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }

            .customer-badge {
                padding: 6px 12px;
            }

            .customer-name {
                font-size: 13px;
            }

            .main {
                padding: 16px;
            }

            .welcome h1 {
                font-size: 32px;
            }

            .profile-form {
                padding: 1rem;
            }
        }

        @@media (max-width: 480px) {
            .customer-name {
                display: none;
            }

            .nav-links {
                gap: 12px;
                font-size: 12px;
            }

            .nav-link i {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="gear gear1"><i class="fas fa-cog"></i></div>
    <div class="gear gear2"><i class="fas fa-cog"></i></div>
    <div class="gear gear3"><i class="fas fa-cog"></i></div>
    <div class="gear gear4"><i class="fas fa-cog"></i></div>

    <header class="header">
        <div class="header-container">
            <a href="/Client/Index" class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </a>
            <div class="nav-links">
                <a href="/Client/Index" class="nav-link"><i class="fas fa-home"></i> Главная</a>
                <a href="/Client/Orders" class="nav-link"><i class="fas fa-truck"></i> Заказы</a>
                <a href="/Client/Favorites" class="nav-link"><i class="fas fa-heart"></i> Избранное</a>
                <a href="/Client/Cart" class="nav-link"><i class="fas fa-shopping-cart"></i> Корзина</a>
                <a href="/Client/Profile" class="nav-link active"><i class="fas fa-user"></i> Профиль</a>
            </div>
            <div class="user-actions">
                <button class="theme-toggle" id="themeToggle"><i class="fas fa-moon"></i></button>
                <a href="/Client/Cart" class="cart-icon" id="cartIcon">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count" id="cartCount">0</span>
                </a>
                <div class="customer-badge">
                    <i class="fas fa-user-circle"></i>
                    <span class="customer-name">@Model.CustomerName</span>
                    @if (!Model.IsGuest)
                    {
                        <form method="post" asp-page="/Account/CustomerLogout">
                            <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i></button>
                        </form>
                    }
                    else
                    {
                        <a href="/Account/Login" class="logout-btn" style="text-decoration: none;"><i class="fas fa-sign-in-alt"></i></a>
                    }
                </div>
            </div>
        </div>
    </header>

    <main class="main">
        <div class="welcome">
            <h1>Мой профиль</h1>
            <p>Управление личными данными</p>
        </div>

        @if (Model.IsGuest)
        {
            <div class="guest-message-box">
                <i class="fas fa-user-circle"></i>
                <h2>Личный кабинет доступен только авторизованным пользователям</h2>
                <p>Войдите или зарегистрируйтесь, чтобы управлять профилем.</p>
                <a href="/Account/Login" class="btn-primary">Войти</a>
                <a href="/Account/CustomerRegister" class="btn-primary" style="margin-left: 12px;">Зарегистрироваться</a>
            </div>
        }
        else
        {
            @if (TempData["Success"] != null)
            {
                <div class="alert-success">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                </div>
            }

            <form method="post" class="profile-form">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label asp-for="Input.FullName">ФИО *</label>
                    <input asp-for="Input.FullName" />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.Email">Email</label>
                    <input asp-for="Input.Email" type="email" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.Phone">Телефон</label>
                    <input asp-for="Input.Phone" />
                    <span asp-validation-for="Input.Phone" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.NewPassword">Новый пароль (оставьте пустым, если не меняете)</label>
                    <input asp-for="Input.NewPassword" type="password" />
                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.ConfirmPassword">Подтверждение пароля</label>
                    <input asp-for="Input.ConfirmPassword" type="password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <button type="submit" class="btn-save"><i class="fas fa-save"></i> Сохранить изменения</button>
                </div>
            </form>
        }
    </main>

    <footer class="footer">
        <p>© 2026 Моноплист — строительные материалы с доставкой</p>
        <p><a href="/Client/About">О компании</a> | <a href="/Client/Contacts">Контакты</a> | <a href="/Client/Delivery">Доставка и оплата</a></p>
    </footer>

    <script>
        const themeToggle = document.getElementById('themeToggle');
        const icon = themeToggle.querySelector('i');
        const savedTheme = localStorage.getItem('clientTheme');
        if (savedTheme === 'dark') {
            document.body.classList.add('dark');
            icon.classList.remove('fa-moon');
            icon.classList.add('fa-sun');
        }
        themeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark');
            if (document.body.classList.contains('dark')) {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
                localStorage.setItem('clientTheme', 'dark');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
                localStorage.setItem('clientTheme', 'light');
            }
        });

        async function updateCartCount() {
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('/Client/Cart?handler=Count', {
                    method: 'GET',
                    headers: { 'RequestVerificationToken': token }
                });
                const data = await response.json();
                const countSpan = document.getElementById('cartCount');
                if (data.count > 0) {
                    countSpan.style.display = 'inline-block';
                    countSpan.innerText = data.count;
                } else {
                    countSpan.style.display = 'none';
                }
            } catch (error) { console.error('Ошибка получения количества товаров', error); }
        }

        updateCartCount();
    </script>
</body>
</html>