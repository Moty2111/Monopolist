@page
@model Monoplist.Pages.Client.ProfileModel
@{
    Layout = null;
    ViewData["Title"] = "Мой профиль";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --bg: #f8f9fc;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.05);
            --shadow-md: 0 8px 20px rgba(0,0,0,0.08);
            --shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.1);
            --radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body.dark {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-hover: #334155;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --text-muted: #94a3b8;
            --border: #334155;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.2);
            --shadow-md: 0 8px 20px rgba(0,0,0,0.3);
            --shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.4);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background 0.3s, color 0.3s;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .gear {
            position: fixed;
            font-size: 6rem;
            color: rgba(255,107,0,0.08);
            z-index: -2;
            animation: spin 30s linear infinite;
            pointer-events: none;
        }

        body.dark .gear {
            color: rgba(255,107,0,0.25);
        }

        .gear1 {
            top: 5%;
            left: 2%;
            animation-duration: 40s;
        }

        .gear2 {
            bottom: 10%;
            right: 3%;
            animation-duration: 35s;
            animation-direction: reverse;
            font-size: 8rem;
        }

        .gear3 {
            top: 30%;
            right: 5%;
            animation-duration: 45s;
            font-size: 5rem;
        }

        .gear4 {
            bottom: 30%;
            left: 5%;
            animation-duration: 50s;
            animation-direction: reverse;
            font-size: 7rem;
        }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .header {
            background: rgba(var(--surface-rgb), 0.95);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid var(--border);
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 28px;
            flex-wrap: nowrap;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-decoration: none;
        }

            .logo i {
                font-size: 30px;
            }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-link {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .nav-link:hover, .nav-link.active {
                color: var(--primary);
            }

        .user-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--border);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--text-secondary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                border-color: var(--primary);
                color: var(--primary);
                transform: rotate(15deg);
            }

        .cart-icon {
            position: relative;
            font-size: 24px;
            color: var(--text-secondary);
            transition: var(--transition);
            text-decoration: none;
        }

            .cart-icon:hover {
                color: var(--primary);
                transform: scale(1.05);
            }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -12px;
            background: var(--primary);
            color: white;
            font-size: 11px;
            font-weight: 600;
            border-radius: 20px;
            padding: 2px 6px;
            min-width: 18px;
            text-align: center;
        }

        .customer-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--surface-hover);
            padding: 8px 16px;
            border-radius: 40px;
            border: 1px solid var(--border);
        }

        .customer-avatar-link {
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        .customer-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

            .customer-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .customer-name {
            font-weight: 500;
            font-size: 15px;
            color: var(--text-primary);
        }

        .logout-btn {
            background: none;
            border: none;
            font-size: 20px;
            color: var(--text-muted);
            cursor: pointer;
        }

            .logout-btn:hover {
                color: var(--primary);
            }

        .main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 24px;
        }

        .profile-card {
            background: var(--surface);
            border-radius: 32px;
            box-shadow: var(--shadow-md);
            overflow: hidden;
            border: 1px solid var(--border);
            transition: transform 0.3s ease;
        }

        .profile-header {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            padding: 40px 32px 80px 32px;
            text-align: center;
            position: relative;
        }

            .profile-header h1 {
                color: white;
                font-size: 32px;
                font-weight: 700;
                margin-bottom: 8px;
            }

            .profile-header p {
                color: rgba(255,255,255,0.9);
                font-size: 16px;
            }

        .avatar-wrapper {
            position: relative;
            width: 140px;
            height: 140px;
            margin: -70px auto 20px auto;
            cursor: pointer;
        }

        .avatar-preview {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: var(--surface);
            border: 4px solid var(--accent);
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            transition: transform 0.3s ease;
        }

            .avatar-preview:hover {
                transform: scale(1.02);
            }

            .avatar-preview img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .avatar-preview i {
                font-size: 80px;
                color: var(--primary);
                display: flex;
                align-items: center;
                justify-content: center;
                height: 100%;
                background: var(--surface-hover);
            }

        .avatar-upload-btn {
            position: absolute;
            bottom: 5px;
            right: 5px;
            background: var(--primary);
            border-radius: 50%;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            cursor: pointer;
            border: 2px solid var(--surface);
            transition: all 0.2s;
        }

            .avatar-upload-btn:hover {
                background: var(--primary-dark);
                transform: scale(1.1);
            }

        .profile-body {
            padding: 32px;
        }

        .form-section {
            background: var(--surface-hover);
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 28px;
            border: 1px solid var(--border);
        }

            .form-section h3 {
                font-size: 20px;
                font-weight: 600;
                margin-bottom: 20px;
                color: var(--primary);
                display: flex;
                align-items: center;
                gap: 10px;
            }

        .form-row {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }

        .form-group {
            flex: 1;
            min-width: 200px;
        }

            .form-group label {
                display: block;
                font-weight: 500;
                margin-bottom: 6px;
                color: var(--text-secondary);
                font-size: 14px;
            }

            .form-group input, .form-group .url-input {
                width: 100%;
                padding: 12px 16px;
                border: 2px solid var(--border);
                border-radius: 14px;
                background: var(--surface);
                color: var(--text-primary);
                font-family: inherit;
                font-size: 15px;
                transition: var(--transition);
            }

                .form-group input:focus, .form-group .url-input:focus {
                    outline: none;
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
                }

        .avatar-url-field {
            margin-top: 16px;
        }

        .btn-save {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            padding: 14px 28px;
            border-radius: 40px;
            color: white;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

            .btn-save:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(255,107,0,0.3);
            }

        .btn-secondary {
            background: transparent;
            border: 2px solid var(--border);
            padding: 12px 24px;
            border-radius: 40px;
            color: var(--text-secondary);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

            .btn-secondary:hover {
                border-color: var(--primary);
                color: var(--primary);
            }

        .alert-success {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            padding: 14px 20px;
            border-radius: 14px;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideDown 0.3s ease;
        }

        .text-danger {
            color: #ef4444;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .guest-message-box {
            text-align: center;
            padding: 60px 20px;
            background: var(--surface);
            border-radius: 32px;
            border: 1px solid var(--border);
        }

            .guest-message-box i {
                font-size: 64px;
                color: var(--primary);
                margin-bottom: 20px;
            }

            .guest-message-box .btn-primary {
                display: inline-block;
                margin-top: 20px;
                padding: 12px 28px;
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-radius: 40px;
                color: white;
                text-decoration: none;
                font-weight: 600;
            }

        .footer {
            background: var(--surface);
            border-top: 1px solid var(--border);
            margin-top: 48px;
            padding: 24px;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
        }

            .footer a {
                color: var(--primary);
                text-decoration: none;
            }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 1024px) {
            .header-container {
                flex-wrap: wrap;
                justify-content: center;
            }

            .nav-links {
                order: 3;
                width: 100%;
                justify-content: center;
                margin-top: 12px;
                gap: 20px;
            }
        }

        @@media (max-width: 768px) {
            .header-container {
                padding: 12px 16px;
            }

            .logo {
                font-size: 22px;
            }

                .logo i {
                    font-size: 26px;
                }

            .nav-link {
                font-size: 14px;
            }

            .theme-toggle {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }

            .customer-badge {
                padding: 6px 12px;
            }

            .customer-name {
                font-size: 13px;
            }

            .main {
                padding: 20px 16px;
            }

            .profile-header {
                padding: 30px 20px 70px 20px;
            }

            .avatar-wrapper {
                width: 110px;
                height: 110px;
                margin-top: -55px;
            }

            .profile-body {
                padding: 20px;
            }

            .form-row {
                flex-direction: column;
                gap: 12px;
            }
        }

        @@media (max-width: 480px) {
            .customer-name {
                display: none;
            }

            .nav-links {
                gap: 12px;
                font-size: 12px;
            }

            .nav-link i {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="gear gear1"><i class="fas fa-cog"></i></div>
    <div class="gear gear2"><i class="fas fa-cog"></i></div>
    <div class="gear gear3"><i class="fas fa-cog"></i></div>
    <div class="gear gear4"><i class="fas fa-cog"></i></div>

    <header class="header">
        <div class="header-container">
            <a href="/Client/Index" class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </a>
            <div class="nav-links">
                <a href="/Client/Index" class="nav-link"><i class="fas fa-home"></i> Главная</a>
                <a href="/Client/Orders" class="nav-link"><i class="fas fa-truck"></i> Заказы</a>
                <a href="/Client/Favorites" class="nav-link"><i class="fas fa-heart"></i> Избранное</a>
                <a href="/Client/Cart" class="nav-link"><i class="fas fa-shopping-cart"></i> Корзина</a>
                <a href="/Client/Profile" class="nav-link active"><i class="fas fa-user"></i> Профиль</a>
            </div>
            <div class="user-actions">
                <button class="theme-toggle" id="themeToggle"><i class="fas fa-moon"></i></button>
                <a href="/Client/Cart" class="cart-icon" id="cartIcon">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count" id="cartCount">0</span>
                </a>
                <div class="customer-badge">
                    <a href="/Client/Profile" class="customer-avatar-link">
                        <div class="customer-avatar">
                            @{
                                string avatarSrc = Model.AvatarUrl;
                                bool isDataUrl = !string.IsNullOrEmpty(avatarSrc) && avatarSrc.StartsWith("data:", StringComparison.OrdinalIgnoreCase);
                            }
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img src="@(isDataUrl? Model.AvatarUrl: Model.AvatarUrl + "?t=" + DateTime.Now.Ticks)" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user-circle\'></i>';" />
                            }
                            else
                            {
                                <i class="fas fa-user-circle"></i>
                            }
                        </div>
                    </a>
                    <span class="customer-name">@Model.CustomerName</span>
                    @if (!Model.IsGuest)
                    {
                        <form method="post" asp-page="/Account/CustomerLogout">
                            <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i></button>
                        </form>
                    }
                    else
                    {
                        <a href="/Account/Login" class="logout-btn" style="text-decoration: none;"><i class="fas fa-sign-in-alt"></i></a>
                    }
                </div>
            </div>
        </div>
    </header>

    <main class="main">
        @if (Model.IsGuest)
        {
            <div class="guest-message-box">
                <i class="fas fa-user-circle"></i>
                <h2>Личный кабинет доступен только авторизованным пользователям</h2>
                <p>Войдите или зарегистрируйтесь, чтобы управлять профилем.</p>
                <a href="/Account/Login" class="btn-primary">Войти</a>
                <a href="/Account/CustomerRegister" class="btn-primary" style="margin-left: 12px;">Зарегистрироваться</a>
            </div>
        }
        else
        {
            @if (TempData["Success"] != null)
            {
                <div class="alert-success">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                </div>
            }

            <div class="profile-card">
                <div class="profile-header">
                    <h1>Мой профиль</h1>
                    <p>Управление личными данными и аватаром</p>
                </div>

                <form method="post" id="profileForm">
                    @Html.AntiForgeryToken()
                    <!-- Скрытое поле для хранения Data URL -->
                    <input type="hidden" id="AvatarDataUrl" name="AvatarDataUrl" />

                    <div class="avatar-wrapper">
                        <div class="avatar-preview" id="avatarPreview">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                bool isDataUrl = Model.AvatarUrl.StartsWith("data:", StringComparison.OrdinalIgnoreCase);
                                <img src="@(isDataUrl? Model.AvatarUrl: Model.AvatarUrl + "?t=" + DateTime.Now.Ticks)" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user\'></i>';" />
                            }
                            else
                            {
                                <i class="fas fa-user"></i>
                            }
                        </div>
                        <label class="avatar-upload-btn" for="avatarFile" title="Загрузить аватар">
                            <i class="fas fa-camera"></i>
                        </label>
                        <input type="file" id="avatarFile" accept="image/*" style="display: none;" />
                    </div>

                    <div class="avatar-url-field" style="max-width: 400px; margin: 0 auto 20px auto;">
                        <div class="form-group">
                            <label for="AvatarUrlInput">URL аватара</label>
                            <input type="text" id="AvatarUrlInput" name="AvatarUrl" class="url-input" placeholder="https://example.com/avatar.jpg" value="@Model.AvatarUrl" />
                        </div>
                    </div>

                    <div class="profile-body">
                        <div class="form-section">
                            <h3><i class="fas fa-user-circle"></i> Основная информация</h3>
                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="Input.FullName">ФИО *</label>
                                    <input asp-for="Input.FullName" />
                                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="Input.Email">Email</label>
                                    <input asp-for="Input.Email" type="email" />
                                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="Input.Phone">Телефон</label>
                                    <input asp-for="Input.Phone" />
                                    <span asp-validation-for="Input.Phone" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3><i class="fas fa-lock"></i> Смена пароля</h3>
                            <p style="margin-bottom: 16px; font-size: 14px; color: var(--text-muted);">Оставьте поля пустыми, если не хотите менять пароль</p>
                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="Input.NewPassword">Новый пароль</label>
                                    <input asp-for="Input.NewPassword" type="password" />
                                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="Input.ConfirmPassword">Подтверждение пароля</label>
                                    <input asp-for="Input.ConfirmPassword" type="password" />
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div style="display: flex; gap: 16px; justify-content: flex-end; margin-top: 24px;">
                            <a href="/Client/Index" class="btn-secondary"><i class="fas fa-arrow-left"></i> На главную</a>
                            <button type="submit" class="btn-save"><i class="fas fa-save"></i> Сохранить изменения</button>
                        </div>
                    </div>
                </form>
            </div>
        }
    </main>

    <footer class="footer">
        <p>© 2026 Моноплист — строительные материалы с доставкой</p>
        <p><a href="/Client/About">О компании</a> | <a href="/Client/Contacts">Контакты</a> | <a href="/Client/Delivery">Доставка и оплата</a></p>
    </footer>

    <script>
        const themeToggle = document.getElementById('themeToggle');
        const icon = themeToggle.querySelector('i');
        const savedTheme = localStorage.getItem('clientTheme');
        if (savedTheme === 'dark') {
            document.body.classList.add('dark');
            icon.classList.remove('fa-moon');
            icon.classList.add('fa-sun');
        }
        themeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark');
            if (document.body.classList.contains('dark')) {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
                localStorage.setItem('clientTheme', 'dark');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
                localStorage.setItem('clientTheme', 'light');
            }
        });

        // Работа с аватаром
        const avatarFile = document.getElementById('avatarFile');
        const avatarPreview = document.getElementById('avatarPreview');
        const avatarUrlInput = document.getElementById('AvatarUrlInput');
        const avatarDataUrl = document.getElementById('AvatarDataUrl');

        function updatePreview(src) {
            if (src) {
                avatarPreview.innerHTML = `<img src="${src}" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user\'></i>';" />`;
            } else {
                avatarPreview.innerHTML = '<i class="fas fa-user"></i>';
            }
        }

        if (avatarFile) {
            avatarFile.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const dataUrl = e.target.result;
                        updatePreview(dataUrl);
                        avatarUrlInput.value = '';          // очищаем поле URL
                        avatarDataUrl.value = dataUrl;       // сохраняем Data URL в скрытое поле
                    };
                    reader.readAsDataURL(file);
                } else {
                    avatarDataUrl.value = '';
                }
            });
        }

        if (avatarUrlInput) {
            avatarUrlInput.addEventListener('input', function() {
                const url = this.value.trim();
                if (url) {
                    updatePreview(url);
                    avatarFile.value = '';       // очищаем выбор файла
                    avatarDataUrl.value = '';    // не используем Data URL
                } else {
                    // Если поле очистили, показываем текущий аватар (из модели)
                    updatePreview('@Model.AvatarUrl');
                    avatarDataUrl.value = '';
                }
            });
        }

        async function updateCartCount() {
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('/Client/Cart?handler=Count', {
                    method: 'GET',
                    headers: { 'RequestVerificationToken': token }
                });
                const data = await response.json();
                const countSpan = document.getElementById('cartCount');
                if (data.count > 0) {
                    countSpan.style.display = 'inline-block';
                    countSpan.innerText = data.count;
                } else {
                    countSpan.style.display = 'none';
                }
            } catch (error) {
                console.error('Ошибка получения количества товаров', error);
            }
        }
        updateCartCount();
    </script>
</body>
</html>