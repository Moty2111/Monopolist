@page
@model Monoplist.Pages.Client.AboutModel
@{
    Layout = null;
    ViewData["Title"] = "О компании";
    string avatarSrc = Model.AvatarUrl;
    bool isDataUrl = !string.IsNullOrEmpty(avatarSrc) && avatarSrc.StartsWith("data:", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --bg: #f8f9fc;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.05);
            --shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.1);
            --radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body.dark {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-hover: #334155;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --text-muted: #94a3b8;
            --border: #334155;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            transition: background 0.3s, color 0.3s;
            min-height: 100vh;
        }

        .gear {
            position: fixed;
            font-size: 6rem;
            color: rgba(255,107,0,0.08);
            z-index: -2;
            animation: spin 30s linear infinite;
            pointer-events: none;
        }

        body.dark .gear {
            color: rgba(255,107,0,0.25);
        }

        .gear1 {
            top: 5%;
            left: 2%;
            animation-duration: 40s;
        }

        .gear2 {
            bottom: 10%;
            right: 3%;
            animation-duration: 35s;
            animation-direction: reverse;
            font-size: 8rem;
        }

        .gear3 {
            top: 30%;
            right: 5%;
            animation-duration: 45s;
            font-size: 5rem;
        }

        .gear4 {
            bottom: 30%;
            left: 5%;
            animation-duration: 50s;
            animation-direction: reverse;
            font-size: 7rem;
        }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .header {
            background: rgba(var(--surface-rgb), 0.95);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid var(--border);
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 28px;
            flex-wrap: nowrap;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-decoration: none;
        }

            .logo i {
                font-size: 30px;
            }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-link {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .nav-link:hover, .nav-link.active {
                color: var(--primary);
            }

        .user-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--border);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--text-secondary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                border-color: var(--primary);
                color: var(--primary);
                transform: rotate(15deg);
            }

        .cart-icon {
            position: relative;
            font-size: 24px;
            color: var(--text-secondary);
            transition: var(--transition);
            text-decoration: none;
        }

            .cart-icon:hover {
                color: var(--primary);
                transform: scale(1.05);
            }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -12px;
            background: var(--primary);
            color: white;
            font-size: 11px;
            font-weight: 600;
            border-radius: 20px;
            padding: 2px 6px;
            min-width: 18px;
            text-align: center;
        }

        .customer-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--surface-hover);
            padding: 8px 16px;
            border-radius: 40px;
            border: 1px solid var(--border);
        }

        .customer-avatar-link {
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        .customer-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

            .customer-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .customer-name {
            font-weight: 500;
            font-size: 15px;
            color: var(--text-primary);
        }

        .logout-btn {
            background: none;
            border: none;
            font-size: 20px;
            color: var(--text-muted);
            cursor: pointer;
        }

            .logout-btn:hover {
                color: var(--primary);
            }

        .main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 32px;
        }

        .welcome {
            margin-bottom: 32px;
            text-align: center;
        }

            .welcome h1 {
                font-size: 42px;
                font-weight: 800;
                background: linear-gradient(135deg, var(--primary), var(--accent), var(--primary-light));
                background-size: 200% auto;
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                animation: gradientShift 6s infinite linear;
            }

        @@keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .welcome p {
            color: var(--text-muted);
            margin-top: 8px;
            font-size: 18px;
        }

        .about-content {
            max-width: 900px;
            margin: 0 auto;
            line-height: 1.8;
            background: var(--surface);
            border-radius: var(--radius);
            padding: 2.5rem;
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
        }

            .about-content h2 {
                color: var(--primary);
                font-size: 1.8rem;
                margin: 2rem 0 1rem;
                border-left: 4px solid var(--accent);
                padding-left: 1rem;
            }

                .about-content h2:first-of-type {
                    margin-top: 0;
                }

            .about-content p {
                margin-bottom: 1.2rem;
            }

            .about-content ul {
                padding-left: 1.8rem;
                margin: 1.2rem 0;
                list-style-type: none;
            }

            .about-content li {
                margin-bottom: 0.8rem;
                position: relative;
                padding-left: 1.5rem;
            }

                .about-content li::before {
                    content: "✓";
                    color: var(--primary);
                    font-weight: bold;
                    position: absolute;
                    left: 0;
                }

            .about-content .highlight {
                background: linear-gradient(135deg, rgba(255,107,0,0.08), rgba(255,215,0,0.08));
                padding: 1.5rem;
                border-radius: 12px;
                border: 1px solid var(--border);
                margin: 1.5rem 0;
            }

            .about-content .stats {
                display: flex;
                justify-content: space-around;
                flex-wrap: wrap;
                gap: 1.5rem;
                margin: 2rem 0;
            }

            .about-content .stat-item {
                text-align: center;
            }

            .about-content .stat-number {
                font-size: 2.5rem;
                font-weight: 800;
                color: var(--primary);
                display: block;
            }

            .about-content .stat-label {
                font-size: 0.9rem;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .footer {
            background: var(--surface);
            border-top: 1px solid var(--border);
            margin-top: 48px;
            padding: 24px;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
        }

            .footer a {
                color: var(--primary);
                text-decoration: none;
            }

        @@media (max-width: 1024px) {
            .header-container {
                flex-wrap: wrap;
                justify-content: center;
            }

            .nav-links {
                order: 3;
                width: 100%;
                justify-content: center;
                margin-top: 12px;
                gap: 20px;
            }
        }

        @@media (max-width: 768px) {
            .header-container {
                padding: 12px 16px;
            }

            .logo {
                font-size: 22px;
            }

                .logo i {
                    font-size: 26px;
                }

            .nav-link {
                font-size: 14px;
            }

            .theme-toggle {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }

            .customer-badge {
                padding: 6px 12px;
            }

            .customer-name {
                font-size: 13px;
            }

            .main {
                padding: 16px;
            }

            .welcome h1 {
                font-size: 32px;
            }

            .about-content {
                padding: 1.5rem;
            }

                .about-content h2 {
                    font-size: 1.5rem;
                }

                .about-content .stat-number {
                    font-size: 2rem;
                }
        }

        @@media (max-width: 480px) {
            .customer-name {
                display: none;
            }

            .nav-links {
                gap: 12px;
                font-size: 12px;
            }

            .nav-link i {
                display: none;
            }

            .about-content .stats {
                flex-direction: column;
                gap: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="gear gear1"><i class="fas fa-cog"></i></div>
    <div class="gear gear2"><i class="fas fa-cog"></i></div>
    <div class="gear gear3"><i class="fas fa-cog"></i></div>
    <div class="gear gear4"><i class="fas fa-cog"></i></div>

    <header class="header">
        <div class="header-container">
            <a href="/Client/Index" class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </a>
            <div class="nav-links">
                <a href="/Client/Index" class="nav-link"><i class="fas fa-home"></i> Главная</a>
                <a href="/Client/About" class="nav-link active"><i class="fas fa-info-circle"></i> О компании</a>
                <a href="/Client/Contacts" class="nav-link"><i class="fas fa-phone-alt"></i> Контакты</a>
                <a href="/Client/Delivery" class="nav-link"><i class="fas fa-truck"></i> Доставка</a>
            </div>
            <div class="user-actions">
                <button class="theme-toggle" id="themeToggle"><i class="fas fa-moon"></i></button>
                <a href="/Client/Cart" class="cart-icon" id="cartIcon">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count" id="cartCount">0</span>
                </a>
                <div class="customer-badge">
                    <a href="/Client/Profile" class="customer-avatar-link">
                        <div class="customer-avatar">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img src="@(isDataUrl? Model.AvatarUrl: Model.AvatarUrl + "?t=" + DateTime.Now.Ticks)" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user-circle\'></i>';" />
                            }
                            else
                            {
                                <i class="fas fa-user-circle"></i>
                            }
                        </div>
                    </a>
                    <span class="customer-name">@Model.CustomerName</span>
                    @if (!Model.IsGuest)
                    {
                        <form method="post" asp-page="/Account/CustomerLogout">
                            <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i></button>
                        </form>
                    }
                    else
                    {
                        <a href="/Account/Login" class="logout-btn" style="text-decoration: none;"><i class="fas fa-sign-in-alt"></i></a>
                    }
                </div>
            </div>
        </div>
    </header>

    <main class="main">
        <div class="welcome">
            <h1>О компании</h1>
            <p>История, ценности и достижения</p>
        </div>
        <div class="about-content">
            <p><strong>Моноплист</strong> — ведущий поставщик строительных и отделочных материалов на российском рынке. С 2010 года мы помогаем строить и ремонтировать тысячи объектов: от небольших квартир до масштабных промышленных комплексов.</p>

            <div class="stats">
                <div class="stat-item">
                    <span class="stat-number">14+</span>
                    <span class="stat-label">лет на рынке</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">5 000+</span>
                    <span class="stat-label">постоянных клиентов</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">50 000+</span>
                    <span class="stat-label">товаров в каталоге</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">12</span>
                    <span class="stat-label">регионов доставки</span>
                </div>
            </div>

            <h2><i class="fas fa-bullseye" style="margin-right: 10px;"></i> Наша миссия</h2>
            <p>Обеспечить строительные компании и частных клиентов качественными материалами по справедливым ценам. Мы сокращаем путь от производителя до стройплощадки, экономя ваше время и деньги.</p>

            <h2><i class="fas fa-gem" style="margin-right: 10px;"></i> Наши ценности</h2>
            <ul>
                <li><strong>Качество без компромиссов</strong> — работаем только с проверенными производителями и брендами.</li>
                <li><strong>Честность и прозрачность</strong> — вы всегда знаете, за что платите. Никаких скрытых наценок.</li>
                <li><strong>Профессионализм</strong> — наши менеджеры проходят регулярное обучение и знают всё о строительных материалах.</li>
                <li><strong>Клиентоориентированность</strong> — мы подстраиваемся под ваши задачи, а не наоборот.</li>
            </ul>

            <h2><i class="fas fa-trophy" style="margin-right: 10px;"></i> Почему выбирают нас</h2>
            <div class="highlight">
                <p><i class="fas fa-check-circle" style="color: var(--primary); margin-right: 8px;"></i> <strong>Собственный складской комплекс</strong> площадью более 10 000 м² в Москве. Всегда в наличии ходовые позиции.</p>
                <p><i class="fas fa-check-circle" style="color: var(--primary); margin-right: 8px;"></i> <strong>Гибкая система скидок</strong> для оптовых покупателей и строительных организаций. Персональный менеджер для крупных заказчиков.</p>
                <p><i class="fas fa-check-circle" style="color: var(--primary); margin-right: 8px;"></i> <strong>Удобные способы оплаты</strong> — наличные, банковские карты, безналичный расчёт, оплата частями.</p>
                <p><i class="fas fa-check-circle" style="color: var(--primary); margin-right: 8px;"></i> <strong>Оперативная доставка</strong> по Москве и области в день заказа, в регионы — от 1 дня.</p>
            </div>

            <h2><i class="fas fa-history" style="margin-right: 10px;"></i> История развития</h2>
            <p>Начав с небольшого магазина строительных материалов в 2010 году, мы постепенно расширяли ассортимент и географию присутствия. В 2015 году открыли собственный склад, а в 2018 запустили онлайн-каталог с возможностью заказа через сайт. Сегодня «Моноплист» — это современная компания, объединяющая розничные и оптовые продажи, собственную логистику и профессиональную команду.</p>

            <h2><i class="fas fa-handshake" style="margin-right: 10px;"></i> Партнёры и бренды</h2>
            <p>Мы сотрудничаем с ведущими мировыми и российскими производителями: Knauf, Ceresit, Weber, Bergauf, Леруа Мерлен, Технониколь, Волма, Основит и многими другими. Это позволяет гарантировать подлинность продукции и предлагать конкурентные цены.</p>

            <h2><i class="fas fa-leaf" style="margin-right: 10px;"></i> Экологическая ответственность</h2>
            <p>Мы заботимся об окружающей среде: внедряем программы по сокращению отходов, используем энергоэффективное оборудование на складе и предлагаем клиентам экологичные строительные материалы.</p>

            <p style="margin-top: 2rem; font-style: italic;">Присоединяйтесь к числу наших довольных клиентов и убедитесь в качестве сервиса «Моноплист»!</p>
        </div>
    </main>

    <footer class="footer">
        <p>© 2026 Моноплист — строительные материалы с доставкой</p>
        <p><a href="/Client/About">О компании</a> | <a href="/Client/Contacts">Контакты</a> | <a href="/Client/Delivery">Доставка и оплата</a></p>
    </footer>

    <script>
        const themeToggle = document.getElementById('themeToggle');
        const icon = themeToggle.querySelector('i');
        const savedTheme = localStorage.getItem('clientTheme');
        if (savedTheme === 'dark') { document.body.classList.add('dark'); icon.classList.remove('fa-moon'); icon.classList.add('fa-sun'); }
        themeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark');
            if (document.body.classList.contains('dark')) { icon.classList.remove('fa-moon'); icon.classList.add('fa-sun'); localStorage.setItem('clientTheme', 'dark'); }
            else { icon.classList.remove('fa-sun'); icon.classList.add('fa-moon'); localStorage.setItem('clientTheme', 'light'); }
        });

        async function updateCartCount() {
            try {
                const response = await fetch('/Client/Cart?handler=Count');
                const data = await response.json();
                const countSpan = document.getElementById('cartCount');
                if (data.count > 0) { countSpan.style.display = 'inline-block'; countSpan.innerText = data.count; }
                else { countSpan.style.display = 'none'; }
            } catch (error) { console.error('Ошибка получения количества товаров', error); }
        }
        updateCartCount();
    </script>
</body>
</html>