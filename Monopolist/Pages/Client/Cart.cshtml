@page
@model Monoplist.Pages.Client.CartModel
@{
    Layout = null;
    ViewData["Title"] = "Корзина";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ========== БАЗОВЫЕ ПЕРЕМЕННЫЕ ========== */
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --bg: #f8f9fc;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.05);
            --shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.1);
            --radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body.dark {
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-hover: #334155;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --text-muted: #94a3b8;
            --border: #334155;
            --shadow: 0 2px 4px -1px rgba(0,0,0,0.2);
            --shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.3);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background 0.3s, color 0.3s;
            position: relative;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Шестерёнки */
        .gear {
            position: fixed;
            font-size: 6rem;
            color: rgba(255,107,0,0.08);
            z-index: -2;
            animation: spin 30s linear infinite;
            pointer-events: none;
        }

        body.dark .gear {
            color: rgba(255,107,0,0.25);
        }

        .gear1 {
            top: 5%;
            left: 2%;
            animation-duration: 40s;
        }

        .gear2 {
            bottom: 10%;
            right: 3%;
            animation-duration: 35s;
            animation-direction: reverse;
            font-size: 8rem;
        }

        .gear3 {
            top: 30%;
            right: 5%;
            animation-duration: 45s;
            font-size: 5rem;
        }

        .gear4 {
            bottom: 30%;
            left: 5%;
            animation-duration: 50s;
            animation-direction: reverse;
            font-size: 7rem;
        }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        /* Шапка */
        .header {
            background: rgba(var(--surface-rgb), 0.95);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid var(--border);
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 28px;
            flex-wrap: nowrap;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-decoration: none;
        }

            .logo i {
                font-size: 30px;
            }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-link {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .nav-link:hover {
                color: var(--primary);
            }

        .user-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--border);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--text-secondary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                border-color: var(--primary);
                color: var(--primary);
                transform: rotate(15deg);
            }

        .cart-icon {
            position: relative;
            font-size: 24px;
            color: var(--text-secondary);
            transition: var(--transition);
            text-decoration: none;
        }

            .cart-icon:hover {
                color: var(--primary);
                transform: scale(1.05);
            }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -12px;
            background: var(--primary);
            color: white;
            font-size: 11px;
            font-weight: 600;
            border-radius: 20px;
            padding: 2px 6px;
            min-width: 18px;
            text-align: center;
        }

        .customer-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--surface-hover);
            padding: 8px 16px;
            border-radius: 40px;
            border: 1px solid var(--border);
        }

        .customer-name {
            font-weight: 500;
            font-size: 15px;
            color: var(--text-primary);
        }

        .logout-btn {
            background: none;
            border: none;
            font-size: 20px;
            color: var(--text-muted);
            cursor: pointer;
        }

            .logout-btn:hover {
                color: var(--primary);
            }

        /* Основной контент */
        .main {
            max-width: 1400px;
            margin: 0 auto;
            padding: 32px;
        }

        .welcome {
            margin-bottom: 32px;
            text-align: center;
        }

            .welcome h1 {
                font-size: 42px;
                font-weight: 800;
                background: linear-gradient(135deg, var(--primary), var(--accent), var(--primary-light));
                background-size: 200% auto;
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                animation: gradientShift 6s infinite linear;
            }

        @@keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .welcome p {
            color: var(--text-muted);
            margin-top: 8px;
            font-size: 18px;
        }

        /* Стили корзины */
        .cart-container {
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            overflow: hidden;
            box-shadow: var(--shadow);
        }

        .cart-table {
            width: 100%;
            border-collapse: collapse;
        }

            .cart-table th {
                text-align: left;
                padding: 16px 20px;
                background: var(--surface-hover);
                border-bottom: 2px solid var(--border);
                font-weight: 600;
                color: var(--text-primary);
            }

            .cart-table td {
                padding: 16px 20px;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

        .cart-product-image {
            width: 80px;
            height: 80px;
            background: var(--surface-hover);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            overflow: hidden;
        }

            .cart-product-image img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .cart-product-name {
            font-weight: 600;
        }

        .cart-quantity input {
            width: 70px;
            padding: 6px 10px;
            border: 2px solid var(--border);
            border-radius: 8px;
            text-align: center;
            font-size: 14px;
            background: var(--surface);
            color: var(--text-primary);
        }

        .cart-remove {
            background: none;
            border: none;
            color: #ef4444;
            font-size: 20px;
            cursor: pointer;
            transition: var(--transition);
        }

            .cart-remove:hover {
                transform: scale(1.1);
                color: #dc2626;
            }

        .cart-summary {
            padding: 20px;
            background: var(--surface-hover);
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .cart-total {
            font-size: 24px;
            font-weight: 700;
            color: var(--primary);
        }

        .checkout-btn {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            padding: 12px 28px;
            border-radius: 40px;
            color: white;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .checkout-btn:hover {
                transform: translateY(-2px);
                background: linear-gradient(135deg, var(--primary-dark), var(--primary));
            }

        /* Пустое состояние */
        .empty-cart {
            text-align: center;
            padding: 80px 20px;
            color: var(--text-muted);
        }

            .empty-cart i {
                font-size: 80px;
                margin-bottom: 20px;
                opacity: 0.5;
            }

        /* Сообщение для гостя */
        .guest-message-box {
            text-align: center;
            padding: 60px 20px;
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            max-width: 500px;
            margin: 0 auto;
        }

            .guest-message-box i {
                font-size: 64px;
                color: var(--primary);
                margin-bottom: 20px;
            }

            .guest-message-box h2 {
                margin-bottom: 16px;
            }

            .guest-message-box .btn-primary {
                display: inline-block;
                margin-top: 20px;
                padding: 12px 28px;
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-radius: 40px;
                color: white;
                text-decoration: none;
                font-weight: 600;
            }

        /* Выбор способа оплаты */
        .payment-section {
            margin-bottom: 20px;
            padding: 0 0 15px 0;
            border-bottom: 1px solid var(--border);
        }

            .payment-section h3 {
                font-size: 18px;
                margin-bottom: 12px;
                color: var(--text-primary);
            }

        .payment-methods {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        .payment-method {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            padding: 8px 16px;
            border: 2px solid var(--border);
            border-radius: 40px;
            transition: var(--transition);
            background: var(--surface);
        }

            .payment-method.selected {
                border-color: var(--primary);
                background: rgba(255,107,0,0.1);
            }

            .payment-method input {
                margin: 0;
                cursor: pointer;
            }

            .payment-method label {
                cursor: pointer;
                font-weight: 500;
                color: var(--text-primary);
            }

        /* Футер */
        .footer {
            background: var(--surface);
            border-top: 1px solid var(--border);
            margin-top: 48px;
            padding: 24px;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
        }

            .footer a {
                color: var(--primary);
                text-decoration: none;
            }

        /* Адаптивность */
        @@media (max-width: 1024px) {
            .header-container {
                flex-wrap: wrap;
                justify-content: center;
            }

            .nav-links {
                order: 3;
                width: 100%;
                justify-content: center;
                margin-top: 12px;
                gap: 20px;
            }
        }

        @@media (max-width: 768px) {
            .header-container {
                padding: 12px 16px;
            }

            .logo {
                font-size: 22px;
            }

                .logo i {
                    font-size: 26px;
                }

            .nav-link {
                font-size: 14px;
            }

            .theme-toggle {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }

            .customer-badge {
                padding: 6px 12px;
            }

            .customer-name {
                font-size: 13px;
            }

            .main {
                padding: 16px;
            }

            .cart-table th, .cart-table td {
                padding: 12px 8px;
                font-size: 14px;
            }

            .cart-product-image {
                width: 60px;
                height: 60px;
            }

            .cart-total {
                font-size: 20px;
            }
        }

        @@media (max-width: 480px) {
            .customer-name {
                display: none;
            }

            .nav-links {
                gap: 12px;
                font-size: 12px;
            }

            .nav-link i {
                display: none;
            }

            .cart-table th:nth-child(3), .cart-table td:nth-child(3),
            .cart-table th:nth-child(5), .cart-table td:nth-child(5) {
                display: none;
            }

            .payment-methods {
                gap: 10px;
            }

            .payment-method {
                padding: 6px 12px;
                font-size: 12px;
            }
        }
    </style>
</head>
<body>
    <div class="gear gear1"><i class="fas fa-cog"></i></div>
    <div class="gear gear2"><i class="fas fa-cog"></i></div>
    <div class="gear gear3"><i class="fas fa-cog"></i></div>
    <div class="gear gear4"><i class="fas fa-cog"></i></div>

    <header class="header">
        <div class="header-container">
            <a href="/Client/Index" class="logo">
                <i class="fas fa-helmet-safety"></i>
                <span>Моноплист</span>
            </a>
            <div class="nav-links">
                <a href="/Client/Index" class="nav-link"><i class="fas fa-home"></i> Главная</a>
                <a href="/Client/Orders" class="nav-link"><i class="fas fa-truck"></i> Заказы</a>
                <a href="/Client/Favorites" class="nav-link"><i class="fas fa-heart"></i> Избранное</a>
                <a href="/Client/Cart" class="nav-link active"><i class="fas fa-shopping-cart"></i> Корзина</a>
                <a href="/Client/Profile" class="nav-link"><i class="fas fa-user"></i> Профиль</a>
            </div>
            <div class="user-actions">
                <button class="theme-toggle" id="themeToggle"><i class="fas fa-moon"></i></button>
                <a href="/Client/Cart" class="cart-icon" id="cartIcon">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count" id="cartCount">0</span>
                </a>
                <div class="customer-badge">
                    <i class="fas fa-user-circle"></i>
                    <span class="customer-name">@Model.CustomerName</span>
                    @if (!Model.IsGuest)
                    {
                        <form method="post" asp-page="/Account/CustomerLogout">
                            <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i></button>
                        </form>
                    }
                    else
                    {
                        <a href="/Account/Login" class="logout-btn" style="text-decoration: none;"><i class="fas fa-sign-in-alt"></i></a>
                    }
                </div>
            </div>
        </div>
    </header>

    <main class="main">
        <div class="welcome">
            <h1>Корзина</h1>
            <p>Ваши выбранные товары</p>
        </div>

        @if (Model.IsGuest)
        {
            <div class="guest-message-box">
                <i class="fas fa-shopping-cart"></i>
                <h2>Доступ к корзине только для зарегистрированных пользователей</h2>
                <p>Войдите или зарегистрируйтесь, чтобы добавлять товары и оформлять заказы.</p>
                <a href="/Account/Login" class="btn-primary">Войти</a>
                <a href="/Account/CustomerRegister" class="btn-primary" style="margin-left: 12px;">Зарегистрироваться</a>
            </div>
        }
        else if (Model.CartItems.Any())
        {
            <div class="cart-container">
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>Товар</th>
                            <th>Наименование</th>
                            <th>Цена</th>
                            <th>Количество</th>
                            <th>Сумма</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            <tr data-id="@item.Id">
                                <td class="cart-product-image">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name">
                                    }
                                    else
                                    {
                                        <i class="fas fa-box-open"></i>
                                    }
                                </td>
                                <td class="cart-product-name">@item.Name</td>
                                <td>@item.Price.ToString("N0") ₽</td>
                                <td class="cart-quantity">
                                    <input type="number" value="@item.Quantity" min="1" max="@item.CurrentStock" data-id="@item.Id">
                                </td>
                                <td class="cart-item-total">@item.Total.ToString("N0") ₽</td>
                                <td><button class="cart-remove" data-id="@item.Id"><i class="fas fa-trash-alt"></i></button></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="cart-summary">
                    <div class="payment-section">
                        <h3>Способ оплаты</h3>
                        <div class="payment-methods">
                            <div class="payment-method" data-method="Card">
                                <input type="radio" name="paymentMethod" value="Card" id="payCard" checked />
                                <label for="payCard"><i class="fas fa-credit-card"></i> Банковская карта</label>
                            </div>
                            <div class="payment-method" data-method="Cash">
                                <input type="radio" name="paymentMethod" value="Cash" id="payCash" />
                                <label for="payCash"><i class="fas fa-money-bill"></i> Наличные</label>
                            </div>
                            <div class="payment-method" data-method="Credit">
                                <input type="radio" name="paymentMethod" value="Credit" id="payCredit" />
                                <label for="payCredit"><i class="fas fa-chart-line"></i> Кредит / Рассрочка</label>
                            </div>
                        </div>
                    </div>
                    <div class="cart-total">Итого: <span id="cart-total">@Model.TotalAmount.ToString("N0")</span> ₽</div>
                    <button id="checkout-btn" class="checkout-btn"><i class="fas fa-credit-card"></i> Оформить заказ</button>
                </div>
            </div>
        }
        else
        {
            <div class="empty-cart">
                <i class="fas fa-shopping-cart"></i>
                <p>Ваша корзина пуста</p>
                <p style="font-size: 14px;">Перейдите в <a href="/Client/Index" style="color: var(--primary);">каталог</a> и добавьте товары</p>
            </div>
        }
    </main>

    <footer class="footer">
        <p>© 2026 Моноплист — строительные материалы с доставкой</p>
        <p><a href="/Client/About">О компании</a> | <a href="/Client/Contacts">Контакты</a> | <a href="/Client/Delivery">Доставка и оплата</a></p>
    </footer>

    <script>
        // Тёмная тема
        const themeToggle = document.getElementById('themeToggle');
        const icon = themeToggle.querySelector('i');
        const savedTheme = localStorage.getItem('clientTheme');
        if (savedTheme === 'dark') {
            document.body.classList.add('dark');
            icon.classList.remove('fa-moon');
            icon.classList.add('fa-sun');
        }
        themeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark');
            if (document.body.classList.contains('dark')) {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
                localStorage.setItem('clientTheme', 'dark');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
                localStorage.setItem('clientTheme', 'light');
            }
        });

        // Получение CSRF-токена
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        }

        // Обновление счётчика корзины в шапке
        async function updateCartCount() {
            try {
                const token = getAntiForgeryToken();
                const response = await fetch('/Client/Cart?handler=Count', {
                    method: 'GET',
                    headers: { 'RequestVerificationToken': token }
                });
                const data = await response.json();
                const countSpan = document.getElementById('cartCount');
                if (data.count > 0) {
                    countSpan.style.display = 'inline-block';
                    countSpan.innerText = data.count;
                } else {
                    countSpan.style.display = 'none';
                }
            } catch (error) {
                console.error('Ошибка получения количества товаров', error);
            }
        }

        // Выбор способа оплаты – визуальное выделение
        document.querySelectorAll('.payment-method').forEach(method => {
            const radio = method.querySelector('input[type="radio"]');
            if (radio) {
                method.addEventListener('click', () => {
                    radio.checked = true;
                    document.querySelectorAll('.payment-method').forEach(m => m.classList.remove('selected'));
                    method.classList.add('selected');
                });
                if (radio.checked) method.classList.add('selected');
            }
        });

        // Обработчики событий на странице корзины (только если не гость)
        @if (!Model.IsGuest)
        {
                <text>
                // Изменение количества
                document.querySelectorAll('.cart-quantity input').forEach(input => {
                    input.addEventListener('change', async (e) => {
                        const cartItemId = input.getAttribute('data-id');
                        const newQty = parseInt(input.value);
                        if (isNaN(newQty) || newQty < 1) return;
                        const formData = new FormData();
                        formData.append('cartItemId', cartItemId);
                        formData.append('quantity', newQty);
                        const token = getAntiForgeryToken();
                        const response = await fetch('/Client/Cart?handler=UpdateQuantity', {
                            method: 'POST',
                            body: formData,
                            headers: { 'RequestVerificationToken': token }
                        });
                        if (response.ok) {
                            location.reload();
                        } else {
                            const error = await response.text();
                            alert(error || 'Ошибка обновления количества');
                            location.reload();
                        }
                    });
                });

                // Удаление товара
                document.querySelectorAll('.cart-remove').forEach(btn => {
                    btn.addEventListener('click', async (e) => {
                        const cartItemId = btn.getAttribute('data-id');
                        const formData = new FormData();
                        formData.append('cartItemId', cartItemId);
                        const token = getAntiForgeryToken();
                        const response = await fetch('/Client/Cart?handler=Remove', {
                            method: 'POST',
                            body: formData,
                            headers: { 'RequestVerificationToken': token }
                        });
                        if (response.ok) {
                            location.reload();
                        } else {
                            alert('Ошибка удаления товара');
                        }
                    });
                });

                // Оформление заказа
                const checkoutBtn = document.getElementById('checkout-btn');
                if (checkoutBtn) {
                    checkoutBtn.addEventListener('click', async () => {
                        const selectedRadio = document.querySelector('input[name="paymentMethod"]:checked');
                        const paymentMethod = selectedRadio ? selectedRadio.value : 'Card';
                        const token = getAntiForgeryToken();
                        try {
                            const response = await fetch('/Client/Cart?handler=Checkout', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'RequestVerificationToken': token
                                },
                                body: JSON.stringify({ paymentMethod: paymentMethod })
                            });
                            if (response.ok) {
                                const data = await response.json();
                                if (data.success) {
                                    alert('Заказ оформлен!');
                                    window.location.href = '/Client/Orders';
                                } else {
                                    alert('Ошибка оформления заказа');
                                }
                            } else {
                                const errorText = await response.text();
                                alert('Ошибка: ' + errorText);
                            }
                        } catch (error) {
                            console.error(error);
                            alert('Ошибка при отправке запроса');
                        }
                    });
                }
                </text>
        }

        updateCartCount();
    </script>
</body>
</html>