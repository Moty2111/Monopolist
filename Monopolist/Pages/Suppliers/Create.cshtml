@page
@model Monoplist.Pages.Suppliers.CreateModel
@{
    ViewData["Title"] = "Добавление поставщика";
}
<div class="dashboard">
    <h1>@ViewData["Title"]</h1>
    <p class="subtitle">Заполните форму</p>

    <div class="form-container">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Supplier.Name"></label>
                <input asp-for="Supplier.Name" class="form-control" />
                <span asp-validation-for="Supplier.Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Supplier.ContactInfo"></label>
                <textarea asp-for="Supplier.ContactInfo" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Supplier.ContactInfo" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Сохранить</button>
                <a asp-page="Index" class="btn-secondary"><i class="fas fa-times"></i> Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}