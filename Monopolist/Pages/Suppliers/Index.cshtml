@page
@model Monoplist.Pages.Suppliers.IndexModel
@{
    ViewData["Title"] = "Поставщики";
}
<div class="dashboard">
    <h1>@ViewData["Title"]</h1>
    <p class="subtitle">Управление поставщиками</p>

    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <p>
            <a asp-page="Create" class="btn-primary">
                <i class="fas fa-plus"></i> Добавить поставщика
            </a>
        </p>
    }

    @if (Model.Suppliers.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Контактная информация</th>
                    <th>Кол-во товаров</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var supplier in Model.Suppliers)
                {
                    <tr>
                        <td>@supplier.Name</td>
                        <td>@supplier.ContactInfo</td>
                        <td>@supplier.ProductsCount</td>
                        <td>
                            <a asp-page="Details" asp-route-id="@supplier.Id" class="btn-sm btn-info" title="Просмотр">
                                <i class="fas fa-info-circle"></i>
                            </a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                            {
                                <a asp-page="Edit" asp-route-id="@supplier.Id" class="btn-sm btn-primary" title="Редактировать">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-page="Delete" asp-route-id="@supplier.Id" class="btn-sm btn-danger" title="Удалить">
                                    <i class="fas fa-trash"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Нет поставщиков.</p>
    }
</div>