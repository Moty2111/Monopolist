@page
@model Monoplist.Pages.Warehouse.EditModel
@{
    Layout = null;
    ViewData["Title"] = Model.Language == "ru" ? "Редактирование склада" : (Model.Language == "en" ? "Edit warehouse" : "Қойманы өңдеу");
}

<!DOCTYPE html>
<html lang="@Model.Language">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        :root {
            --primary: @Model.CustomColor;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-lg: 0 8px 24px rgba(255,107,0,0.15);
            --shadow-hover: 0 12px 28px rgba(255,215,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --card-color-1: #10b981;
            --card-color-2: #3b82f6;
            --card-color-3: #8b5cf6;
            --card-color-4: #f59e0b;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
            --card-color-1: #34d399;
            --card-color-2: #60a5fa;
            --card-color-3: #c084fc;
            --card-color-4: #fbbf24;
        }

        body.compact-mode .sidebar {
            width: 240px;
        }

        body.compact-mode .sidebar-header {
            padding: 16px;
        }

            body.compact-mode .sidebar-header i {
                font-size: 32px;
            }

            body.compact-mode .sidebar-header h2 {
                font-size: 20px;
            }

        body.compact-mode .sidebar-nav li a {
            padding: 8px 12px;
        }

        body.compact-mode .top-bar {
            padding: 12px 24px;
        }

        body.compact-mode .dashboard {
            padding: 16px;
        }

            body.compact-mode .dashboard h1 {
                font-size: 1.8rem;
            }

        body.compact-mode .subtitle {
            font-size: 0.9rem;
            margin-bottom: 16px;
        }

        body.compact-mode .form-group {
            margin-bottom: 1rem;
        }

        body.compact-mode .form-control {
            padding: 8px 12px;
        }

        body.compact-mode .btn-primary,
        body.compact-mode .btn-secondary {
            padding: 8px 18px;
        }

        body.no-animations * {
            transition: none !important;
            animation: none !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

            .user-info span {
                font-weight: 500;
                color: var(--text-secondary);
            }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .btn-logout {
            background: none;
            border: 2px solid var(--accent);
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            color: var(--text-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

            .btn-logout:hover {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-color: transparent;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(255,107,0,0.3);
            }

                .btn-logout:hover i {
                    color: white;
                }

        .content {
            padding: 16px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 16px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 6px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 18px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 10px;
        }

        .form-container {
            max-width: 1000px;
        }

        .form-row {
            display: flex;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .form-group {
            flex: 1;
            margin-bottom: 1.2rem;
        }

            .form-group label {
                display: block;
                font-weight: 600;
                font-size: 0.9rem;
                color: var(--primary);
                margin-bottom: 5px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            font-size: 1rem;
            border: 2px solid var(--border);
            border-radius: 12px;
            background: var(--surface);
            color: var(--text-primary);
            transition: var(--transition);
            font-family: 'Poppins', sans-serif;
        }

            .form-control:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
            }

        textarea.form-control {
            resize: vertical;
            min-height: 80px;
        }

        .products-section {
            margin-top: 30px;
            border-top: 2px solid var(--accent);
            padding-top: 20px;
        }

            .products-section h3 {
                color: var(--primary);
                font-size: 1.3rem;
                margin-bottom: 15px;
            }

        .table-responsive {
            overflow-x: auto;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .products-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--surface);
        }

            .products-table th {
                background: var(--surface-hover);
                padding: 12px 8px;
                text-align: left;
                font-weight: 600;
                color: var(--primary);
                border-bottom: 2px solid var(--accent);
            }

            .products-table td {
                padding: 10px 8px;
                border-bottom: 1px solid var(--border);
                color: var(--text-secondary);
            }

            .products-table tbody tr:hover {
                background: rgba(255,107,0,0.05);
            }

            .products-table input[type="checkbox"] {
                width: 18px;
                height: 18px;
                cursor: pointer;
                accent-color: var(--primary);
            }

        .search-box {
            margin-bottom: 15px;
        }

            .search-box input {
                width: 100%;
                padding: 10px 15px;
                border: 2px solid var(--border);
                border-radius: 30px;
                font-size: 0.95rem;
                background: var(--surface);
                color: var(--text-primary);
            }

        .select-all {
            margin-bottom: 10px;
            padding: 8px;
            background: var(--surface-hover);
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .stock-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .stock-low {
            background: var(--danger-bg);
            color: var(--danger);
        }

        .stock-normal {
            background: var(--success-bg);
            color: var(--success);
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .btn-primary, .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 22px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
            }

        .btn-secondary {
            background: var(--surface);
            color: var(--text-secondary);
            border: 2px solid var(--border);
        }

            .btn-secondary:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
                transform: translateY(-2px);
            }

        .text-danger {
            color: var(--danger);
            font-size: 0.85rem;
            margin-top: 4px;
            display: block;
        }

        .alert {
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-success {
            background: var(--success-bg);
            color: var(--success);
            border-left: 4px solid var(--success);
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger);
            border-left: 4px solid var(--danger);
        }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                top: 0;
                bottom: 0;
                transform: translateX(-100%);
                box-shadow: none;
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
                box-shadow: 2px 0 15px rgba(0,0,0,0.2);
            }

            .menu-toggle {
                display: block;
            }

            .main-content {
                width: 100%;
            }

            .top-bar {
                padding: 12px 16px;
            }

            .page-title {
                font-size: 1.25rem;
            }

            .user-info span {
                display: none;
            }

            .content {
                padding: 12px;
            }

            .dashboard {
                padding: 12px;
            }

            .form-row {
                flex-direction: column;
                gap: 0;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-primary, .btn-secondary {
                width: 100%;
                justify-content: center;
            }

            .products-table {
                font-size: 0.8rem;
            }

                .products-table th, .products-table td {
                    padding: 6px 4px;
                }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .btn-logout {
                padding: 8px 12px;
            }
        }
    </style>
</head>
<body class="@(Model.Theme == "dark" ? "dark-theme" : "") @(Model.CompactMode ? "compact-mode" : "") @(Model.Animations ? "" : "no-animations")">
    <div class="app">
        @await Html.PartialAsync("_Sidebar")

        <main class="main-content">
            @await Html.PartialAsync("_Header")

            <div class="content">
                <div class="dashboard">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
                    }

                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">@Model.WarehouseInput.Name</p>

                    <div class="form-container">
                        <form method="post" id="warehouseForm">
                            <input type="hidden" asp-for="WarehouseInput.Id" />
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="WarehouseInput.Name">@(Model.Language == "ru" ? "Название склада" : Model.Language == "en" ? "Warehouse name" : "Қойма атауы")</label>
                                    <input asp-for="WarehouseInput.Name" class="form-control" />
                                    <span asp-validation-for="WarehouseInput.Name" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label asp-for="WarehouseInput.Location">@(Model.Language == "ru" ? "Местоположение" : Model.Language == "en" ? "Location" : "Орналасқан жері")</label>
                                    <input asp-for="WarehouseInput.Location" class="form-control" />
                                    <span asp-validation-for="WarehouseInput.Location" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="WarehouseInput.ImageUrl">@(Model.Language == "ru" ? "URL изображения" : Model.Language == "en" ? "Image URL" : "Сурет URL-і")</label>
                                <input asp-for="WarehouseInput.ImageUrl" class="form-control" />
                                <span asp-validation-for="WarehouseInput.ImageUrl" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="WarehouseInput.Description">@(Model.Language == "ru" ? "Описание" : Model.Language == "en" ? "Description" : "Сипаттама")</label>
                                <textarea asp-for="WarehouseInput.Description" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="WarehouseInput.Description" class="text-danger"></span>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="WarehouseInput.Capacity">@(Model.Language == "ru" ? "Вместимость" : Model.Language == "en" ? "Capacity" : "Сыйымдылығы")</label>
                                    <input asp-for="WarehouseInput.Capacity" class="form-control" type="number" min="1" />
                                    <span asp-validation-for="WarehouseInput.Capacity" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="products-section">
                                <h3><i class="fas fa-boxes"></i> @(Model.Language == "ru" ? "Товары на складе" : Model.Language == "en" ? "Products in warehouse" : "Қоймадағы тауарлар")</h3>
                                <p class="text-muted">@(Model.Language == "ru" ? "Отметьте товары, которые хранятся на этом складе (каждый товар может находиться только на одном складе)" : Model.Language == "en" ? "Select products stored in this warehouse (each product can be in only one warehouse)" : "Осы қоймада сақталатын тауарларды белгілеңіз (әрбір тауар тек бір қоймада бола алады)")</p>

                                <div class="search-box">
                                    <input type="text" id="productSearch" class="form-control" placeholder="@(Model.Language == "ru" ? "Поиск товаров..." : Model.Language == "en" ? "Search products..." : "Тауарларды іздеу...")" />
                                </div>

                                <div class="select-all">
                                    <input type="checkbox" id="selectAll" />
                                    <label for="selectAll">@(Model.Language == "ru" ? "Выбрать все товары" : Model.Language == "en" ? "Select all products" : "Барлық тауарларды таңдау")</label>
                                </div>

                                <div class="table-responsive">
                                    <table class="products-table" id="productsTable">
                                        <thead>
                                            <tr>
                                                <th style="width: 50px;">@(Model.Language == "ru" ? "Выбрать" : Model.Language == "en" ? "Select" : "Таңдау")</th>
                                                <th>@(Model.Language == "ru" ? "Товар" : Model.Language == "en" ? "Product" : "Тауар")</th>
                                                <th>@(Model.Language == "ru" ? "Артикул" : Model.Language == "en" ? "SKU" : "Артикул")</th>
                                                <th>@(Model.Language == "ru" ? "Остаток" : Model.Language == "en" ? "Stock" : "Қалдық")</th>
                                                <th>@(Model.Language == "ru" ? "Ед." : Model.Language == "en" ? "Unit" : "Өлш.")</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < Model.WarehouseInput.AvailableProducts.Count; i++)
                                            {
                                                var product = Model.WarehouseInput.AvailableProducts[i];
                                                <tr class="product-row" data-name="@product.Name.ToLower()" data-article="@product.Article?.ToLower()">
                                                    <td>
                                                        <input type="checkbox"
                                                               name="WarehouseInput.SelectedProductIds"
                                                               value="@product.Id"
                                                               @(product.IsSelected ? "checked" : "")
                                                               class="product-checkbox" />
                                                    </td>
                                                    <td>@product.Name</td>
                                                    <td>@product.Article</td>
                                                    <td>
                                                        <span class="stock-badge @(product.CurrentStock < 10 ? "stock-low" : "stock-normal")">
                                                            @product.CurrentStock
                                                        </span>
                                                    </td>
                                                    <td>@product.Unit</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn-primary"><i class="fas fa-save"></i> @(Model.Language == "ru" ? "Сохранить изменения" : Model.Language == "en" ? "Save changes" : "Өзгерістерді сақтау")</button>
                                <a asp-page="Index" class="btn-secondary"><i class="fas fa-times"></i> @(Model.Language == "ru" ? "Отмена" : Model.Language == "en" ? "Cancel" : "Бас тарту")</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;

            if (menuToggle) {
                menuToggle.addEventListener('click', () => body.classList.toggle('sidebar-open'));

                document.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(e.target) && !menuToggle.contains(e.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            const themeToggle = document.getElementById('themeToggle');
            if (themeToggle) {
                const themeIcon = themeToggle.querySelector('i');
                const savedTheme = localStorage.getItem('theme') || '@Model.Theme';

                if (savedTheme === 'dark') {
                    body.classList.add('dark-theme');
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                }

                themeToggle.addEventListener('click', () => {
                    body.classList.toggle('dark-theme');
                    if (body.classList.contains('dark-theme')) {
                        themeIcon.classList.remove('fa-sun');
                        themeIcon.classList.add('fa-moon');
                        localStorage.setItem('theme', 'dark');
                    } else {
                        themeIcon.classList.remove('fa-moon');
                        themeIcon.classList.add('fa-sun');
                        localStorage.setItem('theme', 'light');
                    }
                });
            }

            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 500);
                }, 5000);
            });

            const searchInput = document.getElementById('productSearch');
            if (searchInput) {
                searchInput.addEventListener('keyup', function() {
                    const term = this.value.toLowerCase();
                    document.querySelectorAll('.product-row').forEach(row => {
                        const name = row.getAttribute('data-name') || '';
                        const article = row.getAttribute('data-article') || '';
                        row.style.display = (name.includes(term) || article.includes(term)) ? '' : 'none';
                    });
                });
            }

            const selectAll = document.getElementById('selectAll');
            if (selectAll) {
                selectAll.addEventListener('change', function() {
                    document.querySelectorAll('.product-checkbox:visible').forEach(cb => {
                        if (cb.closest('tr').style.display !== 'none') {
                            cb.checked = selectAll.checked;
                        }
                    });
                });

                document.querySelectorAll('.product-checkbox').forEach(cb => {
                    cb.addEventListener('change', function() {
                        const visible = document.querySelectorAll('.product-checkbox:visible');
                        const checked = document.querySelectorAll('.product-checkbox:visible:checked');
                        selectAll.checked = visible.length === checked.length;
                        selectAll.indeterminate = checked.length > 0 && checked.length < visible.length;
                    });
                });
            }
        });
    </script>
</body>
</html>