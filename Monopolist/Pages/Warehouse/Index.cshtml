@page
@model Monoplist.Pages.Warehouse.IndexModel
@{
    Layout = null;
    ViewData["Title"] = "Склады";
    var userName = User.Identity?.Name ?? "Пользователь";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ===== ОБЩИЕ ПЕРЕМЕННЫЕ (как были) ===== */
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-lg: 0 8px 24px rgba(255,107,0,0.15);
            --shadow-hover: 0 12px 28px rgba(255,215,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        /* ===== САЙДБАР ===== */
        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        /* ===== ОСНОВНОЙ КОНТЕНТ ===== */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

            .user-info span {
                font-weight: 500;
                color: var(--text-secondary);
            }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .btn-logout {
            background: none;
            border: 2px solid var(--accent);
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            color: var(--text-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

            .btn-logout:hover {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-color: transparent;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(255,107,0,0.3);
            }

                .btn-logout:hover i {
                    color: white;
                }

        .content {
            padding: 16px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 16px;
            box-shadow: var(--shadow-md);
        }

        .subtitle {
            color: var(--primary);
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: 18px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 10px;
        }

        /* ===== ПАНЕЛЬ ПОИСКА ===== */
        .action-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .search-form {
            display: flex;
            align-items: center;
            gap: 8px;
            flex: 1;
            max-width: 420px;
        }

        .search-input {
            flex: 1;
            padding: 9px 14px;
            border: 2px solid var(--border);
            border-radius: 30px;
            font-size: 0.95rem;
            transition: var(--transition);
            background: var(--surface);
            color: var(--text-primary);
        }

            .search-input:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
            }

        .search-btn, .reset-btn {
            padding: 9px 18px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }

        .search-btn {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 10px rgba(255,107,0,0.3);
        }

            .search-btn:hover {
                background: var(--primary-dark);
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
            }

        .reset-btn {
            background: var(--surface);
            color: var(--text-secondary);
            border: 2px solid var(--border);
        }

            .reset-btn:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
            }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            padding: 9px 18px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            transition: var(--transition);
            box-shadow: 0 4px 10px rgba(255,107,0,0.3);
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
                color: white;
            }

        /* ===== СЕТКА КАРТОЧЕК ===== */
        .warehouse-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 24px;
            margin-top: 20px;
        }

        .warehouse-card {
            background: var(--surface);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow-md);
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            border-left: 4px solid var(--accent);
        }

            .warehouse-card:hover {
                transform: translateY(-6px);
                box-shadow: var(--shadow-hover);
            }

        .warehouse-image {
            height: 180px;
            background-color: var(--surface-hover);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            font-size: 3.5rem;
            border-bottom: 2px solid var(--accent);
            overflow: hidden;
        }

            .warehouse-image img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.3s;
            }

            .warehouse-image:hover img {
                transform: scale(1.05);
            }

        .warehouse-content {
            padding: 18px;
            flex: 1;
        }

        .warehouse-name {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 8px;
        }

        .warehouse-location {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .warehouse-stats {
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-bottom: 12px;
        }

        .progress-bar {
            height: 10px;
            background: var(--border);
            border-radius: 5px;
            overflow: hidden;
            margin-bottom: 16px;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--accent));
            border-radius: 5px;
            transition: width 0.3s;
        }

        .products-preview {
            background: var(--surface-hover);
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 16px;
            border-left: 3px solid var(--accent);
        }

        .products-preview-title {
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        .products-preview-list {
            list-style: none;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

            .products-preview-list li {
                padding: 4px 0;
                border-bottom: 1px dashed var(--border);
            }

                .products-preview-list li:last-child {
                    border-bottom: none;
                }

        .warehouse-actions {
            display: flex;
            gap: 8px;
            padding: 16px 18px;
            border-top: 1px solid var(--border);
            background: var(--surface-hover);
        }

        .btn-sm {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            color: white;
            text-decoration: none;
            transition: var(--transition);
            font-size: 1rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

            .btn-sm.btn-info {
                background: #3b82f6;
            }

            .btn-sm.btn-primary {
                background: var(--primary);
            }

            .btn-sm.btn-danger {
                background: var(--danger);
            }

            .btn-sm:hover {
                transform: translateY(-2px) scale(1.05);
                filter: brightness(1.1);
                box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            }

        .text-muted {
            color: var(--text-muted);
            font-style: italic;
            padding: 18px;
            text-align: center;
            font-size: 0.9rem;
        }

        /* ===== АДАПТИВНОСТЬ ===== */
        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                top: 0;
                bottom: 0;
                transform: translateX(-100%);
                box-shadow: none;
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
                box-shadow: 2px 0 15px rgba(0,0,0,0.2);
            }

            .menu-toggle {
                display: block;
            }

            .main-content {
                width: 100%;
            }

            .top-bar {
                padding: 12px 16px;
            }

            .page-title {
                font-size: 1.25rem;
            }

            .user-info span {
                display: none;
            }

            .content {
                padding: 12px;
            }

            .dashboard {
                padding: 12px;
            }

            .action-bar {
                flex-direction: column;
                align-items: stretch;
            }

            .search-form {
                max-width: 100%;
            }

            .btn-primary {
                width: 100%;
                justify-content: center;
            }

            .warehouse-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .btn-logout {
                padding: 8px 12px;
            }
        }
    </style>
</head>
<body>
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> Главная панель</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> Каталог товаров</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> Продажи</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> Клиенты</a></li>
                    <li><a asp-page="/Warehouse/Index" class="active"><i class="fas fa-warehouse"></i> Склад</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> Поставщики</a></li>
                    <li><a asp-page="/Reports/Index"><i class="fas fa-chart-line"></i> Отчеты</a></li>
                    <li><a asp-page="/Settings/Index"><i class="fas fa-cog"></i> Настройки</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <span><i class="fas fa-user-circle"></i> @userName</span>
                    <div class="theme-toggle" id="themeToggle" title="Сменить тему">
                        <i class="fas fa-sun"></i>
                    </div>
                    <form method="post" asp-page="/Account/Logout" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Выйти</span>
                        </button>
                    </form>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    <h1 class="subtitle">Управление складами</h1>

                    <div class="action-bar">
                        <form method="get" class="search-form">
                            <input type="text" class="search-input" name="searchString" placeholder="Поиск по названию, местоположению..." value="@Model.SearchString" />
                            <button type="submit" class="search-btn"><i class="fas fa-search"></i> Найти</button>
                            @if (!string.IsNullOrEmpty(Model.SearchString))
                            {
                                <a asp-page="Index" class="reset-btn"><i class="fas fa-times"></i> Сброс</a>
                            }
                        </form>

                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <a asp-page="Create" class="btn-primary">
                                <i class="fas fa-plus"></i> Добавить склад
                            </a>
                        }
                    </div>

                    @if (Model.Warehouses.Any())
                    {
                        <div class="warehouse-grid">
                            @foreach (var warehouse in Model.Warehouses)
                            {
                                var occupancyPercent = warehouse.Capacity > 0 ? (int)((double)warehouse.CurrentOccupancy / warehouse.Capacity * 100) : 0;
                                occupancyPercent = occupancyPercent > 100 ? 100 : occupancyPercent;

                                <div class="warehouse-card">
                                    <div class="warehouse-image">
                                        @if (!string.IsNullOrEmpty(warehouse.ImageUrl))
                                        {
                                            <img src="@warehouse.ImageUrl" alt="@warehouse.Name" />
                                        }
                                        else
                                        {
                                            <i class="fas fa-warehouse"></i>
                                        }
                                    </div>
                                    <div class="warehouse-content">
                                        <div class="warehouse-name">@warehouse.Name</div>
                                        <div class="warehouse-location">
                                            <i class="fas fa-map-marker-alt"></i> @(warehouse.Location ?? "Местоположение не указано")
                                        </div>
                                        <div class="warehouse-stats">
                                            <span><i class="fas fa-boxes"></i> @warehouse.CurrentOccupancy / @warehouse.Capacity ед.</span>
                                            <span><i class="fas fa-tag"></i> @warehouse.ProductsCount товаров</span>
                                        </div>
                                        <div class="progress-bar">
                                            <div class="progress-fill" style="width: @occupancyPercent%;"></div>
                                        </div>

                                        @if (warehouse.ProductNames.Any())
                                        {
                                            <div class="products-preview">
                                                <div class="products-preview-title">
                                                    <i class="fas fa-cubes"></i> Товары на складе:
                                                </div>
                                                <ul class="products-preview-list">
                                                    @foreach (var productName in warehouse.ProductNames)
                                                    {
                                                        <li>• @productName</li>
                                                    }
                                                    @if (warehouse.ProductsCount > 3)
                                                    {
                                                        <li><em>и еще @(warehouse.ProductsCount - 3) товаров...</em></li>
                                                    }
                                                </ul>
                                            </div>
                                        }

                                        @if (!string.IsNullOrEmpty(warehouse.Description))
                                        {
                                            <p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 10px;">
                                                @warehouse.Description
                                            </p>
                                        }
                                    </div>
                                    <div class="warehouse-actions">
                                        <a asp-page="Details" asp-route-id="@warehouse.Id" class="btn-sm btn-info" title="Просмотр">
                                            <i class="fas fa-info-circle"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                        {
                                            <a asp-page="Edit" asp-route-id="@warehouse.Id" class="btn-sm btn-primary" title="Редактировать">
                                                <i class="fas fa-pencil-alt"></i>
                                            </a>
                                            <a asp-page="Delete" asp-route-id="@warehouse.Id" class="btn-sm btn-danger" title="Удалить">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Склады не найдены. @if (User.IsInRole("Admin") || User.IsInRole("Manager")) {
                        <span><a asp-page="Create">Добавьте первый склад</a>.</span>
                    }
</p>
                                        }
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;

            if (menuToggle) {
                menuToggle.addEventListener('click', function() {
                    body.classList.toggle('sidebar-open');
                });

                document.addEventListener('click', function(event) {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(event.target) && !menuToggle.contains(event.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = themeToggle.querySelector('i');

            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                themeIcon.classList.remove('fa-sun');
                themeIcon.classList.add('fa-moon');
            }

            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });
        });
    </script>
</body>
</html>