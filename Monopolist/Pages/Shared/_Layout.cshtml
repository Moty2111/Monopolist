<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Информационная система для магазина строительных материалов Моноплист" />
    <title>@ViewData["Title"] - Моноплист</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        :root {
            --theme-primary: #FF6B00;
            --theme-secondary: #FFD700;
            --theme-bg: #f8fafc;
            --theme-text: #0f172a;
        }

        [data-theme="dark"] {
            --theme-bg: #1a202c;
            --theme-text: #e2e8f0;
        }
    </style>
</head>
<body data-theme="light">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="app">
            @await Html.PartialAsync("_Sidebar")
            <main class="main-content" aria-label="Основное содержимое">
                <header class="top-bar" aria-label="Верхняя панель">
                    <button class="menu-toggle" id="sidebarToggle" aria-label="Открыть меню">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div class="page-title">@ViewData["Title"]</div>
                    <div class="user-info">
                        <span class="user-name">@User.Identity?.Name</span>
                        <form method="post" asp-page="/Account/Logout" class="logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-logout" aria-label="Выйти из системы">
                                <i class="fas fa-sign-out-alt" aria-hidden="true"></i>
                                <span class="logout-text">Выйти</span>
                            </button>
                        </form>
                    </div>
                </header>
                <div class="content">
                    @RenderBody()
                </div>
            </main>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const toggleBtn = document.getElementById('sidebarToggle');
                const sidebar = document.querySelector('.sidebar');
                const body = document.body;
                if (toggleBtn && sidebar) {
                    toggleBtn.addEventListener('click', function() {
                        body.classList.toggle('sidebar-open');
                        toggleBtn.setAttribute('aria-expanded', body.classList.contains('sidebar-open'));
                    });
                }
            });
        </script>
    }
    else
    {
        <main class="login-layout" aria-label="Страница входа">
            @RenderBody()
        </main>
    }
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        function toggleTheme() {
            const body = document.body;
            const currentTheme = body.getAttribute('data-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            body.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
        }
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.body.setAttribute('data-theme', savedTheme);
    </script>
</body>
</html>