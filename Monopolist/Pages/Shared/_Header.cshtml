@using System.Security.Claims
@{
    var userName = User.Identity?.Name ?? "Пользователь";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "User";
    var avatarUrl = Context.Request.Cookies[$"user_avatar_{User.FindFirst("UserId")?.Value}"] ?? "";
    var theme = Context.Request.Cookies["theme"] ?? "light";
}

<header class="top-bar">
    <button class="menu-toggle" id="menuToggle">
        <i class="fas fa-bars"></i>
    </button>
    <h1 class="page-title">@ViewData["Title"]</h1>
    <div class="user-info">
        <div class="theme-toggle" id="themeToggle" title="Сменить тему">
            <i class="fas fa-sun"></i>
        </div>
        <div class="user-profile" onclick="toggleUserMenu()">
            <div class="user-avatar">
                @if (!string.IsNullOrEmpty(avatarUrl))
                {
                    <img src="@avatarUrl" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user-circle\'></i>';" />
                }
                else
                {
                    <i class="fas fa-user-circle"></i>
                }
            </div>
            <div class="user-details">
                <span class="user-name">@userName</span>
                <span class="user-role">@userRole</span>
            </div>
            <i class="fas fa-chevron-down"></i>
        </div>
        <div class="user-menu" id="userMenu">
            <a asp-page="/Settings/Profile" class="menu-item">
                <i class="fas fa-user"></i> Профиль
            </a>
            <a asp-page="/Settings/Security" class="menu-item">
                <i class="fas fa-shield-alt"></i> Безопасность
            </a>
            <a asp-page="/Settings/Appearance" class="menu-item">
                <i class="fas fa-palette"></i> Внешний вид
            </a>
            <div class="menu-divider"></div>
            <form method="post" asp-page="/Account/Logout" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="menu-item logout">
                    <i class="fas fa-sign-out-alt"></i> Выйти
                </button>
            </form>
        </div>
    </div>
</header>

<style>
    .user-info {
        position: relative;
        cursor: pointer;
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 12px;
        background: var(--surface-hover);
        border-radius: 40px;
        transition: var(--transition);
    }

        .user-profile:hover {
            background: var(--surface);
            box-shadow: var(--shadow-sm);
        }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        overflow: hidden;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

        .user-avatar i {
            font-size: 40px;
        }

        .user-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .user-details {
        display: flex;
        flex-direction: column;
    }

    .user-name {
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.2;
    }

    .user-role {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .user-menu {
        position: absolute;
        top: calc(100% + 10px);
        right: 0;
        width: 220px;
        background: var(--surface);
        border-radius: 12px;
        box-shadow: var(--shadow-hover);
        border: 1px solid var(--border);
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.2s ease;
        z-index: 1000;
    }

        .user-menu.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        color: var(--text-secondary);
        text-decoration: none;
        transition: var(--transition);
        width: 100%;
        text-align: left;
        border: none;
        background: none;
        font-size: 0.95rem;
        cursor: pointer;
    }

        .menu-item:hover {
            background: var(--surface-hover);
            color: var(--primary);
        }

        .menu-item.logout {
            color: var(--danger);
        }

            .menu-item.logout:hover {
                background: var(--danger-bg);
            }

    .menu-divider {
        height: 1px;
        background: var(--border);
        margin: 8px 0;
    }
</style>

<script>
    function toggleUserMenu() {
        const menu = document.getElementById('userMenu');
        menu.classList.toggle('show');
    }

    document.addEventListener('click', function(event) {
        const userInfo = document.querySelector('.user-info');
        const userMenu = document.getElementById('userMenu');

        if (!userInfo.contains(event.target) && userMenu.classList.contains('show')) {
            userMenu.classList.remove('show');
        }
    });
</script>