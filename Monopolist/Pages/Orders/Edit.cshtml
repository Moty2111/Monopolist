@page
@model Monoplist.Pages.Orders.EditModel
@{
    Layout = null;
    ViewData["Title"] = Model.Language == "ru" ? "Редактирование заказа" : (Model.Language == "en" ? "Edit order" : "Тапсырысты өңдеу");
    var userId = User.FindFirst("UserId")?.Value;
    var avatarUrl = HttpContext.Request.Cookies[$"user_avatar_{userId}"] ?? "";
}

<!DOCTYPE html>
<html lang="@Model.Language">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* Стили полностью совпадают с Create.cshtml, можно скопировать оттуда */
        :root {
            --primary: @Model.CustomColor;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.25);
            --success: #10b981;
            --success-bg: #d1fae5;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
            --warning: #f59e0b;
            --warning-bg: #fed7aa;
            --info: #3b82f6;
            --info-bg: #dbeafe;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
            --info-bg: #1e3a5f;
        }

        body.compact-mode .sidebar {
            width: 240px;
        }

        body.compact-mode .sidebar-header {
            padding: 16px 16px;
        }

            body.compact-mode .sidebar-header i {
                font-size: 32px;
            }

            body.compact-mode .sidebar-header h2 {
                font-size: 20px;
            }

        body.compact-mode .sidebar-nav li a {
            padding: 8px 12px;
        }

        body.compact-mode .top-bar {
            padding: 12px 24px;
        }

        body.compact-mode .dashboard {
            padding: 16px;
        }

            body.compact-mode .dashboard h1 {
                font-size: 1.8rem;
            }

        body.compact-mode .subtitle {
            font-size: 0.9rem;
            margin-bottom: 16px;
        }

        body.compact-mode .form-group {
            margin-bottom: 1rem;
        }

        body.compact-mode .form-control {
            padding: 8px 12px;
        }

        body.compact-mode .btn-primary,
        body.compact-mode .btn-secondary {
            padding: 8px 18px;
        }

        body.compact-mode .items-table th,
        body.compact-mode .items-table td {
            padding: 6px 4px;
        }

        body.no-animations * {
            transition: none !important;
            animation: none !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
            position: relative;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            background: var(--surface-hover);
            border-radius: 40px;
            transition: var(--transition);
            cursor: pointer;
        }

            .user-profile:hover {
                background: var(--surface);
                box-shadow: var(--shadow-sm);
            }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

            .user-avatar i {
                font-size: 40px;
            }

            .user-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .user-details {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .user-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .user-menu {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 220px;
            background: var(--surface);
            border-radius: 12px;
            box-shadow: var(--shadow-hover);
            border: 1px solid var(--border);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.2s ease;
            z-index: 1000;
        }

            .user-menu.show {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
            width: 100%;
            text-align: left;
            border: none;
            background: none;
            font-size: 0.95rem;
            cursor: pointer;
        }

            .menu-item:hover {
                background: var(--surface-hover);
                color: var(--primary);
            }

            .menu-item.logout {
                color: var(--danger);
            }

                .menu-item.logout:hover {
                    background: var(--danger-bg);
                }

        .menu-divider {
            height: 1px;
            background: var(--border);
            margin: 8px 0;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .content {
            padding: 24px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 24px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 2rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 8px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 24px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 12px;
        }

        .alert {
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: var(--success-bg);
            color: var(--success);
            border-left: 4px solid var(--success);
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger);
            border-left: 4px solid var(--danger);
        }

        .form-container {
            max-width: 1000px;
        }

        .form-row {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        .form-group {
            flex: 1 1 200px;
            margin-bottom: 1.2rem;
        }

            .form-group label {
                display: block;
                font-weight: 600;
                font-size: 0.9rem;
                color: var(--primary);
                margin-bottom: 5px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            font-size: 1rem;
            border: 2px solid var(--border);
            border-radius: 12px;
            background: var(--surface);
            color: var(--text-primary);
            transition: var(--transition);
            font-family: 'Poppins', sans-serif;
        }

            .form-control:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
            }

        select.form-control {
            appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%23FF6B00' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 1em;
        }

        .text-danger {
            color: var(--danger);
            font-size: 0.85rem;
            margin-top: 4px;
            display: block;
        }

        .items-section {
            margin-top: 30px;
            border-top: 2px solid var(--accent);
            padding-top: 20px;
        }

            .items-section h3 {
                color: var(--primary);
                font-size: 1.3rem;
                margin-bottom: 15px;
            }

        .add-item-row {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            align-items: flex-end;
        }

        .btn-add {
            background: var(--success);
            color: white;
            border: none;
            border-radius: 30px;
            padding: 10px 20px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

            .btn-add:hover {
                transform: translateY(-2px);
                filter: brightness(1.1);
                box-shadow: 0 4px 10px rgba(16,185,129,0.4);
            }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

            .items-table th {
                background: var(--surface-hover);
                padding: 12px 8px;
                text-align: left;
                font-weight: 600;
                color: var(--primary);
                border-bottom: 2px solid var(--accent);
            }

            .items-table td {
                padding: 10px 8px;
                border-bottom: 1px solid var(--border);
                color: var(--text-secondary);
            }

            .items-table tbody tr:hover {
                background: rgba(255,107,0,0.05);
            }

        .btn-remove {
            background: var(--danger);
            color: white;
            border: none;
            border-radius: 6px;
            width: 30px;
            height: 30px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-remove:hover {
                transform: scale(1.1);
                filter: brightness(1.1);
            }

        .total-row {
            font-weight: 700;
            background: var(--surface-hover);
        }

            .total-row td {
                color: var(--primary);
            }

        .form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .btn-primary, .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
            }

        .btn-secondary {
            background: var(--surface);
            color: var(--text-secondary);
            border: 2px solid var(--border);
        }

            .btn-secondary:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
                transform: translateY(-2px);
            }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                top: 0;
                bottom: 0;
                transform: translateX(-100%);
                box-shadow: none;
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
                box-shadow: 2px 0 15px rgba(0,0,0,0.2);
            }

            .menu-toggle {
                display: block;
            }

            .main-content {
                width: 100%;
            }

            .top-bar {
                padding: 12px 16px;
            }

            .page-title {
                font-size: 1.25rem;
            }

            .user-profile .user-details {
                display: none;
            }

            .content {
                padding: 16px;
            }

            .dashboard {
                padding: 16px;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-primary, .btn-secondary {
                width: 100%;
                justify-content: center;
            }

            .add-item-row {
                flex-direction: column;
                align-items: stretch;
            }

            .items-table {
                font-size: 0.8rem;
            }

                .items-table th, .items-table td {
                    padding: 6px 4px;
                }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .btn-logout {
                padding: 8px 12px;
            }
        }
    </style>
</head>
<body class="@(Model.Theme == "dark" ? "dark-theme" : "") @(Model.CompactMode ? "compact-mode" : "") @(Model.Animations ? "" : "no-animations")">
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> @(Model.Language == "ru" ? "Главная панель" : Model.Language == "en" ? "Dashboard" : "Бас панель")</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> @(Model.Language == "ru" ? "Каталог товаров" : Model.Language == "en" ? "Products" : "Тауарлар каталогы")</a></li>
                    <li><a asp-page="/Orders/Index" class="active"><i class="fas fa-shopping-cart"></i> @(Model.Language == "ru" ? "Продажи" : Model.Language == "en" ? "Orders" : "Сатулар")</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> @(Model.Language == "ru" ? "Клиенты" : Model.Language == "en" ? "Customers" : "Клиенттер")</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> @(Model.Language == "ru" ? "Склад" : Model.Language == "en" ? "Warehouse" : "Қойма")</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> @(Model.Language == "ru" ? "Поставщики" : Model.Language == "en" ? "Suppliers" : "Жеткізушілер")</a></li>
                    <li><a asp-page="/Reports/Index"><i class="fas fa-chart-line"></i> @(Model.Language == "ru" ? "Отчеты" : Model.Language == "en" ? "Reports" : "Есептер")</a></li>
                    <li><a asp-page="/Settings/Index"><i class="fas fa-cog"></i> @(Model.Language == "ru" ? "Настройки" : Model.Language == "en" ? "Settings" : "Баптаулар")</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <div class="theme-toggle" id="themeToggle" title="@(Model.Language == "ru" ? "Сменить тему" : Model.Language == "en" ? "Toggle theme" : "Тақырыпты ауыстыру")">
                        <i class="fas fa-sun"></i>
                    </div>
                    <div class="user-profile" onclick="toggleUserMenu()">
                        <div class="user-avatar">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user-circle\'></i>';" />
                            }
                            else
                            {
                                <i class="fas fa-user-circle"></i>
                            }
                        </div>
                        <div class="user-details">
                            <span class="user-name">@User.Identity?.Name</span>
                            <span class="user-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</span>
                        </div>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-menu" id="userMenu">
                        <a asp-page="/Settings/Profile" class="menu-item"><i class="fas fa-user"></i> @(Model.Language == "ru" ? "Профиль" : Model.Language == "en" ? "Profile" : "Профиль")</a>
                        <a asp-page="/Settings/Security" class="menu-item"><i class="fas fa-shield-alt"></i> @(Model.Language == "ru" ? "Безопасность" : Model.Language == "en" ? "Security" : "Қауіпсіздік")</a>
                        <a asp-page="/Settings/Appearance" class="menu-item"><i class="fas fa-palette"></i> @(Model.Language == "ru" ? "Внешний вид" : Model.Language == "en" ? "Appearance" : "Сыртқы түр")</a>
                        <div class="menu-divider"></div>
                        <form method="post" asp-page="/Account/Logout" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="menu-item logout"><i class="fas fa-sign-out-alt"></i> @(Model.Language == "ru" ? "Выйти" : Model.Language == "en" ? "Logout" : "Шығу")</button>
                        </form>
                    </div>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
                    }

                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">@(Model.Language == "ru" ? "Измените данные заказа и товары" : Model.Language == "en" ? "Edit order details and products" : "Тапсырыс деректері мен тауарларды өзгертіңіз")</p>

                    <div class="form-container">
                        <form method="post" id="orderForm">
                            <input type="hidden" asp-for="Order.Id" />
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="Order.CustomerId">@(Model.Language == "ru" ? "Клиент" : Model.Language == "en" ? "Customer" : "Клиент")</label>
                                    <select asp-for="Order.CustomerId" asp-items="Model.Customers" class="form-control">
                                        <option value="">@(Model.Language == "ru" ? "-- Выберите клиента --" : Model.Language == "en" ? "-- Select customer --" : "-- Клиентті таңдаңыз --")</option>
                                    </select>
                                    <span asp-validation-for="Order.CustomerId" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label asp-for="Order.Status">@(Model.Language == "ru" ? "Статус" : Model.Language == "en" ? "Status" : "Мәртебе")</label>
                                    <select asp-for="Order.Status" asp-items="Model.Statuses" class="form-control"></select>
                                    <span asp-validation-for="Order.Status" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label asp-for="Order.PaymentMethod">@(Model.Language == "ru" ? "Способ оплаты" : Model.Language == "en" ? "Payment method" : "Төлем тәсілі")</label>
                                    <select asp-for="Order.PaymentMethod" asp-items="Model.PaymentMethods" class="form-control">
                                        <option value="">@(Model.Language == "ru" ? "-- Не выбрано --" : Model.Language == "en" ? "-- Not selected --" : "-- Таңдалмаған --")</option>
                                    </select>
                                    <span asp-validation-for="Order.PaymentMethod" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="items-section">
                                <h3><i class="fas fa-boxes"></i> @(Model.Language == "ru" ? "Товары в заказе" : Model.Language == "en" ? "Order items" : "Тапсырыстағы тауарлар")</h3>

                                <div class="add-item-row">
                                    <select id="productSelect" class="form-control" style="flex: 2;">
                                        <option value="">@(Model.Language == "ru" ? "-- Выберите товар --" : Model.Language == "en" ? "-- Select product --" : "-- Тауарды таңдаңыз --")</option>
                                        @foreach (var p in Model.Order.AvailableProducts)
                                        {
                                            <option value="@p.Value" data-price="@p.Price" data-unit="@p.Unit">@p.Text</option>
                                        }
                                    </select>
                                    <input type="number" id="quantityInput" class="form-control" style="flex: 0.5;" min="1" value="1" placeholder="@(Model.Language == "ru" ? "Кол-во" : Model.Language == "en" ? "Qty" : "Саны")" />
                                    <button type="button" class="btn-add" onclick="addItem()"><i class="fas fa-plus"></i> @(Model.Language == "ru" ? "Добавить" : Model.Language == "en" ? "Add" : "Қосу")</button>
                                </div>

                                <table class="items-table" id="itemsTable">
                                    <thead>
                                        <tr>
                                            <th>@(Model.Language == "ru" ? "Товар" : Model.Language == "en" ? "Product" : "Тауар")</th>
                                            <th>@(Model.Language == "ru" ? "Количество" : Model.Language == "en" ? "Quantity" : "Саны")</th>
                                            <th>@(Model.Language == "ru" ? "Цена" : Model.Language == "en" ? "Price" : "Бағасы")</th>
                                            <th>@(Model.Language == "ru" ? "Сумма" : Model.Language == "en" ? "Total" : "Сома")</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody id="itemsBody">
                                        @for (int i = 0; i < Model.Order.Items.Count; i++)
                                        {
                                            <tr>
                                                <td>
                                                    <input type="hidden" name="Order.Items[@i].ProductId" value="@Model.Order.Items[i].ProductId" />
                                                    <input type="hidden" name="Order.Items[@i].ProductName" value="@Model.Order.Items[i].ProductName" />
                                                    @Model.Order.Items[i].ProductName
                                                </td>
                                                <td>
                                                    <input type="number" name="Order.Items[@i].Quantity" value="@Model.Order.Items[i].Quantity" min="1" class="form-control" style="width: 80px;" onchange="updateTotal()" />
                                                </td>
                                                <td>
                                                    <input type="hidden" name="Order.Items[@i].Price" value="@Model.Order.Items[i].Price" />
                                                    @Model.Order.Items[i].Price.ToString("N0") ₽
                                                </td>
                                                <td class="item-total">@Model.Order.Items[i].Total.ToString("N0") ₽</td>
                                                <td>
                                                    <button type="button" class="btn-remove" onclick="removeItem(this)"><i class="fas fa-trash"></i></button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr class="total-row">
                                            <td colspan="3" style="text-align: right;">@(Model.Language == "ru" ? "Итого:" : Model.Language == "en" ? "Total:" : "Барлығы:")</td>
                                            <td id="grandTotal">@Model.Order.Items.Sum(i => i.Total).ToString("N0") ₽</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                                <input type="hidden" asp-for="Order.TotalAmount" id="totalAmountHidden" />
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn-primary"><i class="fas fa-save"></i> @(Model.Language == "ru" ? "Сохранить" : Model.Language == "en" ? "Save" : "Сақтау")</button>
                                <a asp-page="Index" class="btn-secondary"><i class="fas fa-times"></i> @(Model.Language == "ru" ? "Отмена" : Model.Language == "en" ? "Cancel" : "Бас тарту")</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script>
        // Глобальные переменные для хранения данных о товарах
        const availableProducts = @Html.Raw(Json.Serialize(Model.Order.AvailableProducts));
        let itemIndex = @Model.Order.Items.Count;

        function addItem() {
            const select = document.getElementById('productSelect');
            const quantity = parseInt(document.getElementById('quantityInput').value);
            const selectedOption = select.options[select.selectedIndex];

            if (!selectedOption.value) {
                alert('@(Model.Language == "ru" ? "Выберите товар" : Model.Language == "en" ? "Select a product" : "Тауарды таңдаңыз")');
                return;
            }
            if (quantity < 1) {
                alert('@(Model.Language == "ru" ? "Количество должно быть не менее 1" : Model.Language == "en" ? "Quantity must be at least 1" : "Саны кемінде 1 болуы керек")');
                return;
            }

            const productId = selectedOption.value;
            const productName = selectedOption.text.split(' (')[0];
            const price = parseFloat(selectedOption.dataset.price);

            // Проверка на дублирование
            const existingRows = document.querySelectorAll('#itemsBody tr');
            for (let row of existingRows) {
                const hiddenProductId = row.querySelector('input[name$=".ProductId"]');
                if (hiddenProductId && hiddenProductId.value === productId) {
                    alert('@(Model.Language == "ru" ? "Этот товар уже добавлен. Измените количество в существующей строке." : Model.Language == "en" ? "This product is already added. Change quantity in the existing row." : "Бұл тауар қосылған. Санын бар жолда өзгертіңіз.")');
                    return;
                }
            }

            const tbody = document.getElementById('itemsBody');
            const newRow = document.createElement('tr');
            newRow.innerHTML = `
                <td>
                    <input type="hidden" name="Order.Items[${itemIndex}].ProductId" value="${productId}" />
                    <input type="hidden" name="Order.Items[${itemIndex}].ProductName" value="${productName}" />
                    ${productName}
                </td>
                <td>
                    <input type="number" name="Order.Items[${itemIndex}].Quantity" value="${quantity}" min="1" class="form-control" style="width: 80px;" onchange="updateTotal()" />
                </td>
                <td>
                    <input type="hidden" name="Order.Items[${itemIndex}].Price" value="${price}" />
                    ${price.toLocaleString('ru-RU')} ₽
                </td>
                <td class="item-total">${(price * quantity).toLocaleString('ru-RU')} ₽</td>
                <td>
                    <button type="button" class="btn-remove" onclick="removeItem(this)"><i class="fas fa-trash"></i></button>
                </td>
            `;
            tbody.appendChild(newRow);
            itemIndex++;
            updateTotal();
        }

        function removeItem(btn) {
            const row = btn.closest('tr');
            row.remove();
            reindexItems();
            updateTotal();
        }

        function reindexItems() {
            const rows = document.querySelectorAll('#itemsBody tr');
            rows.forEach((row, index) => {
                const productIdInput = row.querySelector('input[name$=".ProductId"]');
                const productNameInput = row.querySelector('input[name$=".ProductName"]');
                const quantityInput = row.querySelector('input[name$=".Quantity"]');
                const priceInput = row.querySelector('input[name$=".Price"]');

                if (productIdInput) productIdInput.name = `Order.Items[${index}].ProductId`;
                if (productNameInput) productNameInput.name = `Order.Items[${index}].ProductName`;
                if (quantityInput) quantityInput.name = `Order.Items[${index}].Quantity`;
                if (priceInput) priceInput.name = `Order.Items[${index}].Price`;
            });
            itemIndex = rows.length;
        }

        function updateTotal() {
            let grandTotal = 0;
            const rows = document.querySelectorAll('#itemsBody tr');
            rows.forEach(row => {
                const quantityInput = row.querySelector('input[name$=".Quantity"]');
                const priceInput = row.querySelector('input[name$=".Price"]');
                if (quantityInput && priceInput) {
                    const quantity = parseInt(quantityInput.value) || 0;
                    const price = parseFloat(priceInput.value) || 0;
                    const total = quantity * price;
                    const totalCell = row.querySelector('.item-total');
                    if (totalCell) {
                        totalCell.textContent = total.toLocaleString('ru-RU') + ' ₽';
                    }
                    grandTotal += total;
                }
            });
            document.getElementById('grandTotal').textContent = grandTotal.toLocaleString('ru-RU') + ' ₽';
            document.getElementById('totalAmountHidden').value = grandTotal;
        }

        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;

            if (menuToggle) {
                menuToggle.addEventListener('click', () => body.classList.toggle('sidebar-open'));
                document.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(e.target) && !menuToggle.contains(e.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            const themeToggle = document.getElementById('themeToggle');
            if (themeToggle) {
                const themeIcon = themeToggle.querySelector('i');
                const savedTheme = localStorage.getItem('theme') || '@Model.Theme';
                if (savedTheme === 'dark') {
                    body.classList.add('dark-theme');
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                }
                themeToggle.addEventListener('click', () => {
                    body.classList.toggle('dark-theme');
                    if (body.classList.contains('dark-theme')) {
                        themeIcon.classList.remove('fa-sun');
                        themeIcon.classList.add('fa-moon');
                        localStorage.setItem('theme', 'dark');
                    } else {
                        themeIcon.classList.remove('fa-moon');
                        themeIcon.classList.add('fa-sun');
                        localStorage.setItem('theme', 'light');
                    }
                });
            }

            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 500);
                }, 5000);
            });

            document.querySelectorAll('input[name$=".Quantity"]').forEach(input => {
                input.addEventListener('change', updateTotal);
            });
        });

        function toggleUserMenu() {
            document.getElementById('userMenu').classList.toggle('show');
        }

        window.addEventListener('click', function(event) {
            const userInfo = document.querySelector('.user-info');
            const userMenu = document.getElementById('userMenu');
            if (!userInfo.contains(event.target) && userMenu.classList.contains('show')) {
                userMenu.classList.remove('show');
            }
        });
    </script>
</body>
</html>