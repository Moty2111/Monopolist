@page
@model Monoplist.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Заказы";
}
<div class="dashboard">
    <h1>@ViewData["Title"]</h1>
    <p class="subtitle">Управление продажами</p>

    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <p>
            <a asp-page="Create" class="btn-primary">
                <i class="fas fa-plus"></i> Создать заказ
            </a>
        </p>
    }

    @if (Model.Orders.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Номер</th>
                    <th>Клиент</th>
                    <th>Дата</th>
                    <th>Сумма</th>
                    <th>Статус</th>
                    <th>Оплата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td>@order.OrderNumber</td>
                        <td>@order.CustomerName</td>
                        <td>@order.OrderDate.ToShortDateString()</td>
                        <td>@order.TotalAmount.ToString("N0") ₽</td>
                        <td>
                            <span class="status-badge status-@order.Status.ToLower()">@order.Status</span>
                        </td>
                        <td>@order.PaymentMethod</td>
                        <td>
                            <a asp-page="Details" asp-route-id="@order.Id" class="btn-sm btn-info" title="Просмотр">
                                <i class="fas fa-info-circle"></i>
                            </a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                            {
                                <a asp-page="Edit" asp-route-id="@order.Id" class="btn-sm btn-primary" title="Редактировать">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-page="Delete" asp-route-id="@order.Id" class="btn-sm btn-danger" title="Удалить">
                                    <i class="fas fa-trash"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Нет заказов.</p>
    }
</div>