@page
@model Monoplist.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = $"Заказ {Model.Order.OrderNumber}";
}
<div class="dashboard">
    <h1>Заказ @Model.Order.OrderNumber</h1>
    <p class="subtitle">Детальная информация</p>

    <div class="details-container">
        <dl class="row">
            <dt class="col-sm-3">Клиент</dt>
            <dd class="col-sm-9">@Model.Order.CustomerName</dd>

            <dt class="col-sm-3">Телефон</dt>
            <dd class="col-sm-9">@Model.Order.CustomerPhone</dd>

            <dt class="col-sm-3">Дата заказа</dt>
            <dd class="col-sm-9">@Model.Order.OrderDate.ToString("dd.MM.yyyy HH:mm")</dd>

            <dt class="col-sm-3">Сумма</dt>
            <dd class="col-sm-9">@Model.Order.TotalAmount.ToString("N0") ₽</dd>

            <dt class="col-sm-3">Статус</dt>
            <dd class="col-sm-9">@Model.Order.Status</dd>

            <dt class="col-sm-3">Оплата</dt>
            <dd class="col-sm-9">@Model.Order.PaymentMethod</dd>
        </dl>

        <h2>Позиции заказа</h2>
        @if (Model.Order.Items.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Товар</th>
                        <th>Количество</th>
                        <th>Цена</th>
                        <th>Сумма</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Order.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>@item.Price.ToString("N0") ₽</td>
                            <td>@item.Total.ToString("N0") ₽</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Нет позиций.</p>
        }
    </div>

    <div class="form-actions">
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a asp-page="Edit" asp-route-id="@Model.Order.Id" class="btn-primary">Редактировать</a>
        }
        <a asp-page="Index" class="btn-secondary">Назад к списку</a>
    </div>
</div>