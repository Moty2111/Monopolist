@page
@model Monoplist.Pages.Reports.SalesReportModel
@{
    Layout = null;
    ViewData["Title"] = Model.Language == "ru" ? "Отчет по продажам" : (Model.Language == "en" ? "Sales report" : "Сату есебі");
    var userId = User.FindFirst("UserId")?.Value;
    var avatarUrl = HttpContext.Request.Cookies[$"user_avatar_{userId}"] ?? "";
}

<!DOCTYPE html>
<html lang="@Model.Language">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ru.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: @Model.CustomColor;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.25);
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
        }

        body.compact-mode .sidebar {
            width: 240px;
        }

        body.compact-mode .sidebar-header {
            padding: 16px;
        }

            body.compact-mode .sidebar-header i {
                font-size: 32px;
            }

            body.compact-mode .sidebar-header h2 {
                font-size: 20px;
            }

        body.compact-mode .sidebar-nav li a {
            padding: 8px 12px;
        }

        body.compact-mode .top-bar {
            padding: 12px 24px;
        }

        body.compact-mode .dashboard {
            padding: 16px;
        }

            body.compact-mode .dashboard h1 {
                font-size: 1.8rem;
            }

        body.compact-mode .subtitle {
            font-size: 0.9rem;
            margin-bottom: 16px;
        }

        body.compact-mode .filter-group input {
            padding: 8px 12px;
        }

        body.compact-mode .btn-primary, .btn-secondary {
            padding: 8px 18px;
        }

        body.no-animations * {
            transition: none !important;
            animation: none !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover, .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i, .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
            position: relative;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            background: var(--surface-hover);
            border-radius: 40px;
            transition: var(--transition);
            cursor: pointer;
        }

            .user-profile:hover {
                background: var(--surface);
                box-shadow: var(--shadow-sm);
            }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

            .user-avatar i {
                font-size: 40px;
            }

            .user-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .user-details {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .user-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .user-menu {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 220px;
            background: var(--surface);
            border-radius: 12px;
            box-shadow: var(--shadow-hover);
            border: 1px solid var(--border);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.2s ease;
            z-index: 1000;
        }

            .user-menu.show {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
            width: 100%;
            text-align: left;
            border: none;
            background: none;
            font-size: 0.95rem;
            cursor: pointer;
        }

            .menu-item:hover {
                background: var(--surface-hover);
                color: var(--primary);
            }

            .menu-item.logout {
                color: var(--danger);
            }

                .menu-item.logout:hover {
                    background: var(--danger-bg);
                }

        .menu-divider {
            height: 1px;
            background: var(--border);
            margin: 8px 0;
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .content {
            padding: 24px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 24px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 2rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 8px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 24px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 12px;
        }

        .alert {
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: var(--success-bg);
            color: var(--success);
            border-left: 4px solid var(--success);
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger);
            border-left: 4px solid var(--danger);
        }

        .filter-panel {
            background: var(--surface-hover);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 30px;
            border: 1px solid var(--border);
        }

        .filter-form {
            display: flex;
            gap: 20px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .date-range {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            flex: 2;
        }

        .filter-group {
            flex: 1;
            min-width: 200px;
        }

            .filter-group label {
                display: block;
                font-weight: 600;
                font-size: 0.85rem;
                color: var(--primary);
                margin-bottom: 6px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .filter-group input {
                width: 100%;
                padding: 12px 15px;
                border: 2px solid var(--border);
                border-radius: 12px;
                background: var(--surface);
                color: var(--text-primary);
                font-family: 'Poppins', sans-serif;
                font-size: 0.95rem;
                transition: var(--transition);
            }

                .filter-group input:focus {
                    outline: none;
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
                }

        .filter-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn-primary, .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            font-size: 0.95rem;
            text-decoration: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
            }

        .btn-secondary {
            background: var(--surface);
            color: var(--text-secondary);
            border: 2px solid var(--border);
        }

            .btn-secondary:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
                transform: translateY(-2px);
            }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .kpi-card {
            background: var(--surface-hover);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            border: 1px solid var(--border);
            border-left: 4px solid var(--primary);
        }

        .kpi-value {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--primary);
            line-height: 1.2;
        }

        .kpi-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .chart-card {
            background: var(--surface);
            border-radius: 16px;
            padding: 20px;
            border: 1px solid var(--border);
        }

            .chart-card h3 {
                font-size: 1.1rem;
                color: var(--primary);
                margin-bottom: 15px;
                font-weight: 600;
            }

        .chart-container {
            height: 300px;
            position: relative;
        }

        .table-responsive {
            overflow-x: auto;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--surface);
        }

            .data-table th {
                background: var(--surface-hover);
                padding: 12px 8px;
                text-align: left;
                font-weight: 600;
                color: var(--primary);
                border-bottom: 2px solid var(--accent);
            }

            .data-table td {
                padding: 10px 8px;
                border-bottom: 1px solid var(--border);
                color: var(--text-secondary);
            }

            .data-table tbody tr:hover {
                background: rgba(255,107,0,0.05);
            }

        .text-right {
            text-align: right;
        }

        .export-buttons {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .btn-export {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            transition: var(--transition);
            border: 2px solid transparent;
        }

        .btn-excel {
            background: #1D6F42;
            color: white;
        }

            .btn-excel:hover {
                background: #155a33;
                transform: translateY(-2px);
            }

        .btn-pdf {
            background: #F40F02;
            color: white;
        }

            .btn-pdf:hover {
                background: #c00c00;
                transform: translateY(-2px);
            }

        .btn-csv {
            background: #217346;
            color: white;
        }

            .btn-csv:hover {
                background: #1a5c38;
                transform: translateY(-2px);
            }

        .btn-word {
            background: #2B5797;
            color: white;
        }

            .btn-word:hover {
                background: #1e3f6f;
                transform: translateY(-2px);
            }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                transform: translateX(-100%);
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
            }

            .menu-toggle {
                display: block;
            }

            .main-content {
                width: 100%;
            }

            .top-bar {
                padding: 12px 16px;
            }

            .page-title {
                font-size: 1.25rem;
            }

            .user-profile .user-details {
                display: none;
            }

            .content {
                padding: 16px;
            }

            .charts-row {
                grid-template-columns: 1fr;
            }

            .filter-form {
                flex-direction: column;
                align-items: stretch;
            }

            .date-range {
                flex-direction: column;
            }

            .filter-group {
                width: 100%;
            }

            .export-buttons {
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .export-buttons {
                flex-direction: column;
            }

            .btn-export {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body class="@(Model.Theme == "dark" ? "dark-theme" : "") @(Model.CompactMode ? "compact-mode" : "") @(Model.Animations ? "" : "no-animations")">
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> @(Model.Language == "ru" ? "Главная панель" : Model.Language == "en" ? "Dashboard" : "Бас панель")</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> @(Model.Language == "ru" ? "Каталог товаров" : Model.Language == "en" ? "Products" : "Тауарлар каталогы")</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> @(Model.Language == "ru" ? "Продажи" : Model.Language == "en" ? "Orders" : "Сатулар")</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> @(Model.Language == "ru" ? "Клиенты" : Model.Language == "en" ? "Customers" : "Клиенттер")</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> @(Model.Language == "ru" ? "Склад" : Model.Language == "en" ? "Warehouse" : "Қойма")</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> @(Model.Language == "ru" ? "Поставщики" : Model.Language == "en" ? "Suppliers" : "Жеткізушілер")</a></li>
                    <li><a asp-page="/Reports/Index" class="active"><i class="fas fa-chart-line"></i> @(Model.Language == "ru" ? "Отчеты" : Model.Language == "en" ? "Reports" : "Есептер")</a></li>
                    <li><a asp-page="/Settings/Index"><i class="fas fa-cog"></i> @(Model.Language == "ru" ? "Настройки" : Model.Language == "en" ? "Settings" : "Баптаулар")</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <div class="theme-toggle" id="themeToggle" title="@(Model.Language == "ru" ? "Сменить тему" : Model.Language == "en" ? "Toggle theme" : "Тақырыпты ауыстыру")">
                        <i class="fas fa-sun"></i>
                    </div>
                    <div class="user-profile" onclick="toggleUserMenu()">
                        <div class="user-avatar">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Avatar" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fas fa-user-circle\'></i>';" />
                            }
                            else
                            {
                                <i class="fas fa-user-circle"></i>
                            }
                        </div>
                        <div class="user-details">
                            <span class="user-name">@User.Identity?.Name</span>
                            <span class="user-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</span>
                        </div>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-menu" id="userMenu">
                        <a asp-page="/Settings/Profile" class="menu-item"><i class="fas fa-user"></i> @(Model.Language == "ru" ? "Профиль" : Model.Language == "en" ? "Profile" : "Профиль")</a>
                        <a asp-page="/Settings/Security" class="menu-item"><i class="fas fa-shield-alt"></i> @(Model.Language == "ru" ? "Безопасность" : Model.Language == "en" ? "Security" : "Қауіпсіздік")</a>
                        <a asp-page="/Settings/Appearance" class="menu-item"><i class="fas fa-palette"></i> @(Model.Language == "ru" ? "Внешний вид" : Model.Language == "en" ? "Appearance" : "Сыртқы түр")</a>
                        <div class="menu-divider"></div>
                        <form method="post" asp-page="/Account/Logout" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="menu-item logout"><i class="fas fa-sign-out-alt"></i> @(Model.Language == "ru" ? "Выйти" : Model.Language == "en" ? "Logout" : "Шығу")</button>
                        </form>
                    </div>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
                    }

                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">@(Model.Language == "ru" ? "Анализ продаж за период" : Model.Language == "en" ? "Sales analysis for period" : "Кезеңдегі сату талдауы")</p>

                    <div class="filter-panel">
                        <form method="post" class="filter-form">
                            <div class="date-range">
                                <div class="filter-group">
                                    <label><i class="fas fa-calendar-alt"></i> @(Model.Language == "ru" ? "С" : Model.Language == "en" ? "From" : "Басталуы")</label>
                                    <input type="text" id="startDate" name="Report.StartDate" value="@Model.Report.StartDate.ToString("yyyy-MM-dd")" class="form-control datepicker" />
                                </div>
                                <div class="filter-group">
                                    <label><i class="fas fa-calendar-alt"></i> @(Model.Language == "ru" ? "По" : Model.Language == "en" ? "To" : "Аяқталуы")</label>
                                    <input type="text" id="endDate" name="Report.EndDate" value="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="form-control datepicker" />
                                </div>
                            </div>
                            <div class="filter-actions">
                                <button type="submit" class="btn-primary">
                                    <i class="fas fa-filter"></i> @(Model.Language == "ru" ? "Применить" : Model.Language == "en" ? "Apply" : "Қолдану")
                                </button>
                                <a asp-page="SalesReport" class="btn-secondary">
                                    <i class="fas fa-redo"></i> @(Model.Language == "ru" ? "Сброс" : Model.Language == "en" ? "Reset" : "Қалпына келтіру")
                                </a>
                            </div>
                        </form>
                    </div>

                    <div class="export-buttons">
                        <a asp-page="Export" asp-route-type="sales" asp-route-format="excel" asp-route-start="@Model.Report.StartDate.ToString("yyyy-MM-dd")" asp-route-end="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="btn-export btn-excel" target="_blank">
                            <i class="fas fa-file-excel"></i> Excel
                        </a>
                        <a asp-page="Export" asp-route-type="sales" asp-route-format="pdf" asp-route-start="@Model.Report.StartDate.ToString("yyyy-MM-dd")" asp-route-end="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="btn-export btn-pdf" target="_blank">
                            <i class="fas fa-file-pdf"></i> PDF
                        </a>
                        <a asp-page="Export" asp-route-type="sales" asp-route-format="csv" asp-route-start="@Model.Report.StartDate.ToString("yyyy-MM-dd")" asp-route-end="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="btn-export btn-csv" target="_blank">
                            <i class="fas fa-file-csv"></i> CSV
                        </a>
                        <a asp-page="Export" asp-route-type="sales" asp-route-format="word" asp-route-start="@Model.Report.StartDate.ToString("yyyy-MM-dd")" asp-route-end="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="btn-export btn-word" target="_blank">
                            <i class="fas fa-file-word"></i> Word
                        </a>
                    </div>

                    <div class="kpi-grid">
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.TotalRevenue.ToString("N0") ₽</div>
                            <div class="kpi-label">@(Model.Language == "ru" ? "Общая выручка" : Model.Language == "en" ? "Total revenue" : "Жалпы кіріс")</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.TotalOrders</div>
                            <div class="kpi-label">@(Model.Language == "ru" ? "Количество заказов" : Model.Language == "en" ? "Orders count" : "Тапсырыстар саны")</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.AverageOrderValue.ToString("N0") ₽</div>
                            <div class="kpi-label">@(Model.Language == "ru" ? "Средний чек" : Model.Language == "en" ? "Average order" : "Орташа чек")</div>
                        </div>
                    </div>

                    @if (Model.Report.DailySales.Any())
                    {
                        <div class="charts-row">
                            <div class="chart-card">
                                <h3><i class="fas fa-chart-line"></i> @(Model.Language == "ru" ? "Динамика продаж по дням" : Model.Language == "en" ? "Daily sales dynamics" : "Күнделікті сату динамикасы")</h3>
                                <div class="chart-container">
                                    <canvas id="dailySalesChart"></canvas>
                                </div>
                            </div>
                            <div class="chart-card">
                                <h3><i class="fas fa-chart-pie"></i> @(Model.Language == "ru" ? "Распределение по категориям" : Model.Language == "en" ? "Category distribution" : "Санаттар бойынша бөлу")</h3>
                                <div class="chart-container">
                                    <canvas id="categoryChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <div class="charts-row">
                            <div class="chart-card">
                                <h3><i class="fas fa-chart-bar"></i> @(Model.Language == "ru" ? "Продажи по способам оплаты" : Model.Language == "en" ? "Sales by payment method" : "Төлем тәсілдері бойынша сату")</h3>
                                <div class="chart-container">
                                    <canvas id="paymentChart"></canvas>
                                </div>
                            </div>
                            <div class="chart-card">
                                <h3><i class="fas fa-table"></i> @(Model.Language == "ru" ? "Детализация по категориям" : Model.Language == "en" ? "Category breakdown" : "Санаттар бойынша бөлшектеу")</h3>
                                <div class="table-responsive" style="height: 300px; overflow-y: auto;">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>@(Model.Language == "ru" ? "Категория" : Model.Language == "en" ? "Category" : "Санат")</th>
                                                <th class="text-right">@(Model.Language == "ru" ? "Продано (шт)" : Model.Language == "en" ? "Sold (pcs)" : "Сатылған (дана)")</th>
                                                <th class="text-right">@(Model.Language == "ru" ? "Сумма" : Model.Language == "en" ? "Amount" : "Сома")</th>
                                                <th class="text-right">@(Model.Language == "ru" ? "Доля" : Model.Language == "en" ? "Share" : "Үлес")</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var cat in Model.Report.CategorySales)
                                            {
                                                <tr>
                                                    <td>@cat.CategoryName</td>
                                                    <td class="text-right">@cat.ItemsSold</td>
                                                    <td class="text-right">@cat.TotalAmount.ToString("N0") ₽</td>
                                                    <td class="text-right">@cat.Percentage.ToString("F1")%</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <h3 style="margin: 30px 0 15px; color: var(--primary);">@(Model.Language == "ru" ? "Последние заказы" : Model.Language == "en" ? "Recent orders" : "Соңғы тапсырыстар")</h3>
                        <div class="table-responsive">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>@(Model.Language == "ru" ? "Дата" : Model.Language == "en" ? "Date" : "Күні")</th>
                                        <th>@(Model.Language == "ru" ? "Номер заказа" : Model.Language == "en" ? "Order #" : "Тапсырыс нөмірі")</th>
                                        <th>@(Model.Language == "ru" ? "Клиент" : Model.Language == "en" ? "Customer" : "Клиент")</th>
                                        <th>@(Model.Language == "ru" ? "Способ оплаты" : Model.Language == "en" ? "Payment" : "Төлем тәсілі")</th>
                                        <th class="text-right">@(Model.Language == "ru" ? "Сумма" : Model.Language == "en" ? "Amount" : "Сома")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Report.RecentOrders)
                                    {
                                        <tr>
                                            <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                                            <td>@order.OrderNumber</td>
                                            <td>@order.CustomerName</td>
                                            <td>
                                                @{
                                                    string paymentText = order.PaymentMethod switch
                                                    {
                                                        "Card" => Model.Language == "ru" ? "Карта" : Model.Language == "en" ? "Card" : "Карта",
                                                        "Cash" => Model.Language == "ru" ? "Наличные" : Model.Language == "en" ? "Cash" : "Қолма-қол",
                                                        "Credit" => Model.Language == "ru" ? "Кредит" : Model.Language == "en" ? "Credit" : "Несие",
                                                        _ => order.PaymentMethod
                                                    };
                                                }
                                                @paymentText
                                            </td>
                                            <td class="text-right">@order.TotalAmount.ToString("N0") ₽</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 50px; color: var(--text-muted);">
                            <i class="fas fa-chart-line" style="font-size: 48px; margin-bottom: 20px;"></i>
                            <p>@(Model.Language == "ru" ? "Нет данных за выбранный период" : Model.Language == "en" ? "No data for selected period" : "Таңдалған кезең үшін деректер жоқ")</p>
                        </div>
                    }

                    <div style="margin-top: 30px; display: flex; gap: 10px;">
                        <a asp-page="Index" class="btn-secondary">
                            <i class="fas fa-arrow-left"></i> @(Model.Language == "ru" ? "Назад к отчетам" : Model.Language == "en" ? "Back to reports" : "Есептерге оралу")
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;

            if (menuToggle) {
                menuToggle.addEventListener('click', () => body.classList.toggle('sidebar-open'));
                document.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(e.target) && !menuToggle.contains(e.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            const themeToggle = document.getElementById('themeToggle');
            if (themeToggle) {
                const themeIcon = themeToggle.querySelector('i');
                const savedTheme = localStorage.getItem('theme') || '@Model.Theme';
                if (savedTheme === 'dark') {
                    body.classList.add('dark-theme');
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                }

                themeToggle.addEventListener('click', () => {
                    body.classList.toggle('dark-theme');
                    if (body.classList.contains('dark-theme')) {
                        themeIcon.classList.remove('fa-sun');
                        themeIcon.classList.add('fa-moon');
                        localStorage.setItem('theme', 'dark');
                    } else {
                        themeIcon.classList.remove('fa-moon');
                        themeIcon.classList.add('fa-sun');
                        localStorage.setItem('theme', 'light');
                    }
                });
            }

            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.style.display = 'none', 500);
                }, 5000);
            });

            // Flatpickr
            flatpickr.localize(flatpickr.l10ns.ru);
            flatpickr("#startDate", {
                dateFormat: "Y-m-d",
                maxDate: "today",
                allowInput: true,
                theme: body.classList.contains('dark-theme') ? 'dark' : 'light'
            });
            flatpickr("#endDate", {
                dateFormat: "Y-m-d",
                maxDate: "today",
                allowInput: true,
                theme: body.classList.contains('dark-theme') ? 'dark' : 'light'
            });

            @if (Model.Report.DailySales.Any())
            {
                    <text>
                    // Daily sales chart
                    new Chart(document.getElementById('dailySalesChart'), {
                        type: 'line',
                        data: {
                            labels: [@Html.Raw(string.Join(",", Model.Report.DailySales.Select(d => $"'{d.DayName}'")))],
                            datasets: [{
                                label: '@(Model.Language == "ru" ? "Выручка (₽)" : Model.Language == "en" ? "Revenue (₽)" : "Кіріс (₽)")',
                                data: [@string.Join(",", Model.Report.DailySales.Select(d => d.Revenue))],
                                borderColor: '#FF6B00',
                                backgroundColor: 'rgba(255,107,0,0.1)',
                                borderWidth: 3,
                                tension: 0.3,
                                fill: true
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
                    });

                    // Category chart
                    new Chart(document.getElementById('categoryChart'), {
                        type: 'doughnut',
                        data: {
                            labels: [@Html.Raw(string.Join(",", Model.Report.CategorySales.Select(c => $"'{c.CategoryName}'")))],
                            datasets: [{
                                data: [@string.Join(",", Model.Report.CategorySales.Select(c => c.TotalAmount))],
                                backgroundColor: ['#FF6B00', '#3b82f6', '#10b981', '#8b5cf6', '#ef4444', '#f59e0b'],
                                borderWidth: 0
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
                    });

                    // Payment chart
                    new Chart(document.getElementById('paymentChart'), {
                        type: 'bar',
                        data: {
                            labels: [@Html.Raw(string.Join(",", Model.Report.PaymentMethods.Select(p => $"'{p.MethodDisplay}'")))],
                            datasets: [{
                                label: '@(Model.Language == "ru" ? "Сумма (₽)" : Model.Language == "en" ? "Amount (₽)" : "Сома (₽)")',
                                data: [@string.Join(",", Model.Report.PaymentMethods.Select(p => p.Total))],
                                backgroundColor: '#FF6B00'
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
                    });
                    </text>
            }
        });

        function toggleUserMenu() {
            document.getElementById('userMenu').classList.toggle('show');
        }

        window.addEventListener('click', function(event) {
            const userInfo = document.querySelector('.user-info');
            const userMenu = document.getElementById('userMenu');
            if (!userInfo.contains(event.target) && userMenu.classList.contains('show')) {
                userMenu.classList.remove('show');
            }
        });
    </script>
</body>
</html>