@page
@model Monoplist.Pages.Reports.SalesReportModel
@{
    Layout = null;
    ViewData["Title"] = "Отчет по продажам";
    var userName = User.Identity?.Name ?? "Пользователь";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ru.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.25);
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

            .user-info span {
                font-weight: 500;
                color: var(--text-secondary);
            }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .btn-logout {
            background: none;
            border: 2px solid var(--accent);
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            color: var(--text-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

            .btn-logout:hover {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-color: transparent;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(255,107,0,0.3);
            }

                .btn-logout:hover i {
                    color: white;
                }

        .content {
            padding: 24px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 24px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 2rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 8px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 24px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 12px;
        }

        .filter-panel {
            background: var(--surface-hover);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 30px;
            border: 1px solid var(--border);
        }

        .filter-form {
            display: flex;
            gap: 20px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .date-range {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            flex: 2;
        }

        .filter-group {
            flex: 1;
            min-width: 200px;
        }

            .filter-group label {
                display: block;
                font-weight: 600;
                font-size: 0.85rem;
                color: var(--primary);
                margin-bottom: 6px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .filter-group input {
                width: 100%;
                padding: 12px 15px;
                border: 2px solid var(--border);
                border-radius: 12px;
                background: var(--surface);
                color: var(--text-primary);
                font-family: 'Poppins', sans-serif;
                font-size: 0.95rem;
                transition: var(--transition);
            }

                .filter-group input:focus {
                    outline: none;
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(255,107,0,0.2);
                }

                .filter-group input.flatpickr-input {
                    background-color: var(--surface);
                    cursor: pointer;
                }

        .filter-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: 30px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            font-size: 0.95rem;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255,107,0,0.4);
            }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border: 2px solid var(--border);
            border-radius: 30px;
            background: var(--surface);
            color: var(--text-secondary);
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition);
            font-size: 0.95rem;
        }

            .btn-secondary:hover {
                background: var(--surface-hover);
                border-color: var(--text-muted);
                transform: translateY(-2px);
            }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .kpi-card {
            background: var(--surface-hover);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            border: 1px solid var(--border);
            border-left: 4px solid var(--primary);
        }

        .kpi-value {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--primary);
            line-height: 1.2;
        }

        .kpi-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .chart-card {
            background: var(--surface);
            border-radius: 16px;
            padding: 20px;
            border: 1px solid var(--border);
        }

            .chart-card h3 {
                font-size: 1.1rem;
                color: var(--primary);
                margin-bottom: 15px;
                font-weight: 600;
            }

        .chart-container {
            height: 300px;
            position: relative;
        }

        .table-responsive {
            overflow-x: auto;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--surface);
        }

            .data-table th {
                background: var(--surface-hover);
                padding: 12px 8px;
                text-align: left;
                font-weight: 600;
                color: var(--primary);
                border-bottom: 2px solid var(--accent);
            }

            .data-table td {
                padding: 10px 8px;
                border-bottom: 1px solid var(--border);
                color: var(--text-secondary);
            }

            .data-table tbody tr:hover {
                background: rgba(255,107,0,0.05);
            }

        .text-right {
            text-align: right;
        }

        .export-buttons {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .btn-export {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            transition: var(--transition);
            border: 2px solid transparent;
        }

        .btn-excel {
            background: #1D6F42;
            color: white;
        }

            .btn-excel:hover {
                background: #155a33;
                transform: translateY(-2px);
            }

        .btn-pdf {
            background: #F40F02;
            color: white;
        }

            .btn-pdf:hover {
                background: #c00c00;
                transform: translateY(-2px);
            }

        .btn-csv {
            background: #217346;
            color: white;
        }

            .btn-csv:hover {
                background: #1a5c38;
                transform: translateY(-2px);
            }

        .btn-word {
            background: #2B5797;
            color: white;
        }

            .btn-word:hover {
                background: #1e3f6f;
                transform: translateY(-2px);
            }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                transform: translateX(-100%);
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
            }

            .menu-toggle {
                display: block;
            }

            .charts-row {
                grid-template-columns: 1fr;
            }

            .filter-form {
                flex-direction: column;
                align-items: stretch;
            }

            .date-range {
                flex-direction: column;
            }

            .filter-group {
                width: 100%;
            }

            .export-buttons {
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .export-buttons {
                flex-direction: column;
            }

            .btn-export {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> Главная панель</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> Каталог товаров</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> Продажи</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> Клиенты</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> Склад</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> Поставщики</a></li>
                    <li><a asp-page="/Reports/Index" class="active"><i class="fas fa-chart-line"></i> Отчеты</a></li>
                    <li><a asp-page="/Settings/Index"><i class="fas fa-cog"></i> Настройки</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <span><i class="fas fa-user-circle"></i> @userName</span>
                    <div class="theme-toggle" id="themeToggle" title="Сменить тему">
                        <i class="fas fa-sun"></i>
                    </div>
                    <form method="post" asp-page="/Account/Logout" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Выйти</span>
                        </button>
                    </form>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">Анализ продаж за период</p>

                    <div class="filter-panel">
                        <form method="post" class="filter-form">
                            <div class="date-range">
                                <div class="filter-group">
                                    <label><i class="fas fa-calendar-alt"></i> С</label>
                                    <input type="text" id="startDate" name="Report.StartDate" value="@Model.Report.StartDate.ToString("yyyy-MM-dd")" class="form-control datepicker" />
                                </div>
                                <div class="filter-group">
                                    <label><i class="fas fa-calendar-alt"></i> По</label>
                                    <input type="text" id="endDate" name="Report.EndDate" value="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="form-control datepicker" />
                                </div>
                            </div>
                            <div class="filter-actions">
                                <button type="submit" class="btn-primary">
                                    <i class="fas fa-filter"></i> Применить
                                </button>
                                <a asp-page="SalesReport" class="btn-secondary">
                                    <i class="fas fa-redo"></i> Сброс
                                </a>
                            </div>
                        </form>
                    </div>

                    <div class="export-buttons">
                        <a asp-page="Export" asp-route-type="sales" asp-route-format="excel" asp-route-start="@Model.Report.StartDate.ToString("yyyy-MM-dd")" asp-route-end="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="btn-export btn-excel" target="_blank">
                            <i class="fas fa-file-excel"></i> Excel
                        </a>
                        <a asp-page="Export" asp-route-type="sales" asp-route-format="pdf" asp-route-start="@Model.Report.StartDate.ToString("yyyy-MM-dd")" asp-route-end="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="btn-export btn-pdf" target="_blank">
                            <i class="fas fa-file-pdf"></i> PDF
                        </a>
                        <a asp-page="Export" asp-route-type="sales" asp-route-format="csv" asp-route-start="@Model.Report.StartDate.ToString("yyyy-MM-dd")" asp-route-end="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="btn-export btn-csv" target="_blank">
                            <i class="fas fa-file-csv"></i> CSV
                        </a>
                        <a asp-page="Export" asp-route-type="sales" asp-route-format="word" asp-route-start="@Model.Report.StartDate.ToString("yyyy-MM-dd")" asp-route-end="@Model.Report.EndDate.ToString("yyyy-MM-dd")" class="btn-export btn-word" target="_blank">
                            <i class="fas fa-file-word"></i> Word
                        </a>
                    </div>

                    <div class="kpi-grid">
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.TotalRevenue.ToString("N0") ₽</div>
                            <div class="kpi-label">Общая выручка</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.TotalOrders</div>
                            <div class="kpi-label">Количество заказов</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.AverageOrderValue.ToString("N0") ₽</div>
                            <div class="kpi-label">Средний чек</div>
                        </div>
                    </div>

                    @if (Model.Report.DailySales.Any())
                    {
                        <div class="charts-row">
                            <div class="chart-card">
                                <h3><i class="fas fa-chart-line"></i> Динамика продаж по дням</h3>
                                <div class="chart-container">
                                    <canvas id="dailySalesChart"></canvas>
                                </div>
                            </div>
                            <div class="chart-card">
                                <h3><i class="fas fa-chart-pie"></i> Распределение по категориям</h3>
                                <div class="chart-container">
                                    <canvas id="categoryChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <div class="charts-row">
                            <div class="chart-card">
                                <h3><i class="fas fa-chart-bar"></i> Продажи по способам оплаты</h3>
                                <div class="chart-container">
                                    <canvas id="paymentChart"></canvas>
                                </div>
                            </div>
                            <div class="chart-card">
                                <h3><i class="fas fa-table"></i> Детализация по категориям</h3>
                                <div class="table-responsive" style="height: 300px; overflow-y: auto;">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>Категория</th>
                                                <th class="text-right">Продано (шт)</th>
                                                <th class="text-right">Сумма</th>
                                                <th class="text-right">Доля</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var cat in Model.Report.CategorySales)
                                            {
                                                <tr>
                                                    <td>@cat.CategoryName</td>
                                                    <td class="text-right">@cat.ItemsSold</td>
                                                    <td class="text-right">@cat.TotalAmount.ToString("N0") ₽</td>
                                                    <td class="text-right">@cat.Percentage.ToString("F1")%</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <h3 style="margin: 30px 0 15px; color: var(--primary);">Последние заказы</h3>
                        <div class="table-responsive">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Дата</th>
                                        <th>Номер заказа</th>
                                        <th>Клиент</th>
                                        <th>Способ оплаты</th>
                                        <th class="text-right">Сумма</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Report.RecentOrders)
                                    {
                                        <tr>
                                            <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                                            <td>@order.OrderNumber</td>
                                            <td>@order.CustomerName</td>
                                            <td>
                                                @{
                                                    string paymentText = order.PaymentMethod switch
                                                    {
                                                        "Card" => "Карта",
                                                        "Cash" => "Наличные",
                                                        "Credit" => "Кредит",
                                                        _ => order.PaymentMethod
                                                    };
                                                }
                                                @paymentText
                                            </td>
                                            <td class="text-right">@order.TotalAmount.ToString("N0") ₽</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 50px; color: var(--text-muted);">
                            <i class="fas fa-chart-line" style="font-size: 48px; margin-bottom: 20px;"></i>
                            <p>Нет данных за выбранный период</p>
                        </div>
                    }

                    <div style="margin-top: 30px; display: flex; gap: 10px;">
                        <a asp-page="Index" class="btn-secondary">
                            <i class="fas fa-arrow-left"></i> Назад к отчетам
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Мобильное меню
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;

            if (menuToggle) {
                menuToggle.addEventListener('click', function() {
                    body.classList.toggle('sidebar-open');
                });

                document.addEventListener('click', function(event) {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(event.target) && !menuToggle.contains(event.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            // Переключение темы
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = themeToggle.querySelector('i');

            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                themeIcon.classList.remove('fa-sun');
                themeIcon.classList.add('fa-moon');
            }

            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });

            // Инициализация красивого календаря Flatpickr
            flatpickr.localize(flatpickr.l10ns.ru);

            flatpickr("#startDate", {
                dateFormat: "Y-m-d",
                maxDate: "today",
                allowInput: true,
                theme: body.classList.contains('dark-theme') ? 'dark' : 'light'
            });

            flatpickr("#endDate", {
                dateFormat: "Y-m-d",
                maxDate: "today",
                allowInput: true,
                theme: body.classList.contains('dark-theme') ? 'dark' : 'light'
            });

            @if (Model.Report.DailySales.Any())
            {
                    <text>
                    // График продаж по дням
                    const dailyCtx = document.getElementById('dailySalesChart').getContext('2d');
                    new Chart(dailyCtx, {
                        type: 'line',
                        data: {
                            labels: [@Html.Raw(string.Join(",", Model.Report.DailySales.Select(d => $"'{d.DayName}'")))],
                            datasets: [{
                                label: 'Выручка (₽)',
                                data: [@string.Join(",", Model.Report.DailySales.Select(d => d.Revenue))],
                                borderColor: '#FF6B00',
                                backgroundColor: 'rgba(255,107,0,0.1)',
                                borderWidth: 3,
                                tension: 0.3,
                                fill: true
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            }
                        }
                    });

                    // Круговая диаграмма по категориям
                    const categoryCtx = document.getElementById('categoryChart').getContext('2d');
                    new Chart(categoryCtx, {
                        type: 'doughnut',
                        data: {
                            labels: [@Html.Raw(string.Join(",", Model.Report.CategorySales.Select(c => $"'{c.CategoryName}'")))],
                            datasets: [{
                                data: [@string.Join(",", Model.Report.CategorySales.Select(c => c.TotalAmount))],
                                backgroundColor: ['#FF6B00', '#3b82f6', '#10b981', '#8b5cf6', '#ef4444', '#f59e0b'],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { position: 'bottom' }
                            }
                        }
                    });

                    // Столбчатая диаграмма по способам оплаты
                    const paymentCtx = document.getElementById('paymentChart').getContext('2d');
                    new Chart(paymentCtx, {
                        type: 'bar',
                        data: {
                            labels: [@Html.Raw(string.Join(",", Model.Report.PaymentMethods.Select(p => $"'{p.MethodDisplay}'")))],
                            datasets: [{
                                label: 'Сумма (₽)',
                                data: [@string.Join(",", Model.Report.PaymentMethods.Select(p => p.Total))],
                                backgroundColor: '#FF6B00'
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            }
                        }
                    });
                    </text>
            }
        });
    </script>
</body>
</html>