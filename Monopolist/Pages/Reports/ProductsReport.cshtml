@page
@model Monoplist.Pages.Reports.ProductsReportModel
@{
    Layout = null;
    ViewData["Title"] = "Отчет по товарам";
    var userName = User.Identity?.Name ?? "Пользователь";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Моноплист</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #FF6B00;
            --primary-dark: #E05E00;
            --primary-light: #FF9500;
            --accent: #FFD700;
            --accent-dark: #CC5500;
            --bg: #f5f7fa;
            --surface: #ffffff;
            --surface-hover: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.25);
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --transition: all 0.2s ease;
        }

        body.dark-theme {
            --bg: #1a1a1a;
            --surface: #2d2d2d;
            --surface-hover: #3a3a3a;
            --text-primary: #f0f0f0;
            --text-secondary: #ccc;
            --text-muted: #999;
            --border: #444;
            --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
            --shadow-hover: 0 12px 28px rgba(255,107,0,0.5);
            --success-bg: #064e3b;
            --warning-bg: #92400e;
            --danger-bg: #7f1d1d;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.5;
            transition: background-color 0.3s, color 0.3s;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--surface);
            box-shadow: 2px 0 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            transition: transform 0.3s ease, background 0.3s;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .sidebar-header i {
                font-size: 40px;
                background: linear-gradient(145deg, var(--primary), var(--accent));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                filter: drop-shadow(0 0 5px rgba(255,107,0,0.5));
            }

            .sidebar-header h2 {
                font-size: 24px;
                font-weight: 700;
                background: linear-gradient(135deg, var(--accent), var(--primary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                margin: 0;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

            .sidebar-nav ul {
                list-style: none;
            }

            .sidebar-nav li {
                margin: 4px 8px;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    padding: 12px 16px;
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-weight: 500;
                    border-radius: 12px;
                    transition: var(--transition);
                    gap: 12px;
                }

                    .sidebar-nav li a i {
                        width: 24px;
                        text-align: center;
                        font-size: 1.25rem;
                        color: var(--text-muted);
                        transition: var(--transition);
                    }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        background: linear-gradient(135deg, rgba(255,107,0,0.1), rgba(255,215,0,0.1));
                        color: var(--primary);
                        transform: translateX(4px);
                    }

                        .sidebar-nav li a:hover i,
                        .sidebar-nav li a.active i {
                            color: var(--primary);
                        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
            min-width: 0;
        }

        .top-bar {
            background: var(--surface);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: var(--shadow-sm);
            transition: background 0.3s;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: rgba(255,107,0,0.1);
                color: var(--primary);
            }

        .page-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-right: auto;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

            .user-info span {
                font-weight: 500;
                color: var(--text-secondary);
            }

        .theme-toggle {
            background: none;
            border: 2px solid var(--accent);
            border-radius: 50px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--primary);
            transition: var(--transition);
        }

            .theme-toggle:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
            }

        .btn-logout {
            background: none;
            border: 2px solid var(--accent);
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            color: var(--text-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

            .btn-logout:hover {
                background: linear-gradient(135deg, var(--primary), var(--primary-dark));
                border-color: transparent;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(255,107,0,0.3);
            }

                .btn-logout:hover i {
                    color: white;
                }

        .content {
            padding: 24px;
            flex: 1;
        }

        .dashboard {
            background: var(--surface);
            border-radius: 22px;
            padding: 24px;
            box-shadow: var(--shadow-md);
        }

            .dashboard h1 {
                font-size: 2rem;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 8px;
            }

        .subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 24px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 12px;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .kpi-card {
            background: var(--surface-hover);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            border: 1px solid var(--border);
            border-left: 4px solid var(--primary);
        }

        .kpi-value {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--primary);
            line-height: 1.2;
        }

        .kpi-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .chart-card {
            background: var(--surface);
            border-radius: 16px;
            padding: 20px;
            border: 1px solid var(--border);
        }

            .chart-card h3 {
                font-size: 1.1rem;
                color: var(--primary);
                margin-bottom: 15px;
                font-weight: 600;
            }

        .chart-container {
            height: 300px;
            position: relative;
        }

        .table-responsive {
            overflow-x: auto;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--surface);
        }

            .data-table th {
                background: var(--surface-hover);
                padding: 12px 8px;
                text-align: left;
                font-weight: 600;
                color: var(--primary);
                border-bottom: 2px solid var(--accent);
            }

            .data-table td {
                padding: 10px 8px;
                border-bottom: 1px solid var(--border);
                color: var(--text-secondary);
            }

            .data-table tbody tr:hover {
                background: rgba(255,107,0,0.05);
            }

        .text-right {
            text-align: right;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .status-low {
            background: var(--danger-bg);
            color: var(--danger);
        }

        .status-normal {
            background: var(--success-bg);
            color: var(--success);
        }

        .status-empty {
            background: var(--warning-bg);
            color: var(--warning);
        }

        .export-buttons {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .btn-export {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            transition: var(--transition);
            border: 2px solid transparent;
        }

        .btn-excel {
            background: #1D6F42;
            color: white;
        }

            .btn-excel:hover {
                background: #155a33;
                transform: translateY(-2px);
            }

        .btn-pdf {
            background: #F40F02;
            color: white;
        }

            .btn-pdf:hover {
                background: #c00c00;
                transform: translateY(-2px);
            }

        .btn-csv {
            background: #217346;
            color: white;
        }

            .btn-csv:hover {
                background: #1a5c38;
                transform: translateY(-2px);
            }

        .btn-word {
            background: #2B5797;
            color: white;
        }

            .btn-word:hover {
                background: #1e3f6f;
                transform: translateY(-2px);
            }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -280px;
                transform: translateX(-100%);
            }

            body.sidebar-open .sidebar {
                transform: translateX(0);
            }

            .menu-toggle {
                display: block;
            }

            .charts-row {
                grid-template-columns: 1fr;
            }

            .export-buttons {
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .btn-logout span {
                display: none;
            }

            .export-buttons {
                flex-direction: column;
            }

            .btn-export {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-helmet-safety"></i>
                <h2>Моноплист</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-page="/Index"><i class="fas fa-home"></i> Главная панель</a></li>
                    <li><a asp-page="/Products/Index"><i class="fas fa-box"></i> Каталог товаров</a></li>
                    <li><a asp-page="/Orders/Index"><i class="fas fa-shopping-cart"></i> Продажи</a></li>
                    <li><a asp-page="/Customers/Index"><i class="fas fa-users"></i> Клиенты</a></li>
                    <li><a asp-page="/Warehouse/Index"><i class="fas fa-warehouse"></i> Склад</a></li>
                    <li><a asp-page="/Suppliers/Index"><i class="fas fa-truck"></i> Поставщики</a></li>
                    <li><a asp-page="/Reports/Index" class="active"><i class="fas fa-chart-line"></i> Отчеты</a></li>
                    <li><a asp-page="/Settings/Index"><i class="fas fa-cog"></i> Настройки</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="user-info">
                    <span><i class="fas fa-user-circle"></i> @userName</span>
                    <div class="theme-toggle" id="themeToggle" title="Сменить тему">
                        <i class="fas fa-sun"></i>
                    </div>
                    <form method="post" asp-page="/Account/Logout" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Выйти</span>
                        </button>
                    </form>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">Анализ товарных запасов</p>

                    <div class="export-buttons">
                        <a asp-page="Export" asp-route-type="products" asp-route-format="excel" class="btn-export btn-excel" target="_blank">
                            <i class="fas fa-file-excel"></i> Excel
                        </a>
                        <a asp-page="Export" asp-route-type="products" asp-route-format="pdf" class="btn-export btn-pdf" target="_blank">
                            <i class="fas fa-file-pdf"></i> PDF
                        </a>
                        <a asp-page="Export" asp-route-type="products" asp-route-format="csv" class="btn-export btn-csv" target="_blank">
                            <i class="fas fa-file-csv"></i> CSV
                        </a>
                        <a asp-page="Export" asp-route-type="products" asp-route-format="word" class="btn-export btn-word" target="_blank">
                            <i class="fas fa-file-word"></i> Word
                        </a>
                    </div>

                    <div class="kpi-grid">
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.TotalProducts</div>
                            <div class="kpi-label">Всего товаров</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.TotalInventoryValue.ToString("N0") ₽</div>
                            <div class="kpi-label">Общая стоимость запасов</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.LowStockCount</div>
                            <div class="kpi-label">Малый остаток</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.Report.OutOfStockCount</div>
                            <div class="kpi-label">Отсутствуют</div>
                        </div>
                    </div>

                    <div class="charts-row">
                        <div class="chart-card">
                            <h3><i class="fas fa-chart-pie"></i> Распределение по категориям</h3>
                            <div class="chart-container">
                                <canvas id="categoryChart"></canvas>
                            </div>
                        </div>
                        <div class="chart-card">
                            <h3><i class="fas fa-chart-bar"></i> Топ-10 товаров по стоимости</h3>
                            <div class="chart-container">
                                <canvas id="topProductsChart"></canvas>
                            </div>
                        </div>
                    </div>

                    <h3 style="margin: 30px 0 15px; color: var(--primary);">Товары с низким остатком</h3>
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Артикул</th>
                                    <th>Наименование</th>
                                    <th>Категория</th>
                                    <th class="text-right">Остаток</th>
                                    <th class="text-right">Минимум</th>
                                    <th>Статус</th>
                                    <th class="text-right">Цена закупки</th>
                                    <th class="text-right">Цена продажи</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Report.LowStockProducts)
                                {
                                    <tr>
                                        <td>@p.Article</td>
                                        <td>@p.Name</td>
                                        <td>@p.Category</td>
                                        <td class="text-right">@p.CurrentStock</td>
                                        <td class="text-right">@p.MinimumStock</td>
                                        <td>
                                            @{
                                                string statusClass = p.CurrentStock == 0 ? "status-empty" : "status-low";
                                                string statusText = p.CurrentStock == 0 ? "Отсутствует" : "Малый остаток";
                                            }
                                            <span class="status-badge @statusClass">@statusText</span>
                                        </td>
                                        <td class="text-right">@p.PurchasePrice.ToString("N0") ₽</td>
                                        <td class="text-right">@p.SalePrice.ToString("N0") ₽</td>
                                    </tr>
                                }
                                @if (!Model.Report.LowStockProducts.Any())
                                {
                                    <tr>
                                        <td colspan="8" class="text-center" style="padding: 20px; color: var(--text-muted);">
                                            Нет товаров с низким остатком
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <h3 style="margin: 30px 0 15px; color: var(--primary);">Статистика по категориям</h3>
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Категория</th>
                                    <th class="text-right">Кол-во товаров</th>
                                    <th class="text-right">Общий остаток</th>
                                    <th class="text-right">Стоимость</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Report.CategoryStock)
                                {
                                    <tr>
                                        <td>@c.CategoryName</td>
                                        <td class="text-right">@c.ProductsCount</td>
                                        <td class="text-right">@c.TotalStock</td>
                                        <td class="text-right">@c.TotalValue.ToString("N0") ₽</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <h3 style="margin: 30px 0 15px; color: var(--primary);">Топ-10 товаров по стоимости</h3>
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Артикул</th>
                                    <th>Наименование</th>
                                    <th>Категория</th>
                                    <th class="text-right">Остаток</th>
                                    <th class="text-right">Цена закупки</th>
                                    <th class="text-right">Стоимость</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Report.TopProducts)
                                {
                                    <tr>
                                        <td>@p.Article</td>
                                        <td>@p.Name</td>
                                        <td>@p.Category</td>
                                        <td class="text-right">@p.CurrentStock</td>
                                        <td class="text-right">@p.PurchasePrice.ToString("N0") ₽</td>
                                        <td class="text-right">@p.StockValue.ToString("N0") ₽</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div style="margin-top: 30px;">
                        <a asp-page="Index" class="btn-secondary" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 24px; border: 2px solid var(--border); border-radius: 30px; background: var(--surface); color: var(--text-secondary); text-decoration: none;">
                            <i class="fas fa-arrow-left"></i> Назад к отчетам
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const body = document.body;

            if (menuToggle) {
                menuToggle.addEventListener('click', function() {
                    body.classList.toggle('sidebar-open');
                });

                document.addEventListener('click', function(event) {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.querySelector('.sidebar');
                        if (!sidebar.contains(event.target) && !menuToggle.contains(event.target) && body.classList.contains('sidebar-open')) {
                            body.classList.remove('sidebar-open');
                        }
                    }
                });
            }

            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = themeToggle.querySelector('i');

            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                body.classList.add('dark-theme');
                themeIcon.classList.remove('fa-sun');
                themeIcon.classList.add('fa-moon');
            }

            themeToggle.addEventListener('click', function() {
                body.classList.toggle('dark-theme');
                if (body.classList.contains('dark-theme')) {
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                    localStorage.setItem('theme', 'dark');
                } else {
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                    localStorage.setItem('theme', 'light');
                }
            });

            @if (Model.Report.CategoryStock.Any())
            {
                    <text>
                    const catCtx = document.getElementById('categoryChart').getContext('2d');
                    new Chart(catCtx, {
                        type: 'doughnut',
                        data: {
                            labels: [@Html.Raw(string.Join(",", Model.Report.CategoryStock.Select(c => $"'{c.CategoryName}'")))],
                            datasets: [{
                                data: [@string.Join(",", Model.Report.CategoryStock.Select(c => c.TotalValue))],
                                backgroundColor: ['#FF6B00', '#3b82f6', '#10b981', '#8b5cf6', '#ef4444', '#f59e0b', '#ec4899', '#14b8a6', '#f97316', '#6366f1'],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { position: 'bottom' }
                            }
                        }
                    });
                    </text>
            }

            @if (Model.Report.TopProducts.Any())
            {
                    <text>
                    const topCtx = document.getElementById('topProductsChart').getContext('2d');
                    new Chart(topCtx, {
                        type: 'bar',
                        data: {
                            labels: [@Html.Raw(string.Join(",", Model.Report.TopProducts.Select(p => $"'{p.Name}'")))],
                            datasets: [{
                                label: 'Стоимость (₽)',
                                data: [@string.Join(",", Model.Report.TopProducts.Select(p => p.StockValue))],
                                backgroundColor: '#FF6B00'
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                y: {
                                    ticks: {
                                        callback: function(value) {
                                            return value.toLocaleString() + ' ₽';
                                        }
                                    }
                                }
                            }
                        }
                    });
                    </text>
            }
        });
    </script>
</body>
</html>