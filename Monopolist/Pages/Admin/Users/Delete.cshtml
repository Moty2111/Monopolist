@page
@model Monoplist.Pages.Admin.Users.DeleteModel
@{
    ViewData["Title"] = "Удаление пользователя";
}
<div class="dashboard">
    <h1>@ViewData["Title"]</h1>
    <p class="subtitle">Вы уверены, что хотите удалить этого пользователя?</p>

    <div class="delete-confirmation">
        <dl class="row">
            <dt class="col-sm-3">Имя пользователя</dt>
            <dd class="col-sm-9">@Model.UserToDelete.Username</dd>

            <dt class="col-sm-3">Роль</dt>
            <dd class="col-sm-9">@Model.UserToDelete.Role</dd>
        </dl>

        <form method="post" asp-page-handler="Delete" asp-route-id="@Model.UserToDelete.Id">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-danger"><i class="fas fa-trash"></i> Удалить</button>
            <a asp-page="Index" class="btn-secondary"><i class="fas fa-times"></i> Отмена</a>
        </form>
    </div>
</div>