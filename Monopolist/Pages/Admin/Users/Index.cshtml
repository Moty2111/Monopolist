@page
@model Monoplist.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Управление пользователями";
}
<div class="dashboard">
    <h1>@ViewData["Title"]</h1>
    <p class="subtitle">Администрирование учётных записей</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        </div>
    }

    <p>
        <a asp-page="Create" class="btn-primary">
            <i class="fas fa-plus"></i> Создать пользователя
        </a>
    </p>

    @if (Model.Users.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Имя пользователя</th>
                    <th>Роль</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>
                            <span class="status-badge status-@user.Role.ToLower()">@user.Role</span>
                        </td>
                        <td class="actions">
                            <a asp-page="Edit" asp-route-id="@user.Id" class="btn-sm btn-primary" title="Редактировать">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-page="ChangePassword" asp-route-id="@user.Id" class="btn-sm btn-info" title="Сменить пароль">
                                <i class="fas fa-key"></i>
                            </a>
                            @if (user.Username != User.Identity?.Name)
                            {
                                <a asp-page="Delete" asp-route-id="@user.Id" class="btn-sm btn-danger" title="Удалить">
                                    <i class="fas fa-trash"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Нет пользователей.</p>
    }
</div>

<style>
    .actions {
        white-space: nowrap;
    }

        .actions a {
            margin-right: 5px;
        }
</style>