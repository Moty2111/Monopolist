@model IEnumerable<Monoplist.ViewModels.UserIndexViewModel>
@{
    Layout = null; // отключаем общий макет, делаем страницу самостоятельной
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Управление пользователями - Моноплист" />
    <title>Управление пользователями | Моноплист</title>

    <!-- Подключение шрифтов и иконок -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />

    <!-- Дополнительные стили для корректного отображения без сайдбара -->
    <style>
        .app {
            display: flex;
            min-height: 100vh;
        }
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #f8fafc;
        }
        .top-bar {
            background: #ffffff;
            padding: 16px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #FFD700;
        }
        .page-title {
            font-size: 24px;
            font-weight: 600;
            color: #0f172a;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .btn-logout {
            background: none;
            border: 2px solid #FFD700;
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            color: #0f172a;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .btn-logout:hover {
            background: linear-gradient(135deg, #FF6B00, #FF4500);
            border-color: transparent;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,107,0,0.3);
        }
        .content {
            padding: 32px;
            flex: 1;
        }
        .table-header {
            margin-bottom: 20px;
        }
        .inline-form {
            display: inline-block;
        }
        .actions {
            white-space: nowrap;
        }
        .role-select {
            padding: 4px 8px;
            border-radius: 4px;
            border: 1px solid #ccc;
        }
        .visually-hidden {
            position: absolute;
            width: 1px;
            height: 1px;
            margin: -1px;
            padding: 0;
            overflow: hidden;
            border: 0;
            clip: rect(0,0,0,0);
        }
    </style>
</head>
<body>
    <div class="app">
        <main class="main-content">
            <header class="top-bar">
                <div class="page-title">@ViewData["Title"]</div>
                <div class="user-info">
                    <span>@User.Identity?.Name</span>
                    <form asp-action="Logout" asp-controller="Account" method="post" class="logout-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout" aria-label="Выйти из системы">
                            <i class="fas fa-sign-out-alt"></i> Выйти
                        </button>
                    </form>
                </div>
            </header>

            <div class="content">
                <div class="dashboard">
                    <h1>@ViewData["Title"]</h1>
                    <p class="subtitle">Администрирование учётных записей</p>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle"></i> @TempData["Success"]
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                        </div>
                    }

                    <div class="table-header">
                        <a asp-action="Create" class="btn-primary">
                            <i class="fas fa-plus"></i> Создать пользователя
                        </a>
                    </div>

                    @if (Model.Any())
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Имя пользователя</th>
                                    <th>Роль</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td>@user.Username</td>
                                        <td>
                                            <span class="status-badge status-@user.Role.ToLower()">@user.Role</span>
                                        </td>
                                        <td class="actions">
                                            <form asp-action="ChangeRole" method="post" class="inline-form" title="Изменить роль">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@user.Id" />
                                                <label for="role-@user.Id" class="visually-hidden">Роль для @user.Username</label>
                                                <select id="role-@user.Id" name="Role" class="role-select">
                                                    <option value="Admin" selected="@(user.Role == "Admin")">Admin</option>
                                                    <option value="Manager" selected="@(user.Role == "Manager")">Manager</option>
                                                    <option value="Seller" selected="@(user.Role == "Seller")">Seller</option>
                                                </select>
                                                <button type="submit" class="btn-sm btn-primary" title="Сохранить роль">
                                                    <i class="fas fa-sync-alt"></i>
                                                </button>
                                            </form>

                                            <a asp-action="ChangePassword" asp-route-id="@user.Id" class="btn-sm btn-info" title="Сменить пароль">
                                                <i class="fas fa-key"></i>
                                            </a>

                                            @if (user.Username != User.Identity?.Name)
                                            {
                                                <form asp-action="DeleteUser" method="post" class="inline-form"
                                                      onsubmit="return confirm('Удалить пользователя @user.Username?');" title="Удалить пользователя">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit" class="btn-sm btn-danger">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">Нет пользователей.</p>
                    }
                </div>
            </div>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>